<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>관리자 대시보드</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    body {
      background: #f3f5fb;
      color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      padding: 28px 16px;
    }
    .wrap { max-width: 880px; margin: 0 auto; }
    .card-soft {
      background: #fff;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
      margin-bottom: 20px;
    }
    .card-soft h2 {
      font-size: 1.05rem;
      font-weight: 700;
      margin-bottom: 14px;
      color: #0f172a;
    }
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin-bottom: 8px;
    }
    .meta-cell {
      background: #f8fafc;
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 0.82rem;
    }
    .meta-cell .label { color: #64748b; font-size: 0.72rem; margin-bottom: 4px; }
    .meta-cell .value { font-weight: 600; color: #0f172a; }
    .badge-soft {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
    }
    .badge-soft.on  { background: #dcfce7; color: #166534; }
    .badge-soft.off { background: #fee2e2; color: #991b1b; }
    .badge-soft.run { background: #fef3c7; color: #92400e; }
    table.subs { font-size: 0.88rem; }
    table.subs th { font-weight: 600; color: #475569; font-size: 0.78rem; }
    table.subs td { vertical-align: middle; }
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
    }
    .topbar h1 {
      font-size: 1.3rem;
      font-weight: 700;
      margin: 0;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <h1><i class="bi bi-speedometer2 me-2"></i>관리자 대시보드</h1>
      <a href="/admin/logout" class="text-decoration-none text-secondary small">
        <i class="bi bi-box-arrow-right me-1"></i>로그아웃
      </a>
    </div>

    <% if (flash) { %>
      <%
        const flashMap = {
          missing_email: { type: "danger", msg: "이메일이 비어 있습니다." },
          not_found: { type: "danger", msg: "해당 이메일을 찾을 수 없습니다." },
          removed: { type: "success", msg: "구독자를 제거했습니다." },
          pattern_seeding: { type: "warning", msg: "패턴 시드가 이미 진행 중입니다." },
          pattern_seed_started: { type: "success", msg: "패턴 시드를 시작했습니다 (4~8분 소요). 새로고침으로 진행 확인." },
          pattern_analyzing: { type: "warning", msg: "패턴 분석이 이미 진행 중입니다." },
          pattern_analyze_started: { type: "success", msg: "패턴 분석을 시작했습니다 (~1분). 완료 후 /pattern 페이지에서 결과 확인." },
        };
        const f = flashMap[flash];
      %>
      <% if (f) { %>
        <div class="alert alert-<%= f.type %> small"><%= f.msg %></div>
      <% } %>
    <% } %>

    <div class="card-soft">
      <h2><i class="bi bi-info-circle me-1"></i>운영 상태</h2>
      <div class="meta-grid">
        <div class="meta-cell">
          <div class="label">구독자</div>
          <div class="value"><%= subscribers.length %> / <%= maxSubscribers %></div>
        </div>
        <% if (typeof stocksMaster !== 'undefined' && stocksMaster) { %>
          <div class="meta-cell">
            <div class="label">종목 마스터</div>
            <div class="value">
              <% if (stocksMaster.stale) { %>
                <span class="badge-soft run"><%= stocksMaster.ageDays %>일 전 ⚠</span>
              <% } else { %>
                <%= stocksMaster.ageDays %>일 전
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
      <% if (typeof seededCount !== 'undefined') { %>
        <div class="meta-cell mt-2">
          <div class="label">패턴 스크리너 시드</div>
          <div class="value"><%= seededCount %> 종목 (시총 50억~500억)</div>
        </div>
      <% } %>
      <div class="alert alert-info small mt-2 mb-0">
        스윙/단타 스캔, 백테스트, 자동 메일 발송, AI 가중치 튜너는 점수 모델 재설계 중이라 일시 비활성화되었습니다.
      </div>
    </div>

    <div class="card-soft">
      <h2><i class="bi bi-people me-1"></i>구독자 (<%= subscribers.length %>)</h2>
      <% if (subscribers.length === 0) { %>
        <div class="small text-muted">구독자가 없습니다.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-sm subs align-middle">
            <thead>
              <tr>
                <th>이메일</th>
                <th>구독일</th>
                <th class="text-end">관리</th>
              </tr>
            </thead>
            <tbody>
              <% subscribers.forEach(function(sub) { %>
                <tr>
                  <td><%= sub.email %></td>
                  <td>
                    <% if (sub.subscribedAt) { %>
                      <%= new Date(sub.subscribedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <form method="post" action="/admin/unsubscribe" class="d-inline" onsubmit="return confirm('<%= sub.email %> 을(를) 구독 해제할까요?');">
                      <input type="hidden" name="email" value="<%= sub.email %>" />
                      <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-x-circle"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="text-center small text-secondary mt-3">
      <a href="/" class="text-decoration-none text-secondary me-3"><i class="bi bi-arrow-left me-1"></i>홈으로</a>
      <a href="/subscribe" class="text-decoration-none text-secondary"><i class="bi bi-envelope-plus me-1"></i>구독 페이지</a>
    </div>
  </div>
</body>
</html>
