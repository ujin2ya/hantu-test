<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>관리자 대시보드</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    body {
      background: #f3f5fb;
      color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      padding: 28px 16px;
    }
    .wrap { max-width: 880px; margin: 0 auto; }
    .card-soft {
      background: #fff;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
      margin-bottom: 20px;
    }
    .card-soft h2 {
      font-size: 1.05rem;
      font-weight: 700;
      margin-bottom: 14px;
      color: #0f172a;
    }
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin-bottom: 8px;
    }
    .meta-cell {
      background: #f8fafc;
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 0.82rem;
    }
    .meta-cell .label { color: #64748b; font-size: 0.72rem; margin-bottom: 4px; }
    .meta-cell .value { font-weight: 600; color: #0f172a; }
    .badge-soft {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
    }
    .badge-soft.on  { background: #dcfce7; color: #166534; }
    .badge-soft.off { background: #fee2e2; color: #991b1b; }
    .badge-soft.run { background: #fef3c7; color: #92400e; }
    table.subs { font-size: 0.88rem; }
    table.subs th { font-weight: 600; color: #475569; font-size: 0.78rem; }
    table.subs td { vertical-align: middle; }
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
    }
    .topbar h1 {
      font-size: 1.3rem;
      font-weight: 700;
      margin: 0;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <h1><i class="bi bi-speedometer2 me-2"></i>관리자 대시보드</h1>
      <a href="/admin/logout" class="text-decoration-none text-secondary small">
        <i class="bi bi-box-arrow-right me-1"></i>로그아웃
      </a>
    </div>

    <% if (flash) { %>
      <%
        const flashMap = {
          missing_email: { type: "danger", msg: "이메일이 비어 있습니다." },
          not_found: { type: "danger", msg: "해당 이메일을 찾을 수 없습니다." },
          removed: { type: "success", msg: "구독자를 제거했습니다." },
          pattern_seeding: { type: "warning", msg: "패턴 시드가 이미 진행 중입니다." },
          pattern_seed_started: { type: "success", msg: "패턴 시드를 시작했습니다 (4~8분 소요). 새로고침으로 진행 확인." },
          pattern_analyzing: { type: "warning", msg: "패턴 분석이 이미 진행 중입니다." },
          pattern_analyze_started: { type: "success", msg: "패턴 분석을 시작했습니다 (~1분). 완료 후 /pattern 페이지에서 결과 확인." },
          mail_sent: { type: "success", msg: "VVI 신호 메일을 발송했습니다." },
          no_result: { type: "danger", msg: "pattern-result.json 파일이 없습니다. 먼저 분석을 실행하세요." },
          mail_error: { type: "danger", msg: "메일 발송 중 오류가 발생했습니다." },
        };
        const f = flashMap[flash];
      %>
      <% if (f) { %>
        <div class="alert alert-<%= f.type %> small"><%= f.msg %></div>
      <% } %>
    <% } %>

    <div class="card-soft">
      <h2><i class="bi bi-info-circle me-1"></i>운영 상태</h2>
      <div class="meta-grid">
        <div class="meta-cell">
          <div class="label">구독자</div>
          <div class="value"><%= subscribers.length %> / <%= maxSubscribers %></div>
        </div>
        <% if (typeof stocksMaster !== 'undefined' && stocksMaster) { %>
          <div class="meta-cell">
            <div class="label">종목 마스터</div>
            <div class="value">
              <% if (stocksMaster.stale) { %>
                <span class="badge-soft run"><%= stocksMaster.ageDays %>일 전 ⚠</span>
              <% } else { %>
                <%= stocksMaster.ageDays %>일 전
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
      <% if (typeof seededCount !== 'undefined') { %>
        <div class="meta-cell mt-2">
          <div class="label">차트 시드 종목</div>
          <div class="value"><%= seededCount %> 종목 — 일봉 캐시 (cache/stock-charts-long)</div>
        </div>
      <% } %>
      <div class="alert alert-info small mt-2 mb-0">
        현재 메인 모델: <strong>CompressionSupportBreakout (CSB)</strong> — 4태그 통과 = 상승 전 압축 후보, 3태그 = 예비 압축. 보조 모델 = Rebound (과매도 반등).
        FlowLead v1~v4 / 점수 시스템은 백테스트 검증 실패로 메인에서 제외.
      </div>
    </div>

    <div class="card-soft">
      <h2><i class="bi bi-graph-up-arrow me-1"></i>종목 분석 파이프라인</h2>
      <div class="small text-secondary mb-3">
        <strong>① 시드</strong>: KRX 일봉 차트 데이터 다운로드 (cache 갱신, 모델 무관) ·
        <strong>② 분석</strong>: <code>analyzeAll()</code> 호출 = 현재 코드의 CSB 모델 기준 재분석 (cache/pattern-result.json 업데이트) ·
        <strong>⚡ 일일 업데이트</strong>: pykrx + Naver 최근 5거래일 차트/수급 갱신 + 재분석 (일반적으로 매일 16:20 자동 실행)
        <br>새 코드 배포 후엔 반드시 <strong>② 분석</strong>을 다시 실행해야 /pattern 페이지에 반영됩니다.
      </div>
      <% if (typeof patternState !== 'undefined' && patternState) { %>
        <div class="row g-2 mb-3">
          <div class="col-12 col-md-6">
            <div class="meta-cell">
              <div class="label">시드 상태</div>
              <div class="value">
                <% if (patternState.seeding) { %>
                  <span class="badge-soft run">진행 중</span>
                  <% if (patternState.seedProgress?.total) { %>
                    <span class="text-secondary small ms-2"><%= patternState.seedProgress.i %>/<%= patternState.seedProgress.total %> · <%= patternState.seedProgress.code %> <%= patternState.seedProgress.name %></span>
                  <% } %>
                <% } else if (patternState.seedFinishedAt) { %>
                  <span class="badge-soft on">완료</span>
                  <span class="text-secondary small ms-2"><%= new Date(patternState.seedFinishedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %></span>
                <% } else { %>
                  <span class="text-secondary small">미실행</span>
                <% } %>
                <% if (patternState.seedError) { %>
                  <div class="text-danger small mt-1"><%= patternState.seedError %></div>
                <% } %>
              </div>
            </div>
          </div>
          <div class="col-12 col-md-6">
            <div class="meta-cell">
              <div class="label">분석 상태</div>
              <div class="value">
                <% if (patternState.analyzing) { %>
                  <span class="badge-soft run">진행 중</span>
                <% } else if (patternState.analyzeFinishedAt) { %>
                  <span class="badge-soft on">완료</span>
                  <span class="text-secondary small ms-2"><%= new Date(patternState.analyzeFinishedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %></span>
                <% } else { %>
                  <span class="text-secondary small">미실행</span>
                <% } %>
                <% if (patternState.analyzeError) { %>
                  <div class="text-danger small mt-1"><%= patternState.analyzeError %></div>
                <% } %>
              </div>
            </div>
          </div>
          <div class="col-12 col-md-6">
            <div class="meta-cell">
              <div class="label">일일 업데이트 상태</div>
              <div class="value">
                <% if (patternState.dailyUpdating) { %>
                  <span class="badge-soft run">분석중</span>
                  <span class="text-secondary small ms-2">약 20~30분 소요 (차트 + 수급 + 분석)</span>
                <% } else if (patternState.dailyUpdateFinishedAt) { %>
                  <span class="badge-soft on">분석끝</span>
                  <span class="text-secondary small ms-2"><%= new Date(patternState.dailyUpdateFinishedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %></span>
                <% } else { %>
                  <span class="text-secondary small">미실행</span>
                <% } %>
                <% if (patternState.dailyUpdateError) { %>
                  <div class="text-danger small mt-1"><%= patternState.dailyUpdateError %></div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% } %>
      <div class="d-flex gap-2 flex-wrap">
        <form method="post" action="/admin/pattern/seed" class="m-0" onsubmit="return confirm('① 차트 시드를 다시 실행할까요? 기존 캐시는 유지, 신규 종목만 추가 (~10분).');">
          <button type="submit" class="btn btn-outline-primary btn-sm" <%= (typeof patternState !== 'undefined' && patternState?.seeding) ? 'disabled' : '' %>>
            <i class="bi bi-cloud-download me-1"></i>① 차트 시드 (KRX 일봉)
          </button>
        </form>
        <form method="post" action="/admin/pattern/analyze" class="m-0" onsubmit="return confirm('② 분석을 다시 실행할까요? CSB 모델 기준 재분석 후 /pattern 페이지 반영 (~1분).');">
          <button type="submit" class="btn btn-success btn-sm" <%= (typeof patternState !== 'undefined' && patternState?.analyzing) ? 'disabled' : '' %>>
            <i class="bi bi-cpu me-1"></i>② 분석 실행 (CSB 모델)
          </button>
        </form>
        <button type="button" class="btn btn-outline-info btn-sm"
          <%= (typeof patternState !== 'undefined' && patternState?.dailyUpdating) ? 'disabled' : '' %>
          onclick="runDailyUpdate()">
          <i class="bi bi-arrow-clockwise me-1"></i>⚡ 일일 업데이트
        </button>
        <form method="post" action="/admin/send-pattern-mail" class="m-0" onsubmit="return confirm('VVI 신호 메일을 지금 발송할까요?');">
          <button type="submit" class="btn btn-outline-warning btn-sm">
            <i class="bi bi-envelope-check me-1"></i>③ VVI 신호 메일 발송
          </button>
        </form>
        <a href="/pattern" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-eye me-1"></i>/pattern 보기
        </a>
      </div>
      <div class="small text-secondary mt-2">
        ※ 새 코드 배포 직후엔 <strong>② 분석 실행</strong> 만 누르면 됩니다. 시드는 KRX 일봉 갱신이 필요할 때만.
      </div>
    </div>

    <div class="card-soft">
      <h2><i class="bi bi-people me-1"></i>구독자 (<%= subscribers.length %>)</h2>
      <% if (subscribers.length === 0) { %>
        <div class="small text-muted">구독자가 없습니다.</div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-sm subs align-middle">
            <thead>
              <tr>
                <th>이메일</th>
                <th>구독일</th>
                <th class="text-end">관리</th>
              </tr>
            </thead>
            <tbody>
              <% subscribers.forEach(function(sub) { %>
                <tr>
                  <td><%= sub.email %></td>
                  <td>
                    <% if (sub.subscribedAt) { %>
                      <%= new Date(sub.subscribedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <form method="post" action="/admin/unsubscribe" class="d-inline" onsubmit="return confirm('<%= sub.email %> 을(를) 구독 해제할까요?');">
                      <input type="hidden" name="email" value="<%= sub.email %>" />
                      <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-x-circle"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="text-center small text-secondary mt-3">
      <a href="/" class="text-decoration-none text-secondary me-3"><i class="bi bi-arrow-left me-1"></i>홈으로</a>
      <a href="/subscribe" class="text-decoration-none text-secondary"><i class="bi bi-envelope-plus me-1"></i>구독 페이지</a>
    </div>
  </div>

  <script>
    async function runDailyUpdate() {
      const msg = '일일 업데이트를 실행할까요? (차트 + 수급 + 분석, 약 20~30분 소요)';
      if (!confirm(msg)) return;

      try {
        const resp = await fetch('/admin/run-daily-update', { method: 'POST' });
        if (resp.ok) {
          // 서버 상태 업데이트 대기 후 페이지 새로고침 (300ms)
          setTimeout(() => {
            location.reload();
          }, 300);
        } else {
          alert('요청 실패: ' + resp.status);
        }
      } catch (e) {
        alert('오류: ' + e.message);
      }
    }
  </script>
</body>
</html>
