<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>패턴 스크리너 — 종목 상태 분석 도구</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    body {
      background: #f3f5fb; color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      padding: 24px 16px;
    }
    .wrap { max-width: 1100px; margin: 0 auto; }
    .glass { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 6px 18px rgba(15,23,42,0.06); margin-bottom: 20px; }
    .glass.compact { padding: 16px 18px; }
    h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 6px; }
    h2 { font-size: 1.1rem; font-weight: 700; margin: 0 0 14px; color: #0f172a; }
    h2 .count { color: #64748b; font-weight: 500; font-size: 0.85rem; margin-left: 6px; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; flex-wrap: wrap; gap: 8px; }

    /* 현황 셀 */
    .meta-cell { background: #f8fafc; border-radius: 10px; padding: 10px 12px; }
    .meta-cell .label { color: #64748b; font-size: 0.72rem; margin-bottom: 4px; }
    .meta-cell .value { font-weight: 700; color: #0f172a; font-size: 1.05rem; }

    /* 카테고리 배너 — 모델 설명 */
    .cat-banner {
      background: #f1f5f9; border-left: 4px solid #94a3b8; padding: 10px 14px;
      border-radius: 0 8px 8px 0; font-size: 0.82rem; color: #475569; margin-bottom: 12px;
    }
    .cat-banner.flow    { background: #eff6ff; border-color: #3b82f6; color: #1e40af; }
    .cat-banner.rebound { background: #f0fdf4; border-color: #10b981; color: #065f46; }
    .cat-banner.bull    { background: #fefce8; border-color: #eab308; color: #854d0e; }
    .cat-banner.warn    { background: #fef2f2; border-color: #ef4444; color: #991b1b; }
    .cat-banner.holding { background: #faf5ff; border-color: #a855f7; color: #6b21a8; }
    .cat-banner.report  { background: #f8fafc; border-color: #475569; color: #334155; }

    /* 종목 카드 */
    .item-card { background: #f8fafc; border-radius: 10px; padding: 12px 14px; margin-bottom: 8px; }
    .item-card .row1 { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
    .item-card .name-block { flex: 1; min-width: 0; }
    .item-card .nm { font-weight: 700; color: #0f172a; }
    .item-card .cd { color: #94a3b8; font-size: 0.78rem; margin-left: 4px; }
    .item-card .mkt { color: #64748b; font-size: 0.7rem; margin-left: 6px; padding: 1px 6px; background: #e2e8f0; border-radius: 4px; }
    /* 종목명 클릭 → 상세 페이지 (/?query=code) */
    .item-card a.deep-link { text-decoration: none; color: inherit; display: inline-flex; align-items: center; gap: 4px; }
    .item-card a.deep-link:hover .nm { color: #2563eb; text-decoration: underline; }
    .item-card .row2, .item-card .row3 { display: flex; flex-wrap: wrap; gap: 4px 14px; font-size: 0.78rem; color: #475569; }
    .item-card .row2 strong, .item-card .row3 strong { color: #0f172a; font-variant-numeric: tabular-nums; }
    .item-card .row3 { margin-top: 4px; padding-top: 5px; border-top: 1px dashed #e2e8f0; }

    /* 점수 pill */
    .score-pill { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.78rem; font-weight: 700; font-variant-numeric: tabular-nums; }
    .score-pill.flow    { background: #dbeafe; color: #1e40af; }
    .score-pill.rebound { background: #d1fae5; color: #065f46; }
    .score-pill.bull    { background: #fef3c7; color: #854d0e; }
    .score-pill.warn    { background: #fee2e2; color: #991b1b; }

    /* 태그 뱃지 */
    .tag-badge {
      display: inline-block; padding: 2px 8px; border-radius: 4px;
      font-size: 0.7rem; font-weight: 600; margin-right: 4px;
    }
    .tag-FLOW_LEAD          { background: #dbeafe; color: #1e40af; }
    .tag-REBOUND            { background: #d1fae5; color: #065f46; }
    .tag-BULL_TREND_WATCH   { background: #fef3c7; color: #854d0e; }
    .tag-OVERHEAT_WARNING   { background: #fee2e2; color: #991b1b; }
    .tag-HIGH_VOLATILITY    { background: #fef9c3; color: #713f12; }
    .tag-STRUCTURE_BROKEN   { background: #f1f5f9; color: #475569; text-decoration: line-through; }
    .tag-NO_SIGNAL          { background: #f1f5f9; color: #94a3b8; }

    /* 탭 네비 */
    .nav-tabs { border-bottom: 2px solid #e2e8f0; margin-bottom: 20px; }
    .nav-tabs .nav-link {
      color: #64748b; font-weight: 600; border: none; border-radius: 0;
      padding: 10px 20px; background: transparent;
    }
    .nav-tabs .nav-link.active {
      color: #0f172a; background: transparent;
      border-bottom: 3px solid #2563eb; margin-bottom: -2px;
    }
    .nav-tabs .nav-link:hover { color: #2563eb; }

    .ret-pos { color: #16a34a; font-weight: 600; }
    .ret-neg { color: #dc2626; font-weight: 600; }

    .service-notice {
      background: #f8fafc; border-radius: 10px; padding: 12px 16px;
      font-size: 0.82rem; color: #475569; line-height: 1.6;
      border: 1px dashed #cbd5e1; margin-top: 16px;
    }

    .empty-state {
      text-align: center; padding: 24px; color: #94a3b8; font-size: 0.85rem;
      background: #f8fafc; border-radius: 10px;
    }

    @media (max-width: 576px) {
      body { padding: 16px 10px; }
      .glass { padding: 16px; border-radius: 12px; margin-bottom: 14px; }
      h1 { font-size: 1.1rem; }
      .topbar h1 i { display: none; }
      .nav-tabs .nav-link { padding: 8px 12px; font-size: 0.85rem; }
    }
  </style>
</head>
<body>
<div class="wrap">

<%
// Defensive defaults — 옛 app.js 가 새 변수를 res.render 에 넘기지 않아도 result 에서 자동 fallback.
// PM2 reload 누락 / 부분 deploy / 캐시 미존재 어느 상황에서도 EJS 가 깨지지 않게.
var csbMainCandidates  = (typeof csbMainCandidates  !== 'undefined' && csbMainCandidates)  ? csbMainCandidates  : ((result && result.csbMainCandidates)  || []);
var csbSubCandidates   = (typeof csbSubCandidates   !== 'undefined' && csbSubCandidates)   ? csbSubCandidates   : ((result && result.csbSubCandidates)   || []);
var smallCsbReadyCandidates = (typeof smallCsbReadyCandidates !== 'undefined' && smallCsbReadyCandidates) ? smallCsbReadyCandidates : ((result && result.smallCsbReady) || []);
var smallCsbWatchCandidates = (typeof smallCsbWatchCandidates !== 'undefined' && smallCsbWatchCandidates) ? smallCsbWatchCandidates : ((result && result.smallCsbWatch) || []);
var flowLeadCandidates = (typeof flowLeadCandidates !== 'undefined' && flowLeadCandidates) ? flowLeadCandidates : ((result && result.flowLeadCandidates) || []);
var reboundCandidates  = (typeof reboundCandidates  !== 'undefined' && reboundCandidates)  ? reboundCandidates  : ((result && result.reboundCandidates)  || []);
var bullTrendWatch     = (typeof bullTrendWatch     !== 'undefined' && bullTrendWatch)     ? bullTrendWatch     : ((result && result.bullTrendWatch)     || []);
var overheatWarnings   = (typeof overheatWarnings   !== 'undefined' && overheatWarnings)   ? overheatWarnings   : ((result && result.overheatWarnings)   || []);
var taggedAll          = (typeof taggedAll          !== 'undefined' && taggedAll)          ? taggedAll          : ((result && result.taggedAll)          || []);
var holdingsCards      = (typeof holdingsCards      !== 'undefined' && holdingsCards)      ? holdingsCards      : [];
var holdingsRaw        = (typeof holdingsRaw        !== 'undefined') ? holdingsRaw        : '';
var cQuery             = (typeof cQuery             !== 'undefined') ? cQuery             : '';
var seededCount        = (typeof seededCount        !== 'undefined') ? seededCount        : ((result && result.seeded) || 0);

// 태그 한글 매핑 (CSS class 는 영어 식별자 유지, 화면 표시만 한글)
var tagLabels = {
  CSB_BREAKOUT: '상승 전 압축',
  CSB_COMPRESSION: '예비 압축',
  FLOW_LEAD: '자금 선행',
  REBOUND: '과매도 반등',
  BULL_TREND_WATCH: '강세장 추세',
  OVERHEAT_WARNING: '과열 주의',
  HIGH_VOLATILITY: '고변동성',
  STRUCTURE_BROKEN: '구조 붕괴',
  NO_SIGNAL: '신호 없음'
};
// CSB stage tag (한글)
var csbStageLabel = {
  compressionFormed: '압축 형성',
  supportConfirmed: '지지 확인',
  breakoutReady: '돌파 대기',
  volumeReturning: '거래대금 재활성',
};
function tagText(t) { return tagLabels[t] || t.replace(/_/g, ' '); }
function regimeText(r) {
  if (r === 'bull') return '강세장';
  if (r === 'bear') return '약세장';
  if (r === 'sideways') return '횡보장';
  return r || '-';
}
function won(v) {
  if (!v && v !== 0) return '-';
  return Number(v).toLocaleString('ko-KR') + '원';
}
%>

  <!-- ─── 헤더 ─── -->
  <div class="topbar">
    <h1><i class="bi bi-graph-up-arrow me-2"></i>종목 상태 분석 도구</h1>
    <div class="d-flex gap-2 align-items-center">
      <a href="/subscribe" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-envelope me-1"></i>구독
      </a>
      <a href="/admin" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-gear me-1"></i>관리자
      </a>
    </div>
  </div>

  <!-- ─── 현황 요약 ─── -->
  <div class="glass compact">
    <div class="row g-2 row-cols-2 row-cols-md-6">
      <% if (result) { %>
        <div class="col"><div class="meta-cell" style="background:#ecfdf5;"><div class="label" style="color:#065f46;">상승 전 압축</div><div class="value" style="color:#047857;"><%= result.csbMainCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell" style="background:#f0fdfa;"><div class="label" style="color:#0f766e;">예비 압축</div><div class="value" style="color:#0d9488;"><%= result.csbSubCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell" style="background:#f0fdf4;"><div class="label" style="color:#166534;">과매도 반등</div><div class="value" style="color:#16a34a;"><%= result.reboundCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell" style="background:#fef2f2;"><div class="label" style="color:#991b1b;">과열/추격주의</div><div class="value" style="color:#b91c1c;"><%= result.overheatCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell"><div class="label">분석 종목</div><div class="value"><%= result.processed || 0 %></div></div></div>
        <div class="col"><div class="meta-cell"><div class="label">시드</div><div class="value"><%= seededCount %></div></div></div>
      <% } else { %>
        <div class="col"><div class="meta-cell"><div class="label">시드 종목</div><div class="value"><%= seededCount %></div></div></div>
      <% } %>
    </div>
    <div class="small mt-3 text-secondary">
      <% if (!result) { %>
        분석 결과 없음. <strong>관리자 페이지</strong>에서 시드(약 15분) → 분석(약 5분) 실행 필요.
      <% } else { %>
        분석 완료: <%= new Date(result.analyzedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %>
        <% if (result.marketRegime) { %>
          · 시장 regime: KOSPI <strong><%= result.marketRegime.kospi %></strong> / KOSDAQ <strong><%= result.marketRegime.kosdaq %></strong>
        <% } %>
      <% } %>
    </div>
  </div>

<% if (result) { %>

  <!-- ─── 검색 ─── -->
  <div class="glass compact">
    <form method="get" action="/pattern" class="row g-2 align-items-end">
      <div class="col-9 col-md-10">
        <input type="text" name="cq" value="<%= cQuery || '' %>" placeholder="검색 (예: 서울반도체 or 046890)" class="form-control form-control-sm" />
      </div>
      <div class="col-3 col-md-2">
        <button type="submit" class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-search me-1"></i>검색</button>
      </div>
    </form>
  </div>

  <!-- ─── 4탭 ─── -->
  <ul class="nav nav-tabs" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-today">오늘의 후보</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-smallcap">중소형 후보</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-warn">주의 종목</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-validation">모델 검증</button></li>
  </ul>

  <div class="tab-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TAB 1: 오늘의 후보 (자금선행 / 과매도반등 / 강세장 추세 관찰) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade show active" id="tab-today" role="tabpanel">

      <!-- 1. 상승 전 압축 후보 (CSB 4태그) — 메인 모델 -->
      <div class="glass">
        <h2><i class="bi bi-bullseye me-1"></i>상승 전 압축 후보 <span class="count">(<%= csbMainCandidates.length %>건)</span></h2>
        <div class="cat-banner" style="background:#ecfdf5; border-left:4px solid #047857;">
          <strong>가격 압축, 지지 유지, 돌파 대기 위치, 거래대금 재활성</strong>이 동시에 나타난 종목입니다.
          큰 폭 상승 전 매수 시점 후보 (검증 기준 d20 +4.5%·승률 55%·PF 2.3, 매수 추천 아님).
          <div class="small text-secondary mt-1">
            손절 가이드 — <strong>clamp(ATR%×2.5, 8%, 12%)</strong> 종가 기준. 진입가 대비 N% 하락 종가 시 청산.
          </div>
        </div>
        <% if (!csbMainCandidates.length) { %>
          <div class="empty-state">현재 시점 통과 종목 없음 (4태그 모두 통과 까다로움)</div>
        <% } else { %>
          <% csbMainCandidates.forEach(function(c) { var m = c.csb?.metrics || {}; var sg = c.csb?.stopGuide; var st = c.csb?.stages || {}; var tp = c.csb?.tradePlan; %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                </div>
                <span class="score-pill" style="background:#d1fae5; color:#065f46;">
                  <%= c.csb.displayGrade %> · 4태그
                </span>
              </div>
              <div class="row2">
                <span>관찰가 <strong><%= won(c.closePrice) %></strong></span>
                <span>압축 <strong><%= ((m.compressionRatio || 0) * 100).toFixed(0) %>%</strong></span>
                <span>거래대금 <strong><%= (m.valueRatio5d20d || 0).toFixed(2) %>x</strong></span>
                <span>20일 고점거리 <strong><%= ((m.distFromHigh20 || 0) * 100).toFixed(1) %>%</strong></span>
                <span style="margin-left:auto; color:#64748b;">시총 <strong><%= ((c.marketCap || 0) / 1e8).toFixed(0) %>억</strong></span>
              </div>
              <% if (tp) { %>
                <div class="trade-plan" style="background:#f0fdf4; border:1px solid #86efac; border-radius:8px; padding:10px 12px; margin:8px 0; font-size:0.85rem;">
                  <div style="display:flex; gap:14px; flex-wrap:wrap; align-items:center;">
                    <span><strong style="color:#065f46;">확인 진입</strong> <%= won(tp.triggerPrice) %> <span class="text-secondary small">(<%= tp.triggerSource %>)</span></span>
                    <span><strong style="color:#991b1b;">종가 손절</strong> <%= won(tp.stopPrice) %> (-<%= tp.stopPct %>%)</span>
                    <span><strong style="color:#1e40af;">1차 목표</strong> <%= won(tp.target1) %> <% if (tp.rr1) { %><span class="text-secondary small">손익비 <%= tp.rr1 %></span><% } %></span>
                    <span><strong style="color:#7c3aed;">2차 목표</strong> <%= won(tp.target2) %> <% if (tp.rr2) { %><span class="text-secondary small">손익비 <%= tp.rr2 %></span><% } %></span>
                    <span class="text-secondary small" style="margin-left:auto;"><%= tp.horizon %></span>
                  </div>
                </div>
              <% } %>
              <div class="row3">
                <% if (st.compressionFormed) { %><span class="tag-badge" style="background:#d1fae5; color:#065f46;">압축 형성</span><% } %>
                <% if (st.supportConfirmed) { %><span class="tag-badge" style="background:#dbeafe; color:#1e40af;">지지 확인</span><% } %>
                <% if (st.breakoutReady) { %><span class="tag-badge" style="background:#fef3c7; color:#854d0e;">돌파 대기</span><% } %>
                <% if (st.volumeReturning) { %><span class="tag-badge" style="background:#fce7f3; color:#9d174d;">거래대금 재활성</span><% } %>
                <% if (c.csb?.warnings && c.csb.warnings.length) { c.csb.warnings.forEach(function(w) { %>
                  <span class="tag-badge" style="background:#fef2f2; color:#991b1b;"><i class="bi bi-exclamation-triangle me-1"></i><%= w %></span>
                <% }) } %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- 1b. 예비 압축 후보 (CSB 3태그) — 보조 -->
      <div class="glass">
        <h2><i class="bi bi-hourglass-split me-1"></i>예비 압축 후보 <span class="count">(<%= csbSubCandidates.length %>건)</span></h2>
        <div class="cat-banner" style="background:#f0fdfa; border-left:4px solid #0d9488;">
          지지 확인 + 거래대금 재활성에 더해 압축 또는 돌파 중 한 가지를 만족하는 종목입니다.
          4태그 통과로 발전할 가능성을 관찰하는 보조 후보입니다.
        </div>
        <% if (!csbSubCandidates.length) { %>
          <div class="empty-state">현재 시점 통과 종목 없음</div>
        <% } else { %>
          <% csbSubCandidates.slice(0, 30).forEach(function(c) { var m = c.csb?.metrics || {}; var st = c.csb?.stages || {}; var tp = c.csb?.tradePlan; %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                </div>
                <span class="score-pill" style="background:#ccfbf1; color:#0f766e;">3태그</span>
              </div>
              <div class="row2">
                <span>관찰가 <strong><%= won(c.closePrice) %></strong></span>
                <span>압축 <strong><%= ((m.compressionRatio || 0) * 100).toFixed(0) %>%</strong></span>
                <span>거래대금 <strong><%= (m.valueRatio5d20d || 0).toFixed(2) %>x</strong></span>
                <span>고점거리 <strong><%= ((m.distFromHigh20 || 0) * 100).toFixed(1) %>%</strong></span>
                <span style="margin-left:auto; color:#64748b;">시총 <strong><%= ((c.marketCap || 0) / 1e8).toFixed(0) %>억</strong></span>
              </div>
              <% if (tp) { %>
                <div class="trade-plan" style="background:#f0fdfa; border:1px solid #5eead4; border-radius:8px; padding:10px 12px; margin:8px 0; font-size:0.85rem;">
                  <div style="display:flex; gap:14px; flex-wrap:wrap; align-items:center;">
                    <span><strong style="color:#0f766e;">확인 진입</strong> <%= won(tp.triggerPrice) %></span>
                    <span><strong style="color:#991b1b;">종가 손절</strong> <%= won(tp.stopPrice) %> (-<%= tp.stopPct %>%)</span>
                    <span><strong style="color:#1e40af;">1차 목표</strong> <%= won(tp.target1) %></span>
                    <span><strong style="color:#7c3aed;">2차 목표</strong> <%= won(tp.target2) %></span>
                    <% if (tp.rr1) { %><span class="text-secondary small">손익비 <%= tp.rr1 %>/<%= tp.rr2 %></span><% } %>
                  </div>
                </div>
              <% } %>
              <div class="row3">
                <% if (st.compressionFormed) { %><span class="tag-badge" style="background:#d1fae5; color:#065f46;">압축 형성</span><% } %>
                <% if (st.supportConfirmed) { %><span class="tag-badge" style="background:#dbeafe; color:#1e40af;">지지 확인</span><% } %>
                <% if (st.breakoutReady) { %><span class="tag-badge" style="background:#fef3c7; color:#854d0e;">돌파 대기</span><% } %>
                <% if (st.volumeReturning) { %><span class="tag-badge" style="background:#fce7f3; color:#9d174d;">거래대금 재활성</span><% } %>
                <% if (c.csb?.warnings && c.csb.warnings.length) { c.csb.warnings.forEach(function(w) { %>
                  <span class="tag-badge" style="background:#fef2f2; color:#991b1b;"><i class="bi bi-exclamation-triangle me-1"></i><%= w %></span>
                <% }) } %>
              </div>
            </div>
          <% }) %>
          <% if (csbSubCandidates.length > 30) { %>
            <div class="small text-secondary mt-2">상위 30개 표시 — 총 <%= csbSubCandidates.length %>건</div>
          <% } %>
        <% } %>
      </div>


      <!-- 2. 과매도 반등 후보 (Rebound) -->
      <div class="glass">
        <h2><i class="bi bi-arrow-counterclockwise me-1"></i>과매도 반등 후보 <span class="count">(<%= reboundCandidates.length %>건)</span></h2>
        <div class="cat-banner rebound">
          최근 단기 과매도 상태이지만, 장기 구조가 완전히 무너지지 않은 종목입니다.
          d1~d5 단기 반등 관찰용 후보입니다 (매수 추천 아님).
        </div>
        <% if (!reboundCandidates.length) { %>
          <div class="empty-state">현재 시점 통과 종목 없음</div>
        <% } else { %>
          <% reboundCandidates.forEach(function(c) { var s = c.rebound?.signals || {}; %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                </div>
                <span class="score-pill rebound">반등 점수 <%= c.rebound.score %></span>
              </div>
              <div class="row2">
                <span>현재가 <strong><%= won(c.closePrice || s.close) %></strong></span>
                <span>5일 수익률 <strong class="ret-neg"><%= ((s.ret5d || 0) * 100).toFixed(1) %>%</strong></span>
                <span>10일 <strong class="<%= s.ret10d >= 0 ? 'ret-pos' : 'ret-neg' %>"><%= ((s.ret10d || 0) * 100).toFixed(1) %>%</strong></span>
                <span>20일 <strong class="<%= s.ret20d >= 0 ? 'ret-pos' : 'ret-neg' %>"><%= ((s.ret20d || 0) * 100).toFixed(1) %>%</strong></span>
              </div>
              <div class="row2">
                <span>변동성(ATR) <strong><%= ((s.atrPct || 0) * 100).toFixed(1) %>%</strong></span>
                <% if (s.ma120) { %><span>120일선 거리 <strong><%= ((s.close / s.ma120 - 1) * 100).toFixed(1) %>%</strong></span><% } %>
                <span>3일 외+기 순매수 <strong><%= ((s.sum3 || 0) / 1e8).toFixed(0) %>억</strong></span>
                <span style="margin-left:auto; color:#64748b;">시총 <strong><%= ((c.marketCap || 0) / 1e8).toFixed(0) %>억</strong></span>
              </div>
              <div class="row3">
                <% c.tags.forEach(function(t) { %><span class="tag-badge tag-<%= t %>"><%= tagText(t) %></span><% }) %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- 3. 강세장 추세 관찰 (BullTrendWatch) -->
      <div class="glass">
        <h2><i class="bi bi-eye me-1"></i>강세장 추세 관찰 <span class="count">(<%= bullTrendWatch.length %>건)</span></h2>
        <div class="cat-banner bull">
          이 카테고리는 단기 매수 신호가 아니라 강세장 20일 추세 관찰용입니다.
          기존 모델은 d5 매수 모델로 실패했고, 75-84점 + bull regime 조합만 d20 추세 관찰로 사용합니다.
        </div>
        <% if (!bullTrendWatch.length) { %>
          <div class="empty-state">현재 bull regime + 75-84점 + entry-ready 조건 통과 종목 없음</div>
        <% } else { %>
          <% bullTrendWatch.forEach(function(c) { %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                </div>
                <span class="score-pill bull">추세 점수 <%= c.setupScore %></span>
              </div>
              <div class="row2">
                <span>현재가 <strong><%= won(c.closePrice) %></strong></span>
                <% if (c.weekly) { %><span>주봉 추세 <strong><%= c.weekly.stage || '-' %></strong></span><% } %>
                <% if (c.trend) { %><span>추세 조건 <strong><%= c.trend.passed %>/6</strong></span><% } %>
                <% if (c.atr) { %><span>손절 폭 <strong><%= c.atr.stopPct || '-' %>%</strong></span><% } %>
                <% if (c.financials?.score != null) { %><span>실적 점수 <strong><%= c.financials.score %></strong></span><% } %>
                <span>시장 <strong>강세장</strong></span>
              </div>
              <div class="row3">
                <span class="tag-badge tag-BULL_TREND_WATCH">강세장 추세</span>
                <span style="margin-left:auto; color:#94a3b8; font-size:0.72rem;">20일 추세 관찰용 · 단기 매수 신호 아님</span>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

    </div><!-- /tab-today -->

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TAB 2: 중소형 후보 (500억~3000억) — READY + WATCH -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade" id="tab-smallcap" role="tabpanel">

      <div class="glass">
        <h2><i class="bi bi-lightning-fill me-1"></i>중소형 상승 전 압축 후보 <span class="count" style="color:#dc2626;">(<%= (smallCsbReadyCandidates || []).length %>건)</span></h2>
        <div class="alert alert-warning small mb-3" style="border-left:4px solid #dc2626; background:#fff7ed; color:#7c2d12;">
          <i class="bi bi-exclamation-triangle me-2"></i><strong>중소형 주의</strong> · 중소형 후보는 시총 500억~3,000억 구간의 관찰 후보입니다.
          대형주보다 변동성, 체결 리스크, 급등락 가능성이 클 수 있습니다.
        </div>

        <!-- 필터 UI -->
        <div style="background:#f8fafc; border-radius:10px; padding:14px; margin-bottom:16px;">
          <div style="display:flex; gap:20px; flex-wrap:wrap; align-items:flex-start;">
            <div>
              <label style="display:block; font-size:0.82rem; font-weight:600; color:#0f172a; margin-bottom:6px;">시총 구간</label>
              <div style="display:flex; gap:8px;">
                <button onclick="filterSmallCap('all', 'cap', this)" class="smallcap-filter-cap active" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">전체</button>
                <button onclick="filterSmallCap('cap500to1000', 'cap', this)" class="smallcap-filter-cap" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">500~1000억</button>
                <button onclick="filterSmallCap('cap1000to2000', 'cap', this)" class="smallcap-filter-cap" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">1000~2000억</button>
                <button onclick="filterSmallCap('cap2000to3000', 'cap', this)" class="smallcap-filter-cap" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">2000~3000억</button>
              </div>
            </div>
            <div>
              <label style="display:block; font-size:0.82rem; font-weight:600; color:#0f172a; margin-bottom:6px;">주가</label>
              <div style="display:flex; gap:8px;">
                <button onclick="filterSmallCap('all', 'price', this)" class="smallcap-filter-price active" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">전체</button>
                <button onclick="filterSmallCap('price50k', 'price', this)" class="smallcap-filter-price" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">5만원이하</button>
                <button onclick="filterSmallCap('price100k', 'price', this)" class="smallcap-filter-price" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">10만원이하</button>
                <button onclick="filterSmallCap('price200k', 'price', this)" class="smallcap-filter-price" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">20만원이하</button>
              </div>
            </div>
          </div>
        </div>

        <!-- 후보 표시 -->
        <% if (!(smallCsbReadyCandidates && smallCsbReadyCandidates.length)) { %>
          <div class="empty-state">현재 시점 통과 종목 없음</div>
        <% } else { %>
          <% smallCsbReadyCandidates.forEach(function(c) { var scb = c.smallCsb || c.csb || {}; var m = scb.metrics || {}; var st = scb.stages || {}; var capBucket = scb.capBucket || c.capBucket || 'unknown'; var price = c.closePrice || 0; var marketCap = c.marketCap || 0; %>
            <div class="item-card smallcap-item" data-cap="<%= capBucket %>" data-price="<%= price %>" style="display:block;">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                </div>
                <span class="score-pill" style="background:#fee2e2; color:#991b1b;">
                  <%= scb.displayGrade || '준비' %> · 4태그
                </span>
              </div>
              <div class="row2">
                <span>현재가 <strong><%= won(price) %></strong></span>
                <span>시총구간 <strong style="color:#dc2626;"><%= ((marketCap) / 1e8).toFixed(0) %>억</strong></span>
                <span>20일 거래대금 <strong><%= ((m.avg20Value || 0) / 1e8).toFixed(0) %>억</strong></span>
                <span>ATR% <strong><%= ((m.atrPct || 0) * 100).toFixed(1) %>%</strong></span>
              </div>
              <div class="row2">
                <span>압축비 <strong><%= ((m.compressionRatio || 0) * 100).toFixed(0) %>%</strong></span>
                <span>거래대금비 <strong><%= (m.valueRatio5d20d || 0).toFixed(2) %>x</strong></span>
                <span>고점거리 <strong><%= ((m.distFromHigh20 || 0) * 100).toFixed(1) %>%</strong></span>
                <span>손절가 <strong><%= won((price * 0.92).toFixed(0)) %></strong></span>
              </div>
              <div class="row3">
                <% if (st.compressionFormed) { %><span class="tag-badge" style="background:#d1fae5; color:#065f46;">압축 형성</span><% } %>
                <% if (st.supportConfirmed) { %><span class="tag-badge" style="background:#dbeafe; color:#1e40af;">지지 확인</span><% } %>
                <% if (st.breakoutReady) { %><span class="tag-badge" style="background:#fef3c7; color:#854d0e;">돌파 대기</span><% } %>
                <% if (st.volumeReturning) { %><span class="tag-badge" style="background:#fce7f3; color:#9d174d;">거래대금 재활성</span><% } %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div class="glass">
        <h2><i class="bi bi-hourglass-split me-1"></i>중소형 예비 압축 후보 <span class="count" style="color:#dc2626;">(<%= (smallCsbWatchCandidates || []).length %>건)</span></h2>
        <div style="background:#f8fafc; border-radius:10px; padding:14px; margin-bottom:16px;">
          <div style="display:flex; gap:20px; flex-wrap:wrap; align-items:flex-start;">
            <div>
              <label style="display:block; font-size:0.82rem; font-weight:600; color:#0f172a; margin-bottom:6px;">시총 구간</label>
              <div style="display:flex; gap:8px;">
                <button onclick="filterSmallCapWatch('all', 'cap', this)" class="smallcap-filter-cap-watch active" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">전체</button>
                <button onclick="filterSmallCapWatch('cap500to1000', 'cap', this)" class="smallcap-filter-cap-watch" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">500~1000억</button>
                <button onclick="filterSmallCapWatch('cap1000to2000', 'cap', this)" class="smallcap-filter-cap-watch" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">1000~2000억</button>
                <button onclick="filterSmallCapWatch('cap2000to3000', 'cap', this)" class="smallcap-filter-cap-watch" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">2000~3000억</button>
              </div>
            </div>
            <div>
              <label style="display:block; font-size:0.82rem; font-weight:600; color:#0f172a; margin-bottom:6px;">주가</label>
              <div style="display:flex; gap:8px;">
                <button onclick="filterSmallCapWatch('all', 'price', this)" class="smallcap-filter-price-watch active" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">전체</button>
                <button onclick="filterSmallCapWatch('price50k', 'price', this)" class="smallcap-filter-price-watch" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">5만원이하</button>
                <button onclick="filterSmallCapWatch('price100k', 'price', this)" class="smallcap-filter-price-watch" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">10만원이하</button>
                <button onclick="filterSmallCapWatch('price200k', 'price', this)" class="smallcap-filter-price-watch" style="padding:6px 12px; border:1px solid #cbd5e1; border-radius:6px; background:#fff; cursor:pointer; font-size:0.78rem; font-weight:500;">20만원이하</button>
              </div>
            </div>
          </div>
        </div>

        <% if (!(smallCsbWatchCandidates && smallCsbWatchCandidates.length)) { %>
          <div class="empty-state">현재 시점 통과 종목 없음</div>
        <% } else { %>
          <% smallCsbWatchCandidates.forEach(function(c) { var scb = c.smallCsb || c.csb || {}; var m = scb.metrics || {}; var st = scb.stages || {}; var capBucket = scb.capBucket || c.capBucket || 'unknown'; var price = c.closePrice || 0; var marketCap = c.marketCap || 0; %>
            <div class="item-card smallcap-item-watch" data-cap="<%= capBucket %>" data-price="<%= price %>" style="display:block;">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                </div>
                <span class="score-pill" style="background:#ccfbf1; color:#0f766e;">3태그</span>
              </div>
              <div class="row2">
                <span>현재가 <strong><%= won(price) %></strong></span>
                <span>시총구간 <strong style="color:#dc2626;"><%= ((marketCap) / 1e8).toFixed(0) %>억</strong></span>
                <span>20일 거래대금 <strong><%= ((m.avg20Value || 0) / 1e8).toFixed(0) %>억</strong></span>
                <span>ATR% <strong><%= ((m.atrPct || 0) * 100).toFixed(1) %>%</strong></span>
              </div>
              <div class="row2">
                <span>압축비 <strong><%= ((m.compressionRatio || 0) * 100).toFixed(0) %>%</strong></span>
                <span>거래대금비 <strong><%= (m.valueRatio5d20d || 0).toFixed(2) %>x</strong></span>
                <span>고점거리 <strong><%= ((m.distFromHigh20 || 0) * 100).toFixed(1) %>%</strong></span>
              </div>
              <div class="row3">
                <% if (st.compressionFormed) { %><span class="tag-badge" style="background:#d1fae5; color:#065f46;">압축 형성</span><% } %>
                <% if (st.supportConfirmed) { %><span class="tag-badge" style="background:#dbeafe; color:#1e40af;">지지 확인</span><% } %>
                <% if (st.breakoutReady) { %><span class="tag-badge" style="background:#fef3c7; color:#854d0e;">돌파 대기</span><% } %>
                <% if (st.volumeReturning) { %><span class="tag-badge" style="background:#fce7f3; color:#9d174d;">거래대금 재활성</span><% } %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

    </div><!-- /tab-smallcap -->

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TAB 3: 주의 종목 (과열/추격주의 / 고변동성 / 구조 붕괴) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade" id="tab-warn" role="tabpanel">

      <!-- 4. 과열/추격주의 -->
      <% var overheatTop = (overheatWarnings || []).slice(0, 30); %>
      <div class="glass">
        <h2><i class="bi bi-fire me-1"></i>과열/추격주의 <span class="count">(<%= overheatWarnings.length %>건 중 상위 30)</span></h2>
        <div class="cat-banner warn">
          추세는 강하지만 단기 과열 가능성이 있어 신규 진입 시 주의가 필요한 종목입니다.
          신규 추격매수보다는 분할 익절, 보유 시 리스크 관리 관점으로 확인하세요.
        </div>
        <% if (!overheatTop.length) { %>
          <div class="empty-state">과열 시그널 종목 없음</div>
        <% } else { %>
          <% overheatTop.forEach(function(c) { %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                </div>
                <span class="score-pill warn">과열</span>
              </div>
              <div class="row2">
                <span>현재가 <strong><%= won(c.closePrice) %></strong></span>
                <span>5일 <strong class="<%= c.ret5d >= 0 ? 'ret-pos' : 'ret-neg' %>"><%= c.ret5d %>%</strong></span>
                <span>20일 <strong class="<%= c.ret20d >= 0 ? 'ret-pos' : 'ret-neg' %>"><%= c.ret20d %>%</strong></span>
                <span>20일선 이격 <strong><%= c.dist20pct %>%</strong></span>
              </div>
              <div class="row2">
                <span>변동성(ATR) <strong><%= c.atrPct %>%</strong></span>
                <span>거래대금 확장 <strong><%= c.valueExpansion %>배</strong></span>
                <% if (c.setupScore) { %><span>추세 점수 <strong><%= c.setupScore %></strong></span><% } %>
                <span style="margin-left:auto; color:#64748b;">시총 <strong><%= ((c.marketCap || 0) / 1e8).toFixed(0) %>억</strong></span>
              </div>
              <div class="row3">
                <% c.tags.forEach(function(t) { %><span class="tag-badge tag-<%= t %>"><%= tagText(t) %></span><% }) %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- 5. 고변동성 / 구조 붕괴 (taggedAll 에서 필터) -->
