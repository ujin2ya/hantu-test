<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>패턴 스크리너 — 종목 상태 분석 도구</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    body {
      background: #f3f5fb; color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      padding: 24px 16px;
    }
    .wrap { max-width: 1100px; margin: 0 auto; }
    .glass { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 6px 18px rgba(15,23,42,0.06); margin-bottom: 20px; }
    .glass.compact { padding: 16px 18px; }
    h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 6px; }
    h2 { font-size: 1.1rem; font-weight: 700; margin: 0 0 14px; color: #0f172a; }
    h2 .count { color: #64748b; font-weight: 500; font-size: 0.85rem; margin-left: 6px; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; flex-wrap: wrap; gap: 8px; }

    /* 현황 셀 */
    .meta-cell { background: #f8fafc; border-radius: 10px; padding: 10px 12px; }
    .meta-cell .label { color: #64748b; font-size: 0.72rem; margin-bottom: 4px; }
    .meta-cell .value { font-weight: 700; color: #0f172a; font-size: 1.05rem; }

    /* 카테고리 배너 — 모델 설명 */
    .cat-banner {
      background: #f1f5f9; border-left: 4px solid #94a3b8; padding: 10px 14px;
      border-radius: 0 8px 8px 0; font-size: 0.82rem; color: #475569; margin-bottom: 12px;
    }
    .cat-banner.flow    { background: #eff6ff; border-color: #3b82f6; color: #1e40af; }
    .cat-banner.rebound { background: #f0fdf4; border-color: #10b981; color: #065f46; }
    .cat-banner.bull    { background: #fefce8; border-color: #eab308; color: #854d0e; }
    .cat-banner.warn    { background: #fef2f2; border-color: #ef4444; color: #991b1b; }
    .cat-banner.holding { background: #faf5ff; border-color: #a855f7; color: #6b21a8; }
    .cat-banner.report  { background: #f8fafc; border-color: #475569; color: #334155; }

    /* 종목 카드 */
    .item-card { background: #f8fafc; border-radius: 10px; padding: 12px 14px; margin-bottom: 8px; }
    .item-card .row1 { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
    .item-card .name-block { flex: 1; min-width: 0; }
    .item-card .nm { font-weight: 700; color: #0f172a; }
    .item-card .cd { color: #94a3b8; font-size: 0.78rem; margin-left: 4px; }
    .item-card .mkt { color: #64748b; font-size: 0.7rem; margin-left: 6px; padding: 1px 6px; background: #e2e8f0; border-radius: 4px; }
    /* 종목명 클릭 → 상세 페이지 (/?query=code) */
    .item-card a.deep-link { text-decoration: none; color: inherit; display: inline-flex; align-items: center; gap: 4px; }
    .item-card a.deep-link:hover .nm { color: #2563eb; text-decoration: underline; }
    .item-card .row2, .item-card .row3 { display: flex; flex-wrap: wrap; gap: 4px 14px; font-size: 0.78rem; color: #475569; }
    .item-card .row2 strong, .item-card .row3 strong { color: #0f172a; font-variant-numeric: tabular-nums; }
    .item-card .row3 { margin-top: 4px; padding-top: 5px; border-top: 1px dashed #e2e8f0; }

    /* 점수 pill */
    .score-pill { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.78rem; font-weight: 700; font-variant-numeric: tabular-nums; }
    .score-pill.flow    { background: #dbeafe; color: #1e40af; }
    .score-pill.rebound { background: #d1fae5; color: #065f46; }
    .score-pill.bull    { background: #fef3c7; color: #854d0e; }
    .score-pill.warn    { background: #fee2e2; color: #991b1b; }

    /* 태그 뱃지 */
    .tag-badge {
      display: inline-block; padding: 2px 8px; border-radius: 4px;
      font-size: 0.7rem; font-weight: 600; margin-right: 4px;
    }
    .tag-FLOW_LEAD          { background: #dbeafe; color: #1e40af; }
    .tag-REBOUND            { background: #d1fae5; color: #065f46; }
    .tag-BULL_TREND_WATCH   { background: #fef3c7; color: #854d0e; }
    .tag-OVERHEAT_WARNING   { background: #fee2e2; color: #991b1b; }
    .tag-HIGH_VOLATILITY    { background: #fef9c3; color: #713f12; }
    .tag-STRUCTURE_BROKEN   { background: #f1f5f9; color: #475569; text-decoration: line-through; }
    .tag-NO_SIGNAL          { background: #f1f5f9; color: #94a3b8; }

    /* 탭 네비 */
    .nav-tabs { border-bottom: 2px solid #e2e8f0; margin-bottom: 20px; }
    .nav-tabs .nav-link {
      color: #64748b; font-weight: 600; border: none; border-radius: 0;
      padding: 10px 20px; background: transparent;
    }
    .nav-tabs .nav-link.active {
      color: #0f172a; background: transparent;
      border-bottom: 3px solid #2563eb; margin-bottom: -2px;
    }
    .nav-tabs .nav-link:hover { color: #2563eb; }

    .ret-pos { color: #16a34a; font-weight: 600; }
    .ret-neg { color: #dc2626; font-weight: 600; }

    .service-notice {
      background: #f8fafc; border-radius: 10px; padding: 12px 16px;
      font-size: 0.82rem; color: #475569; line-height: 1.6;
      border: 1px dashed #cbd5e1; margin-top: 16px;
    }

    .empty-state {
      text-align: center; padding: 24px; color: #94a3b8; font-size: 0.85rem;
      background: #f8fafc; border-radius: 10px;
    }

    @media (max-width: 576px) {
      body { padding: 16px 10px; }
      .glass { padding: 16px; border-radius: 12px; margin-bottom: 14px; }
      h1 { font-size: 1.1rem; }
      .topbar h1 i { display: none; }
      .nav-tabs .nav-link { padding: 8px 12px; font-size: 0.85rem; }
    }
  </style>
</head>
<body>
<div class="wrap">

<%
  // Safe variables — 정의되지 않으면 빈 배열로 fallback
  const safeVviCandidates = typeof vviCandidates !== 'undefined' ? vviCandidates : [];
  const safeVviTodayCandidates = typeof vviTodayCandidates !== 'undefined' ? vviTodayCandidates : [];
  const safeVviRecentSignals = typeof vviRecentSignals !== 'undefined' ? vviRecentSignals : [];
  const safeLatestMarketDate = typeof latestMarketDate !== 'undefined' ? latestMarketDate : null;
  const safeQvaCandidates = typeof qvaCandidates !== 'undefined' ? qvaCandidates : [];
  const safeQvaHoldCandidates = typeof qvaHoldCandidates !== 'undefined' ? qvaHoldCandidates : [];
  const safeQvaHigherLowCandidates = typeof qvaHigherLowCandidates !== 'undefined' ? qvaHigherLowCandidates : [];
  const safeCsbMainCandidates = typeof csbMainCandidates !== 'undefined' ? csbMainCandidates : [];
  const safeCsbSubCandidates = typeof csbSubCandidates !== 'undefined' ? csbSubCandidates : [];
  const safeFlowLeadCandidates = typeof flowLeadCandidates !== 'undefined' ? flowLeadCandidates : [];
  const safeReboundCandidates = typeof reboundCandidates !== 'undefined' ? reboundCandidates : [];
  const safeBullTrendWatch = typeof bullTrendWatch !== 'undefined' ? bullTrendWatch : [];
  const safeOverheatWarnings = typeof overheatWarnings !== 'undefined' ? overheatWarnings : [];
  const safeSmallCsbReadyCandidates = typeof smallCsbReadyCandidates !== 'undefined' ? smallCsbReadyCandidates : [];
  const safeSmallCsbWatchCandidates = typeof smallCsbWatchCandidates !== 'undefined' ? smallCsbWatchCandidates : [];
  const safeBuyCandidates = typeof buyCandidates !== 'undefined' ? buyCandidates : [];
  const safeWatchlist = typeof watchlist !== 'undefined' ? watchlist : [];
  const safeObservationList = typeof observationList !== 'undefined' ? observationList : [];
  const safeStage1to2Transitions = typeof stage1to2Transitions !== 'undefined' ? stage1to2Transitions : [];
  const safeTodaysBreakouts = typeof todaysBreakouts !== 'undefined' ? todaysBreakouts : [];
  const safeVcpForming = typeof vcpForming !== 'undefined' ? vcpForming : [];
  const safeStage2Pool = typeof stage2Pool !== 'undefined' ? stage2Pool : [];
  const safeHoldingsCards = typeof holdingsCards !== 'undefined' ? holdingsCards : [];
  const safeTaggedAll = typeof taggedAll !== 'undefined' ? taggedAll : [];

  // 헬퍼 함수들
  const tagLabels = {
  CSB_BREAKOUT: '상승 전 압축',
  CSB_COMPRESSION: '예비 압축',
  FLOW_LEAD: '자금 선행',
  REBOUND: '과매도 반등',
  BULL_TREND_WATCH: '강세장 추세',
  OVERHEAT_WARNING: '과열 주의',
  HIGH_VOLATILITY: '고변동성',
  STRUCTURE_BROKEN: '구조 붕괴',
  NO_SIGNAL: '신호 없음'
};
// CSB stage tag (한글)
var csbStageLabel = {
  compressionFormed: '압축 형성',
  supportConfirmed: '지지 확인',
  breakoutReady: '돌파 대기',
  volumeReturning: '거래대금 재활성',
  };

  // 헬퍼 함수
  const tagText = function(t) { return tagLabels[t] || t.replace(/_/g, ' '); };
  const regimeText = function(r) {
    if (r === 'bull') return '강세장';
    if (r === 'bear') return '약세장';
    if (r === 'sideways') return '횡보장';
    return r || '-';
  };
  const won = function(v) {
    if (!v && v !== 0) return '-';
    return Number(v).toLocaleString('ko-KR') + '원';
  };
%>

  <!-- ─── 헤더 ─── -->
  <div class="topbar">
    <h1><i class="bi bi-graph-up-arrow me-2"></i>종목 상태 분석 도구</h1>
    <div class="d-flex gap-2 align-items-center">
      <a href="/subscribe" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-envelope me-1"></i>구독
      </a>
      <a href="/admin" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-gear me-1"></i>관리자
      </a>
    </div>
  </div>

  <!-- ─── 분석 기준 정보 ─── -->
  <div class="small text-secondary mb-3" style="border-bottom: 1px solid #e2e8f0; padding-bottom: 12px;">
    <%
      const today = new Date();
      const todayStr = today.getFullYear() + '-' +
        String(today.getMonth() + 1).padStart(2, '0') + '-' +
        String(today.getDate()).padStart(2, '0');
      const latestDateStr = safeLatestMarketDate ?
        safeLatestMarketDate.slice(0,4) + '-' + safeLatestMarketDate.slice(4,6) + '-' + safeLatestMarketDate.slice(6,8)
        : '미확인';
    %>
    <strong>📅 분석 기준:</strong> 오늘 <%= todayStr %> |
    <strong>📊 데이터 기준:</strong> <%= latestDateStr %> |
    <strong>💡 신호 기준:</strong> 거래대금 초동은 <%= latestDateStr %> 신호, 최근 신호는 이전 거래일 기준
  </div>

  <!-- ─── 현황 요약 ─── -->
  <div class="glass compact">
    <div class="row g-2 row-cols-2 row-cols-md-6">
      <% if (result) { %>
        <div class="col"><div class="meta-cell" style="background:#ecfdf5;"><div class="label" style="color:#065f46;">상승 전 압축</div><div class="value" style="color:#047857;"><%= result.csbMainCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell" style="background:#f0fdfa;"><div class="label" style="color:#0f766e;">예비 압축</div><div class="value" style="color:#0d9488;"><%= result.csbSubCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell" style="background:#f0fdf4;"><div class="label" style="color:#166534;">과매도 반등</div><div class="value" style="color:#16a34a;"><%= result.reboundCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell" style="background:#fef2f2;"><div class="label" style="color:#991b1b;">과열/추격주의</div><div class="value" style="color:#b91c1c;"><%= result.overheatCount || 0 %></div></div></div>
        <div class="col"><div class="meta-cell"><div class="label">분석 종목</div><div class="value"><%= result.processed || 0 %></div></div></div>
        <div class="col"><div class="meta-cell"><div class="label">시드</div><div class="value"><%= seededCount %></div></div></div>
      <% } else { %>
        <div class="col"><div class="meta-cell"><div class="label">시드 종목</div><div class="value"><%= seededCount %></div></div></div>
      <% } %>
    </div>
    <div class="small mt-3 text-secondary">
      <% if (!result) { %>
        분석 결과 없음. <strong>관리자 페이지</strong>에서 시드(약 15분) → 분석(약 5분) 실행 필요.
      <% } else { %>
        분석 완료: <%= new Date(result.analyzedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %>
        <% if (result.marketRegime) { %>
          · 시장 regime: KOSPI <strong><%= result.marketRegime.kospi %></strong> / KOSDAQ <strong><%= result.marketRegime.kosdaq %></strong>
        <% } %>
      <% } %>
    </div>
  </div>

<% if (result) { %>

  <!-- ─── 검색 ─── -->
  <div class="glass compact">
    <form id="searchForm" method="get" action="/pattern" style="display: flex; gap: 8px; align-items: center;">
      <input type="text" name="cq" value="<%= cQuery || '' %>" placeholder="검색 (예: 서울반도체 or 046890)" class="form-control form-control-sm" style="flex: 1;" />
      <button type="button" onclick="document.getElementById('searchForm').submit();" class="btn btn-outline-primary btn-sm" style="white-space: nowrap;"><i class="bi bi-search me-1"></i>검색</button>
    </form>
  </div>

  <!-- ─── QVA + VVI 목록 ─── -->

  <div class="tab-content">
    <div class="tab-pane fade show active" id="tab-today" role="tabpanel">

      <!-- 저점상승 + 구조진화 (최우선) -->
      <% const safeQvaStrongCandidates = qvaStrongCandidates || []; %>
      <div class="glass">
        <h2><i class="bi bi-star-fill me-1"></i>QVA-STRONG <span class="count">(<%= safeQvaStrongCandidates.length %>건)</span></h2>
        <div class="cat-banner" style="background:#fef3c7; border-left:4px solid #d97706; color:#92400e;">
          <strong>저점 상승 + 구조 진화</strong> — 저점 상승(HIGHER_LOW)과 구조 진화(EVOLUTION)를 동시에 만족하는 강한 신호입니다. 초기 누적 후 구조 개선 가능성이 높습니다.
        </div>

        <% if (safeQvaStrongCandidates.length === 0) { %>
          <div class="empty-state">QVA-STRONG 후보 없음</div>
        <% } else { %>
          <% safeQvaStrongCandidates.forEach(function(c) {
            var hlSig = (c.qvaHigherLow)?.signals || {};
            var evSig = (c.qvaEvolution)?.signals || {};
          %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span><span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                  <% if (c.marketCap) { %>
                    <span style="font-size:0.8rem; color:#64748b; margin-left:8px;">시총 <strong><%= (c.marketCap / 1e8).toFixed(0) %>억</strong></span>
                  <% } %>
                </div>
                <div style="display:flex; gap:4px; flex-wrap:wrap; align-items:center;">
                  <span class="score-pill" style="background:#fbbf24; color:#78350f;">QVA-STRONG</span>
                  <% if (c.qvaBadges && c.qvaBadges.length > 0) { %>
                    <% c.qvaBadges.forEach(badge => {
                      // 배지별 색상 정의 (위험도에 따라)
                      let bgColor = '#e5e7eb', textColor = '#374151';

                      // 안정형 (초록)
                      if (badge === '안정형') { bgColor = '#d1fae5'; textColor = '#065f46'; }

                      // 재료 배지 (파랑)
                      else if (badge === '실적재료') { bgColor = '#dbeafe'; textColor = '#0369a1'; }
                      else if (badge === '테마주의') { bgColor = '#dbeafe'; textColor = '#0369a1'; }

                      // 주의 배지 (주황)
                      else if (badge === 'VI주의') { bgColor = '#fed7aa'; textColor = '#92400e'; }
                      else if (badge === '변동성주의') { bgColor = '#fed7aa'; textColor = '#92400e'; }

                      // 위험 배지 (빨강)
                      else if (badge === '바이오이벤트') { bgColor = '#fecaca'; textColor = '#7c2d12'; }
                      else if (badge === 'CB주의') { bgColor = '#fca5a5'; textColor = '#7c2d12'; }
                    %>
                      <span class="badge" style="background:<%= bgColor %>; color:<%= textColor %>; padding:2px 6px; border-radius:3px; font-size:0.7rem; font-weight:600; white-space:nowrap;">
                        <%= badge %>
                      </span>
                    <% }) %>
                  <% } %>
                </div>
              </div>
              <div class="row2">
                <span>HL점수 <strong><%= (c.qvaHlScore || 0).toFixed(0) %>/100</strong></span>
                <span>EV점수 <strong><%= (c.qvaEvScore || 0).toFixed(0) %>/100</strong></span>
                <span>거래대금비(중앙값) <strong><%= (c.qvaMedianRatio || 0).toFixed(2) %>x</strong></span>
                <span>구조 진화 <strong><%= (evSig.structureCount || 0) %>/6</strong></span>
                <% if (c.qvaBadges && c.qvaBadges.length > 0) { %>
                  <div style="display:flex; gap:3px; flex-wrap:wrap; width:100%;">
                    <% c.qvaBadges.forEach(badge => {
                      let bgColor = '#e5e7eb', textColor = '#374151';
                      if (badge === '안정형') { bgColor = '#d1fae5'; textColor = '#065f46'; }
                      else if (badge === '실적재료' || badge === '테마주의') { bgColor = '#dbeafe'; textColor = '#0369a1'; }
                      else if (badge === 'VI주의' || badge === '변동성주의') { bgColor = '#fed7aa'; textColor = '#92400e'; }
                      else if (badge === '바이오이벤트' || badge === 'CB주의') { bgColor = '#fca5a5'; textColor = '#7c2d12'; }
                    %>
                      <span style="background:<%= bgColor %>; color:<%= textColor %>; padding:2px 5px; border-radius:3px; font-size:0.65rem; font-weight:600; white-space:nowrap;">
                        <%= badge %>
                      </span>
                    <% }) %>
                  </div>
                <% } %>
              </div>
              <div class="row2">
                <span>현재가 <strong data-stock-code="<%= c.code %>"><%= (c.closePrice || 0).toLocaleString() %>원</strong></span>
                <span>거래량비 <strong><%= (hlSig.volumeRatio20 || 0).toFixed(2) %>x</strong></span>
                <span>저점 상승 <strong><%= hlSig.higherLow5 ? '✓' : '✗' %></strong></span>
                <span>가격 거리 <strong><%= (evSig.distToHigh20Pct || 0).toFixed(1) %>%</strong></span>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- 저점 상승 (메인 QVA) -->
      <% const safeQvaHigherLowCandidates = qvaHigherLowCandidates || []; %>
      <div class="glass">
        <h2><i class="bi bi-graph-up-arrow me-1"></i>QVA — 20거래일 추적 후보 <span class="count">(<%= safeQvaHigherLowCandidates.length %>건)</span></h2>
        <div class="cat-banner" style="background:#dcfce7; border-left:4px solid #16a34a; color:#15803d;">
          거래량·거래대금 이상징후와 저점 상승이 감지된 종목입니다. 매수 추천이 아니라, 이후 20거래일 안에 큰 상승 구간이 나오는지 추적하기 위한 후보입니다.
        </div>

        <% if (safeQvaHigherLowCandidates.length === 0) { %>
          <div class="empty-state">QVA-HL 후보 없음</div>
        <% } else { %>
          <% safeQvaHigherLowCandidates.forEach(function(c) {
            var s = (c.qvaHigherLow)?.signals || {};
          %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span><span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                  <% if (c.marketCap) { %>
                    <span style="font-size:0.8rem; color:#64748b; margin-left:8px;">시총 <strong><%= (c.marketCap / 1e8).toFixed(0) %>억</strong></span>
                  <% } %>
                </div>
                <span class="score-pill" style="background:#bbf7d0; color:#166534;">QVA-HL</span>
              </div>
              <div class="row2">
                <span>점수 <strong><%= (c.qvaScore || 0).toFixed(0) %>/100</strong></span>
                <span>거래량비 <strong><%= (s.volumeRatio20 || 0).toFixed(2) %>x</strong></span>
                <span>거래대금비 <strong><%= (s.valueRatio20 || 0).toFixed(2) %>x</strong></span>
                <span>거래대금비(중앙값) <strong><%= (s.valueMedianRatio20 || 0).toFixed(2) %>x</strong></span>
              </div>
              <div class="row2">
                <span>현재가 <strong data-stock-code="<%= c.code %>"><%= (c.closePrice || 0).toLocaleString() %>원</strong></span>
                <span>低点 상승 <strong><%= s.higherLow5 ? '✓' : '✗' %></strong></span>
                <span>가격거리 <strong><%= (s.distToHigh20Pct || 0).toFixed(1) %>%</strong></span>
                <span>今日 <strong class="<%= s.todayReturn >= 0 ? 'ret-pos' : 'ret-neg' %>"><%= (s.todayReturn || 0).toFixed(2) %>%</strong></span>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- 1. 거래대금 초동 후보 (VVI Breakout Confirm) — 가장 먼저 표시 -->
      <div class="glass">
        <h2><i class="bi bi-graph-up me-1"></i>거래대금 초동 후보 <span class="count">(<%= safeVviTodayCandidates.length %>건)</span><% if (safeLatestMarketDate) { %> <small style="color:#94a3b8; font-weight:400; font-size:0.72rem; margin-left:8px;">기준일 <%= safeLatestMarketDate %></small><% } %></h2>
        <div class="cat-banner vvi" style="background:linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%); color:#78350f; border-left:4px solid #d97706;">
          <strong>VVI Breakout Confirm</strong> — 오늘 거래량과 거래대금이 평소보다 증가하고, 종가가 당일 범위 상단에서 마감한 종목입니다. 다음 거래일에 전일 고가를 돌파하는지 확인하는 방식이 백테스트상 가장 양호했습니다.
          <br/><small style="margin-top:8px; display:block; color:#92400e;"><strong>d5 기준</strong> 평균 +1.77%, 승률 50%, PF 1.68 · 강세장에서는 평균 +4.63%, PF 3.46</small>
        </div>
        <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:12px; margin-bottom:16px; font-size:0.85rem; color:#475569;">
          <strong style="color:#0f172a;">태그 범례:</strong>
          <span style="display:inline-block; margin:6px 12px 0 0; background:#93c5fd; color:#1e3a8a; padding:2px 8px; border-radius:4px;">2~3배 초동</span>
          <span style="display:inline-block; margin:6px 12px 0 0; background:#a3e635; color:#365314; padding:2px 8px; border-radius:4px;">3~5배 확장</span>
          <span style="display:inline-block; margin:6px 12px 0 0; background:#fca5a5; color:#7f1d1d; padding:2px 8px; border-radius:4px;">⚠️ 5배+ 주의</span>
          <span style="display:inline-block; margin:6px 12px 0 0; background:#86efac; color:#166534; padding:2px 8px; border-radius:4px;">종가 강함</span>
          <span style="display:inline-block; margin:6px 12px 0 0; background:#c084fc; color:#4c1d95; padding:2px 8px; border-radius:4px;">대형주 우위</span>
          <span style="display:inline-block; margin:6px 12px 0 0; background:#fbbf24; color:#78350f; padding:2px 8px; border-radius:4px;">강세장 우위</span>
        </div>
        <div class="alert alert-info small mb-3" style="border-left:4px solid #3b82f6; background:#eff6ff; color:#1e40af;">
          <i class="bi bi-info-circle me-2"></i><strong>관찰용 신호입니다</strong> · 이 항목은 매수 추천이 아니라 거래대금 초동 관찰 신호입니다. 다음 거래일 전일 고가 돌파 여부를 확인하는 방식으로 해석합니다.
        </div>
        <% if (!safeVviTodayCandidates || !safeVviTodayCandidates.length) { %>
          <div class="empty-state">오늘 VVI 신호 없음</div>
        <% } else { %>
          <% safeVviTodayCandidates.forEach(function(c) { var s = c.vvi?.signals || {}; var vr = s.valueRatio20 || 0; var cl = s.closeLocation || 0; %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                  <% if (c.marketCap) { %>
                    <span style="font-size:0.8rem; color:#64748b; margin-left:8px;">시총 <strong><%= (c.marketCap / 1e8).toFixed(0) %>억</strong></span>
                  <% } %>
                </div>
                <span class="score-pill vvi" style="background:#d97706; border-color:#d97706;">VVI 점수 <%= c.vvi.score %></span>
              </div>

              <div class="row2">
                <span>신호일 <strong><%= c.signalDate %></strong></span>
                <span>신호 종가 <strong><%= won(c.signalClose) %></strong></span>
                <span>거래량배 <strong><%= (s.volumeRatio20 || 0).toFixed(1) %>배</strong></span>
                <span>거래대금배 <strong><%= (s.valueRatio20 || 0).toFixed(1) %>배</strong></span>
              </div>

              <div class="row2">
                <span>종가위치 <strong><%= ((cl || 0) * 100).toFixed(0) %>%</strong></span>
                <span>신호고가 <strong style="color:#dc2626;"><%= won(c.signalHigh) %></strong></span>
                <span>확인조건 <strong>전일 고가 돌파</strong></span>
                <span class="tag-badge" style="background:#fef3c7; color:#92400e;">대기중</span>
              </div>

              <div class="row3" style="flex-wrap:wrap; gap:6px;">
                <% if (vr >= 5.0) { %>
                  <span class="tag-badge" style="background:#fca5a5; color:#7f1d1d;">⚠️ 5배+ 주의</span>
                <% } else if (vr >= 3.0) { %>
                  <span class="tag-badge" style="background:#a3e635; color:#365314;">3~5배 확장</span>
                <% } else if (vr >= 2.0) { %>
                  <span class="tag-badge" style="background:#93c5fd; color:#1e3a8a;">2~3배 초동</span>
                <% } %>

                <% if (cl >= 0.8) { %>
                  <span class="tag-badge" style="background:#86efac; color:#166534;">종가 강함</span>
                <% } %>

                <% if ((c.marketCap || 0) >= 1_000_000_000_000) { %>
                  <span class="tag-badge" style="background:#c084fc; color:#4c1d95;">대형주 우위</span>
                <% } %>

                <% if (c.regime === 'bull') { %>
                  <span class="tag-badge" style="background:#fbbf24; color:#78350f;">강세장 우위</span>
                <% } %>

                <% if (c.vvi?.category === 'STRONG_IGNITION') { %>
                  <span class="tag-badge tag-VVI_STRONG">강한신호</span>
                <% } else { %>
                  <span class="tag-badge" style="background:#d1d5db; color:#374151;">신호</span>
                <% } %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- 2. 최근 VVI 신호 추적 (1~5 거래일 사후 상태) -->
      <div class="glass">
        <h2><i class="bi bi-clock-history me-1"></i>최근 VVI 신호 추적 <span class="count">(<%= safeVviRecentSignals.length %>건)</span><% if (safeLatestMarketDate) { %> <small style="color:#94a3b8; font-weight:400; font-size:0.72rem; margin-left:8px;">현재 <%= safeLatestMarketDate %> 기준</small><% } %></h2>
        <div class="cat-banner vvi" style="background:#fef9c3; border-left:4px solid #eab308; color:#713f12;">
          신호 발생 후 1~5 거래일 이내 종목의 추적 현황입니다. 상태별로 대응 방향이 다릅니다.
        </div>
        <% if (!safeVviRecentSignals || !safeVviRecentSignals.length) { %>
          <div class="empty-state">최근 5 거래일 내 추적 중인 신호 없음</div>
        <% } else { %>
          <% safeVviRecentSignals.forEach(function(c) {
             var s = c.vvi?.signals || {};
             var status = c.vviStatus || '';
             var statusConfig = {
               CONFIRMED:              { label: '돌파 확인', bg: '#d1fae5', color: '#065f46' },
               CHASE_RISK:             { label: '추격 위험', bg: '#fca5a5', color: '#7f1d1d' },
               PULLBACK_AFTER_CONFIRM: { label: '확인 후 되돌림', bg: '#fef3c7', color: '#854d0e' },
               FAILED_CONFIRM:         { label: '돌파 실패', bg: '#fee2e2', color: '#991b1b' },
               EXPIRED:                { label: '신호 만료', bg: '#f1f5f9', color: '#94a3b8' },
               STALE:                  { label: '데이터 오래됨', bg: '#e2e8f0', color: '#475569' }
             };
             var sc = statusConfig[status] || { label: status, bg: '#e2e8f0', color: '#475569' };
          %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a href="/?query=<%= c.code %>" class="deep-link" title="상세 보기">
                    <span class="nm"><%= c.name %></span>
                    <span class="cd"><%= c.code %></span>
                  </a>
                  <span class="mkt"><%= c.market %></span>
                  <% if (c.marketCap) { %>
                    <span style="font-size:0.8rem; color:#64748b; margin-left:8px;">시총 <strong><%= (c.marketCap / 1e8).toFixed(0) %>억</strong></span>
                  <% } %>
                </div>
                <span class="tag-badge" style="background:<%= sc.bg %>; color:<%= sc.color %>;"><%= sc.label %></span>
              </div>

              <div class="row2">
                <span>신호일 <strong><%= c.signalDate %></strong></span>
                <span>신호고가 <strong><%= won(c.signalHigh) %></strong></span>
                <span>현재가 <strong><%= won(c.currentPrice || c.closePrice) %></strong></span>
                <% if (c.signalHigh && (c.currentPrice || c.closePrice)) {
                     var retPct = (((c.currentPrice || c.closePrice) / c.signalHigh - 1) * 100).toFixed(1);
                     var retPos = parseFloat(retPct) >= 0;
                %>
                  <span>수익률(신호고가比) <strong class="<%= retPos ? 'ret-pos' : 'ret-neg' %>"><%= retPct %>%</strong></span>
                <% } %>
                <span style="margin-left:auto; color:#64748b;">D+<%= c.daysAfterSignal ?? '-' %></span>
              </div>

              <% if (c.confirmHigh && c.signalHigh) { %>
                <div class="row2">
                  <span>신호 후 최고가 <strong><%= won(c.confirmHigh) %></strong></span>
                  <% var peakRetPct = ((c.confirmHigh / c.signalHigh - 1) * 100).toFixed(1); %>
                  <span>최고 수익률 <strong class="ret-pos">+<%= peakRetPct %>%</strong></span>
                </div>
              <% } %>

              <div class="row3" style="flex-wrap:wrap; gap:6px;">
                <% if ((s.valueRatio20 || 0) >= 3.0) { %>
                  <span class="tag-badge" style="background:#a3e635; color:#365314;">거대금 3배+</span>
                <% } %>
                <% if (c.vvi?.category === 'STRONG_IGNITION') { %>
                  <span class="tag-badge tag-VVI_STRONG">강한신호</span>
                <% } %>
                <% if (c.regime === 'bull') { %>
                  <span class="tag-badge" style="background:#fbbf24; color:#78350f;">강세장</span>
                <% } %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

    </div><!-- /tab-today -->
  </div><!-- /tab-content -->

  <!-- ─── 서비스 안내 ─── -->
  <div class="service-notice">
    <strong>본 서비스는 매수 추천이 아닙니다.</strong>
    각 종목의 상태와 과거 검증 기반 후보를 보여주는 분석 도구입니다.
    각 모델은 서로 다른 가설을 기반으로 하며, 시장 상황에 따라 성과가 달라질 수 있습니다.
    투자 판단과 책임은 사용자 본인에게 있습니다.
  </div>

<% } else { %>
  <div class="glass">
    <p class="text-secondary mb-0">아직 분석 결과가 없습니다. 관리자 페이지에서 시드 + 분석을 실행하세요.</p>
  </div>
<% } %>

</div><!-- /wrap -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// 중소형 READY 필터링
var smallCapCapFilter = 'all';
var smallCapPriceFilter = 'all';
function filterSmallCap(value, type, btn) {
  if (type === 'cap') {
    smallCapCapFilter = value;
    document.querySelectorAll('.smallcap-filter-cap').forEach(b => updateButtonStyle(b, false));
    updateButtonStyle(btn, true);
  } else {
    smallCapPriceFilter = value;
    document.querySelectorAll('.smallcap-filter-price').forEach(b => updateButtonStyle(b, false));
    updateButtonStyle(btn, true);
  }
  applySmallCapFilters();
}
function applySmallCapFilters() {
  document.querySelectorAll('.smallcap-item').forEach(item => {
    var cap = item.getAttribute('data-cap');
    var price = parseInt(item.getAttribute('data-price'));
    var show = true;
    if (smallCapCapFilter !== 'all' && cap !== smallCapCapFilter) show = false;
    if (smallCapPriceFilter === 'price50k' && price > 50000) show = false;
    if (smallCapPriceFilter === 'price100k' && price > 100000) show = false;
    if (smallCapPriceFilter === 'price200k' && price > 200000) show = false;
    item.style.display = show ? 'block' : 'none';
  });
}

// 중소형 WATCH 필터링
var smallCapWatchCapFilter = 'all';
var smallCapWatchPriceFilter = 'all';
function filterSmallCapWatch(value, type, btn) {
  if (type === 'cap') {
    smallCapWatchCapFilter = value;
    document.querySelectorAll('.smallcap-filter-cap-watch').forEach(b => updateButtonStyle(b, false));
    updateButtonStyle(btn, true);
  } else {
    smallCapWatchPriceFilter = value;
    document.querySelectorAll('.smallcap-filter-price-watch').forEach(b => updateButtonStyle(b, false));
    updateButtonStyle(btn, true);
  }
  applySmallCapWatchFilters();
}
function applySmallCapWatchFilters() {
  document.querySelectorAll('.smallcap-item-watch').forEach(item => {
    var cap = item.getAttribute('data-cap');
    var price = parseInt(item.getAttribute('data-price'));
    var show = true;
    if (smallCapWatchCapFilter !== 'all' && cap !== smallCapWatchCapFilter) show = false;
    if (smallCapWatchPriceFilter === 'price50k' && price > 50000) show = false;
    if (smallCapWatchPriceFilter === 'price100k' && price > 100000) show = false;
    if (smallCapWatchPriceFilter === 'price200k' && price > 200000) show = false;
    item.style.display = show ? 'block' : 'none';
  });
}

// 버튼 스타일 업데이트
function updateButtonStyle(btn, isActive) {
  if (isActive) {
    btn.classList.add('active');
    btn.style.backgroundColor = '#dbeafe';
    btn.style.borderColor = '#3b82f6';
    btn.style.color = '#1e40af';
  } else {
    btn.classList.remove('active');
    btn.style.backgroundColor = '#fff';
    btn.style.borderColor = '#cbd5e1';
    btn.style.color = '#334155';
  }
}

// 보유/관심종목 점검 폼 AJAX 제출 (페이지 리로드 없이 탭 유지)
function submitHoldingsCheck() {
  var holdingsInput = document.getElementById('holdingsInput');
  var cqInput = document.querySelector('input[name="cq"]');

  if (!holdingsInput.value.trim()) {
    alert('점검할 종목을 입력하세요.');
    return;
  }

  var params = new URLSearchParams();
  if (holdingsInput.value.trim()) params.append('holdings', holdingsInput.value.trim());
  if (cqInput && cqInput.value) params.append('cq', cqInput.value);

  var queryString = params.toString();
  var url = '/pattern' + (queryString ? '?' + queryString : '');

  fetch(url)
    .then(response => response.text())
    .then(html => {
      var parser = new DOMParser();
      var newDoc = parser.parseFromString(html, 'text/html');
      var newHoldingsSection = newDoc.querySelector('#holdings-results');
      var currentHoldingsSection = document.querySelector('#holdings-results');

      if (newHoldingsSection && currentHoldingsSection) {
        currentHoldingsSection.innerHTML = newHoldingsSection.innerHTML;
      }
    })
    .catch(error => console.error('점검 실패:', error));
}

// 실시간 현재가 갱신
function updateCurrentPrices() {
  const priceElements = document.querySelectorAll('[data-stock-code]');
  if (!priceElements.length) return;

  const codes = Array.from(priceElements).map(el => el.dataset.stockCode).filter(c => c);
  if (!codes.length) return;

  fetch('/api/current-prices?codes=' + codes.join(','))
    .then(r => r.json())
    .then(prices => {
      priceElements.forEach(el => {
        const code = el.dataset.stockCode;
        if (prices[code]) {
          el.textContent = prices[code].toLocaleString() + '원';
          el.dataset.currentPrice = prices[code];
        }
      });
    })
    .catch(e => console.error('현재가 갱신 실패:', e));
}

// 초기 버튼 스타일
document.addEventListener('DOMContentLoaded', function() {
  // 필터 버튼 스타일
  document.querySelectorAll('.smallcap-filter-cap, .smallcap-filter-price, .smallcap-filter-cap-watch, .smallcap-filter-price-watch').forEach(btn => {
    if (btn.classList.contains('active')) {
      updateButtonStyle(btn, true);
    } else {
      updateButtonStyle(btn, false);
    }
  });

  // URL hash 확인하고 탭 활성화
  if (window.location.hash) {
    var tabId = window.location.hash.substring(1); // '#' 제거
    var tabElement = document.getElementById(tabId);
    if (tabElement) {
      var tab = new bootstrap.Tab(tabElement);
      tab.show();
    }
  }

  // 현재가 초기 갱신 및 주기적 갱신 (30초)
  updateCurrentPrices();
  setInterval(updateCurrentPrices, 30000);
});
</script>
</body>
</html>
