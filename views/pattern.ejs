<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>패턴 스크리너 — +40% 종목 분석</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    body {
      background: #f3f5fb; color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      padding: 24px 16px;
    }
    .wrap { max-width: 1100px; margin: 0 auto; }
    .glass { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 6px 18px rgba(15,23,42,0.06); margin-bottom: 20px; }
    h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 6px; }
    h2 { font-size: 1.05rem; font-weight: 700; margin: 0 0 12px; }
    .meta-cell { background: #f8fafc; border-radius: 10px; padding: 10px 12px; }
    .meta-cell .label { color: #64748b; font-size: 0.72rem; margin-bottom: 4px; }
    .meta-cell .value { font-weight: 600; color: #0f172a; }
    .bucket-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
    .bucket-card { background: #f8fafc; border-radius: 10px; padding: 12px; }
    .bucket-card h3 { font-size: 0.95rem; font-weight: 700; margin: 0 0 6px; }
    .bucket-card .feature-row { display: flex; justify-content: space-between; font-size: 0.78rem; color: #475569; margin-bottom: 2px; }
    .bucket-card .feature-row strong { color: #0f172a; }
    .magnitude-pill { display: inline-block; padding: 2px 8px; border-radius: 999px; background: #dcfce7; color: #166534; font-size: 0.72rem; font-weight: 700; }
    .regime-bull { color: #166534; font-weight: 600; }
    .regime-bear { color: #991b1b; font-weight: 600; }
    .regime-side { color: #475569; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }

    /* ─── 카드 리스트 (모바일·데스크탑 공통) ─── */
    .item-card { background: #f8fafc; border-radius: 10px; padding: 10px 12px; margin-bottom: 8px; }
    .item-card .row1 { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 4px; flex-wrap: wrap; }
    .item-card .row1 .name-block { flex: 1; min-width: 0; }
    .item-card .row1 .name-block .nm { font-weight: 700; color: #0f172a; }
    .item-card .row1 .name-block .cd { color: #94a3b8; font-size: 0.78rem; margin-left: 4px; }
    .item-card .row1 .name-block a.deep-link { text-decoration: none; color: inherit; display: inline-flex; align-items: center; gap: 2px; }
    .item-card .row1 .name-block a.deep-link:hover .nm { color: #2563eb; text-decoration: underline; }
    .item-card .row1 .name-block a.deep-link .arr { color: #cbd5e1; font-size: 0.7rem; margin-left: 2px; }
    .item-card .row1 .name-block a.deep-link:hover .arr { color: #2563eb; }
    .item-card .row1 .name-block .rk { color: #64748b; font-size: 0.78rem; margin-right: 6px; font-variant-numeric: tabular-nums; }
    .item-card .row2, .item-card .row3 {
      display: flex; flex-wrap: wrap; gap: 4px 12px;
      font-size: 0.78rem; color: #475569;
    }
    .item-card .row2 strong, .item-card .row3 strong { color: #0f172a; font-variant-numeric: tabular-nums; }
    .item-card .row3 { margin-top: 3px; padding-top: 4px; border-top: 1px dashed #e2e8f0; }
    .score-pill { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.78rem; font-weight: 700; font-variant-numeric: tabular-nums; }

    /* per-feature LR 기여도 색상 */
    .feat { padding: 1px 6px; border-radius: 4px; }
    .feat-good { background: #dcfce7; color: #166534; }
    .feat-good strong { color: #166534; }
    .feat-bad  { background: #fee2e2; color: #991b1b; }
    .feat-bad strong { color: #991b1b; }
    .feat-neu  { background: transparent; color: #475569; }
    .feat .lr { font-size: 0.7rem; opacity: 0.7; margin-left: 2px; }

    .legend { display: inline-flex; gap: 8px; font-size: 0.72rem; margin-top: 4px; }
    .legend .swatch { display: inline-block; padding: 1px 6px; border-radius: 4px; }

    @media (max-width: 576px) {
      body { padding: 16px 10px; }
      .glass { padding: 14px; border-radius: 12px; margin-bottom: 14px; }
      h1 { font-size: 1.1rem; }
      .topbar { gap: 8px; }
      .topbar h1 i { display: none; }
      .item-card .row2, .item-card .row3 { font-size: 0.74rem; gap: 3px 10px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <h1><i class="bi bi-graph-up-arrow me-2"></i>패턴 스크리너 — +40% 상승 종목 분석</h1>
      <a href="/" class="text-secondary small text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i>홈으로
      </a>
    </div>

    <div class="glass">
      <h2><i class="bi bi-info-circle me-1"></i>현황</h2>
      <div class="row g-2 row-cols-2 row-cols-md-4">
        <div class="col"><div class="meta-cell"><div class="label">시드된 종목</div><div class="value"><%= seededCount %></div></div></div>
        <% if (result) { %>
          <div class="col"><div class="meta-cell"><div class="label">분석된 종목</div><div class="value"><%= result.processed %></div></div></div>
          <div class="col"><div class="meta-cell"><div class="label">+40% 이벤트</div><div class="value"><%= result.successCount %></div></div></div>
          <% if (result.candidates) { %>
            <div class="col"><div class="meta-cell"><div class="label">현재 후보</div><div class="value"><%= result.candidates.total %></div></div></div>
          <% } %>
        <% } %>
      </div>
      <div class="muted-text small mt-3 text-secondary">
        <% if (!result) { %>
          분석 결과 없음. <strong>관리자 페이지</strong>에서 시드(약 4분) → 분석(약 1분) 실행 필요.
        <% } else { %>
          분석 완료: <%= new Date(result.analyzedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %>
        <% } %>
      </div>
    </div>

    <% if (result) { %>
      <!-- 버킷별 점화 전 지표 분포 -->
      <div class="glass">
        <h2><i class="bi bi-bar-chart-line me-1"></i>점화 전 지표 — 상승 기간별 버킷 분포</h2>
        <div class="bucket-grid">
          <%
            const buckets = result.success.buckets;
            const bucketMeta = [
              { key: 'A', label: '속전속결 (~30일)', color: '#dc2626' },
              { key: 'B', label: '중기 상승 (31~50일)', color: '#ea580c' },
              { key: 'C', label: '장기 누적 (51~70일)', color: '#16a34a' },
              { key: 'D', label: '느린 트렌드 (71~90일)', color: '#0ea5e9' },
            ];
            const featureLabels = {
              turnover: '회전율 (시총 대비)',
              bullBearRatio: '양봉/음봉 거래대금',
              volumeSurge: '거래량 급증 배수',
              foreignDelta: '외인 보유율 변화 %p',
              atrCompress: 'ATR 수렴비',
              positionPct: '60일 고점 대비 위치',
              positionFromLow: '60일 저점 대비 상승률',
              maPos20: '20일선 대비 위치',
              maPos60: '60일선 대비 위치',
              ma20Slope: '20일선 기울기',
              ma60Slope: '60일선 기울기',
              resistAbove: '위쪽 매물대 비율',
              localResistance: '점화가 ±5% 매물 밀도',
              boxDays: '박스권 연속 일수',
              igniteValueRatio: '점화일 거래대금/시총',
              igniteVolumeRatio: '점화일 거래량 배수',
            };
          %>
          <% bucketMeta.forEach(function(bm) { var b = buckets[bm.key]; %>
            <div class="bucket-card" style="border-left: 3px solid <%= bm.color %>;">
              <h3><%= bm.label %></h3>
              <div class="text-secondary small mb-2">이벤트 <strong><%= b.n %></strong>건</div>
              <% if (b.summary) { %>
                <% Object.keys(featureLabels).forEach(function(k) { var f = b.summary[k]; %>
                  <% if (f) { %>
                    <div class="feature-row">
                      <span><%= featureLabels[k] %></span>
                      <strong><%= f.median %><span class="text-secondary" style="font-weight:400;font-size:0.7rem;"> (p25~p75: <%= f.p25 %>~<%= f.p75 %>)</span></strong>
                    </div>
                  <% } %>
                <% }) %>
              <% } else { %>
                <div class="text-muted small">데이터 없음</div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>


      <!-- 현재 후보 (Phase B: Likelihood Ratio 스코어링) -->
      <% if (result.candidates && result.candidates.top && result.candidates.top.length) { %>
        <div class="glass">
          <h2><i class="bi bi-radar me-1"></i>현재 후보 — +40% 종목 패턴 닮은 종목</h2>
          <div class="alert alert-success small mb-2" style="background:#ecfdf5; border-color:#a7f3d0; color:#065f46;">
            <i class="bi bi-stars me-1"></i><strong>지금 살 만한 종목 찾기.</strong>
            오늘 기준 직전 20일 거래 패턴이 과거 +40% 종목들 (long base → 폭발 패턴) 의 <em>점화 직전</em> 모습과 얼마나 닮았는지 — 16개 차원 중 몇 개가 매칭되는지 카운트.
            <strong>점화 전 60일선 -3% 이상 하락 종목은 사전에 제외</strong> (인투셀·엔알비 같은 다운트렌드 위양성 방지).
            <ul class="mb-0 mt-1 ps-3" style="font-size:0.78rem;">
              <li><strong>16/16 (초록)</strong> = 모든 차원 매칭 — 가장 엄격</li>
              <li><strong>14~15/16 (노랑)</strong> = 권장 — 1~2개 빠지지만 통계적으로 충분히 닮음</li>
              <li><strong>그 이하 (회색)</strong> = 약하게 닮음</li>
            </ul>
            <div class="mt-1" style="font-size:0.75rem;">⚠ <strong>"언제" 점화될지는 모름</strong> — 1주 안일 수도, 한 달 뒤일 수도. 후보군일 뿐 매수 시그널 아님.</div>
            <div class="mt-2" style="font-size:0.75rem; padding:6px 8px; background:#fef3c7; border-radius:6px; color:#92400e;">
              💡 <strong>실전 매수 시점 찾기</strong>: 매칭 14+ 는 "조용한 watchlist" 용 — breakout 거의 없는 게 정상.
              실제 진입할 후보는 <strong>매칭 12~13/16 + 🔥 breakout</strong> 조합 (cmin 12 로 낮추고 breakout 만 체크). 오늘 8건.
            </div>
            <% if (result.candidates && result.candidates.signature) { %>
              <details class="mt-2" style="font-size:0.75rem;">
                <summary style="cursor:pointer; color:#065f46;">🎯 +40% 종목들이 공통으로 보였던 패턴 (16개 차원 · 중심 60% 밴드)</summary>
                <%
                  const sig = result.candidates.signature;
                  function sigFmt(k, v) {
                    if (v == null) return '-';
                    if (k === 'turnover' || k === 'igniteValueRatio' || k === 'localResistance' || k === 'resistAbove') return (v*100).toFixed(0) + '%';
                    if (k === 'positionPct' || k === 'positionFromLow' || k === 'maPos20' || k === 'maPos60' || k === 'ma20Slope' || k === 'ma60Slope') {
                      const d = (v - 1) * 100;
                      return (d >= 0 ? '+' : '') + d.toFixed(0) + '%';
                    }
                    if (k === 'igniteVolumeRatio' || k === 'volumeSurge' || k === 'atrCompress' || k === 'bullBearRatio') return v.toFixed(2) + '배';
                    if (k === 'boxDays') return v + '일';
                    if (k === 'foreignDelta') return (v >= 0 ? '+' : '') + (v*100).toFixed(0) + '%p';
                    return v;
                  }
                  const sigOrder = [
                    ['ma60Slope', '60일선 기울기 ⭐'],
                    ['ma20Slope', '20일선 기울기'],
                    ['turnover', '20일 회전율'],
                    ['boxDays', '박스권'],
                    ['positionPct', '60일 고점 대비'],
                    ['positionFromLow', '60일 저점 대비'],
                    ['maPos20', '20일선 대비'],
                    ['maPos60', '60일선 대비'],
                    ['localResistance', '현재가 매물밀도'],
                    ['resistAbove', '위쪽 매물대'],
                    ['igniteValueRatio', '오늘 거래대금/시총'],
                    ['igniteVolumeRatio', '오늘 거래량 (평소 대비)'],
                    ['volumeSurge', '5일 평균 거래량'],
                    ['bullBearRatio', '양봉/음봉 거래대금'],
                    ['atrCompress', 'ATR 수렴'],
                    ['foreignDelta', '외인 보유율 변화'],
                  ];
                %>
                <ul class="mb-0 mt-1 ps-3" style="font-size:0.72rem; line-height:1.5;">
                  <% sigOrder.forEach(function(p) { const k = p[0], lbl = p[1], s = sig[k]; if (!s) return; %>
                    <li><strong><%= lbl %></strong>: <%= sigFmt(k, s.lo) %> ~ <%= sigFmt(k, s.hi) %> <span class="text-secondary">(median <%= sigFmt(k, s.p50) %>)</span></li>
                  <% }) %>
                </ul>
                <div class="mt-1" style="font-size:0.7rem; color:#475569;">
                  💡 후보 카드의 <strong>"N/14"</strong> = 그 후보가 14개 차원 중 몇 개를 이 밴드 안에 들어가는지.
                </div>
              </details>
            <% } %>
            <details class="mt-2" style="font-size:0.75rem;">
              <summary style="cursor:pointer; color:#065f46;">📖 features 읽는 법</summary>
              <ul class="mb-0 mt-1 ps-3" style="font-size:0.72rem; line-height:1.5;">
                <li><strong>20일선 / 60일 고점·저점</strong> = 종가가 그 선·점에서 ±몇 %인지 (양수=위, 음수=아래)</li>
                <li><strong>현재가 매물밀도</strong> = 직전 60일 거래대금 중 종가 ±5% 가격대에 쌓인 비율 (높을수록 매물 두꺼움)</li>
                <li><strong>20일 회전율</strong> = 직전 20일 거래대금 합계가 시총의 몇 % (100% = 시총만큼 거래됨)</li>
                <li><strong>박스권</strong> = 점화 직전 일변동 ≤4% 가 며칠 연속이었나 (성공 종목은 보통 0일 — 박스 없이 점화)</li>
                <li><strong>오늘 거래량</strong> = 오늘 거래량 / 직전 20일 평균 (1배=평소, 3배+=급증)</li>
                <li><strong>오늘 거래대금</strong> = 오늘 거래대금 / 시총 (시총의 몇 % 가 오늘 거래됐나)</li>
              </ul>
            </details>
          </div>

          <form method="get" action="/pattern" class="row g-2 align-items-end mb-3">
            <div class="col-12 col-md-4">
              <label class="form-label small text-secondary mb-1">후보 검색</label>
              <input type="text" name="cq" value="<%= cQuery || '' %>" placeholder="예: 서울반도체 or 046890" class="form-control form-control-sm" />
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label small text-secondary mb-1">최소 매칭</label>
              <select name="cmin" class="form-select form-select-sm">
                <% [0,12,13,14,15,16].forEach(function(n) { %>
                  <option value="<%= n %>" <%= cMinMatch === n ? 'selected' : '' %>><%= n === 0 ? '제한 없음' : (n === 16 ? '16/16 (가장 엄격)' : n === 14 ? '14/16 (권장)' : n + '/16 이상') %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-md-3">
              <label class="form-label small text-secondary mb-1">최근 시동</label>
              <div class="form-check small">
                <input type="checkbox" name="cbreak" value="1" id="cbreak" class="form-check-input" <%= cOnlyBreakout ? 'checked' : '' %> />
                <label for="cbreak" class="form-check-label">🔥 breakout 만 (3일 안)</label>
              </div>
            </div>
            <div class="col-6 col-md-1">
              <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search"></i></button>
            </div>
            <div class="col-6 col-md-1">
              <a href="/pattern" class="btn btn-outline-secondary btn-sm w-100">초기화</a>
            </div>
          </form>

          <div class="text-secondary small mb-2">
            상위 <strong><%= result.candidates.total %></strong>건 중 <strong><%= totalCandidates %></strong>건
            <% if (totalCandidates > 0) { %>
              · <%= (candidatePage - 1) * pageSize + 1 %>~<%= Math.min(candidatePage * pageSize, totalCandidates) %> 표시 (페이지 <%= candidatePage %>/<%= totalCandidatePages %>)
            <% } %>
          </div>

          <% if (pagedCandidates.length === 0) { %>
            <div class="alert alert-light small mb-0">조건에 맞는 후보가 없습니다.</div>
          <% } else { %>
            <% pagedCandidates.forEach(function(c, idx) {
              const rank = (candidatePage - 1) * pageSize + idx + 1;
              const scoreColor = c.score >= 1.5 ? { bg: '#dcfce7', fg: '#166534' }
                : (c.score >= 0.5 ? { bg: '#fef3c7', fg: '#92400e' }
                : { bg: '#fee2e2', fg: '#991b1b' });
              const changeCls = (c.changeRate || 0) > 0 ? 'regime-bull' : (c.changeRate < 0 ? 'regime-bear' : 'regime-side');
            %>
              <%
                const matched = c.matched || 0;
                const totalK = c.totalKeys || 14;
                const matchPct = totalK > 0 ? matched / totalK : 0;
                const matchColor = matched === totalK ? { bg: '#dcfce7', fg: '#166534' }   // 14/14 만점
                  : (matchPct >= 11/14 ? { bg: '#fef3c7', fg: '#92400e' }                  // 11~13/14
                  : { bg: '#f1f5f9', fg: '#64748b' });                                       // 그 이하
              %>
              <div class="item-card">
                <div class="row1">
                  <div class="name-block">
                    <span class="rk">#<%= rank %></span>
                    <a class="deep-link" href="/?query=<%= encodeURIComponent(c.code) %>" target="_blank" rel="noopener" title="딥다이브 분석 (새 탭)">
                      <span class="nm"><%= c.name %></span>
                      <span class="cd"><%= c.code %></span>
                      <i class="bi bi-box-arrow-up-right arr"></i>
                    </a>
                    <% if (c.breakout) { %>
                      <span class="score-pill ms-1" style="background:#fef3c7; color:#92400e; font-size:0.68rem;" title="<%= c.breakout.date.slice(4,6)+'/'+c.breakout.date.slice(6,8) %> 거래량 <%= c.breakout.volRatio %>x + 양봉 +<%= c.breakout.dayChange %>%">
                        🔥 <%= c.breakout.daysAgo === 0 ? '오늘' : c.breakout.daysAgo + '일전' %> +<%= c.breakout.dayChange %>%
                      </span>
                    <% } %>
                  </div>
                  <span class="score-pill" style="background: <%= matchColor.bg %>; color: <%= matchColor.fg %>;" title="16개 차원 중 +40% 종목 패턴 밴드 안에 들어가는 차원 수">
                    <%= matched %>/<%= totalK %>
                  </span>
                </div>
                <div class="row2">
                  <span>시총 <strong><%= (c.marketCap / 1e8).toFixed(0) %>억</strong></span>
                  <span>종가 <strong><%= c.closePrice ? c.closePrice.toLocaleString() : '-' %></strong></span>
                  <span class="<%= changeCls %>"><%= c.changeRate != null ? (c.changeRate > 0 ? '+' : '') + c.changeRate.toFixed(2) + '%' : '-' %></span>
                </div>
                <%
                  // 시그니처 밴드 (p10~p90) 안에 들어가면 초록, 아니면 회색
                  function featCls(inBand) {
                    if (inBand == null) return 'feat feat-neu';
                    return inBand ? 'feat feat-good' : 'feat feat-neu';
                  }
                  // 사람이 읽기 좋은 포맷
                  function fmtPct(v)  { return v == null ? '-' : (v * 100).toFixed(0) + '%'; }
                  function fmtDelta(v){ if (v == null) return '-'; const d = (v - 1) * 100; return (d >= 0 ? '+' : '') + d.toFixed(0) + '%'; }
                  function fmtMult(v) { return v == null ? '-' : v.toFixed(1) + '배'; }
                  function fmtDays(v) { return v == null ? '-' : v + '일'; }

                  const featRowsA = [
                    // 가격/위치 관점
                    ['maPos20',          '20일선 대비',     fmtDelta(c.features?.maPos20),          c.features?.maPos20 != null ? `종가 / 20일 SMA = ${c.features.maPos20}` : ''],
                    ['positionPct',      '60일 고점',       fmtDelta(c.features?.positionPct),       c.features?.positionPct != null ? `종가 / 60일 고점 = ${c.features.positionPct}` : ''],
                    ['positionFromLow',  '60일 저점',       fmtDelta(c.features?.positionFromLow),   c.features?.positionFromLow != null ? `종가 / 60일 저점 = ${c.features.positionFromLow}` : ''],
                    ['localResistance',  '현재가 매물밀도', fmtPct(c.features?.localResistance),     c.features?.localResistance != null ? `점화가 ±5% 60일 거래대금 비율` : ''],
                  ];
                  const featRowsB = [
                    // 행동/거래 관점
                    ['turnover',          '20일 회전율',    fmtPct(c.features?.turnover),            '직전 20일 거래대금 / 시총'],
                    ['boxDays',           '박스권',         fmtDays(c.features?.boxDays),            '점화 직전 일변동 ≤4% 연속일수'],
                    ['igniteVolumeRatio', '오늘 거래량',    fmtMult(c.features?.igniteVolumeRatio), '오늘 거래량 / 직전 20일 평균'],
                    ['igniteValueRatio',  '오늘 거래대금',  fmtPct(c.features?.igniteValueRatio),    '오늘 거래대금 / 시총'],
                  ];
                %>
                <div class="row3">
                  <% featRowsA.forEach(function(fr) {
                    const inBand = c.sigBreakdown ? c.sigBreakdown[fr[0]] : null;
                  %>
                    <span class="<%= featCls(inBand) %>" title="<%= fr[3] %><%= inBand === true ? ' · ✓ 밴드 안' : (inBand === false ? ' · 밴드 밖' : '') %>">
                      <%= fr[1] %> <strong><%= fr[2] %></strong>
                    </span>
                  <% }) %>
                </div>
                <div class="row3">
                  <% featRowsB.forEach(function(fr) {
                    const lr = c.breakdown ? c.breakdown[fr[0]] : null;
                  %>
                    <span class="<%= featCls(lr) %>" title="<%= fr[3] %> · LR=<%= lr != null ? lr.toFixed(2) : '-' %>">
                      <%= fr[1] %> <strong><%= fr[2] %></strong>
                    </span>
                  <% }) %>
                </div>
              </div>
            <% }) %>

            <% if (totalCandidatePages > 1) {
              function candidatePageUrl(p) {
                const params = new URLSearchParams();
                if (cQuery) params.set("cq", cQuery);
                if (cSort && cSort !== "score") params.set("csort", cSort);
                if (cMinMatch > 0) params.set("cmin", cMinMatch);
                if (cOnlyBreakout) params.set("cbreak", "1");
                params.set("cpage", p);
                if (query) params.set("q", query);
                if (bucket !== "all") params.set("bucket", bucket);
                if (page > 1) params.set("page", page);
                return "/pattern?" + params.toString() + "#candidates";
              }
              const cStart = Math.max(1, candidatePage - 2);
              const cEnd = Math.min(totalCandidatePages, candidatePage + 2);
            %>
              <nav class="mt-3">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                  <li class="page-item <%= candidatePage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= candidatePageUrl(1) %>">«</a>
                  </li>
                  <li class="page-item <%= candidatePage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= candidatePageUrl(Math.max(1, candidatePage - 1)) %>">‹</a>
                  </li>
                  <% for (let p = cStart; p <= cEnd; p++) { %>
                    <li class="page-item <%= p === candidatePage ? 'active' : '' %>">
                      <a class="page-link" href="<%= candidatePageUrl(p) %>"><%= p %></a>
                    </li>
                  <% } %>
                  <li class="page-item <%= candidatePage === totalCandidatePages ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= candidatePageUrl(Math.min(totalCandidatePages, candidatePage + 1)) %>">›</a>
                  </li>
                  <li class="page-item <%= candidatePage === totalCandidatePages ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= candidatePageUrl(totalCandidatePages) %>">»</a>
                  </li>
                </ul>
              </nav>
            <% } %>
          <% } %>
        </div>
      <% } %>

      <!-- +40% 이벤트 리스트 + 검색·필터·페이징 -->
      <div class="glass">
        <h2><i class="bi bi-list-stars me-1"></i>+40% 이벤트 — 과거 데이터 (검증·드릴다운용)</h2>
        <div class="alert alert-secondary small mb-3" style="background:#f1f5f9; border-color:#cbd5e1; color:#334155;">
          <i class="bi bi-archive me-1"></i><strong>과거에 이미 +40% 오른 종목들의 원본 리스트</strong> — 위쪽 "현재 후보" 모델이 학습한 데이터예요.
          <ul class="mb-0 mt-1 ps-3" style="font-size:0.78rem;">
            <li>매매에는 직접 안 씀 (이미 다 끝난 사건들). 아래 용도로 가끔 보세요:</li>
            <li><strong>검증</strong> — 내가 아는 종목(예: 서울반도체)이 잡혔나? 시총·기간 분포가 합리적인가?</li>
            <li><strong>드릴다운</strong> — 특정 종목·버킷이 어떤 features 로 점화됐는지 확인</li>
          </ul>
        </div>

        <form method="get" action="/pattern" class="row g-2 align-items-end mb-3">
          <div class="col-12 col-md-5">
            <label class="form-label small text-secondary mb-1">종목 검색 (이름 또는 코드)</label>
            <input type="text" name="q" value="<%= query || '' %>" placeholder="예: 삼성전자 or 005930" class="form-control form-control-sm" />
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label small text-secondary mb-1">상승 기간 버킷</label>
            <select name="bucket" class="form-select form-select-sm">
              <option value="all" <%= bucket === 'all' ? 'selected' : '' %>>전체</option>
              <option value="A" <%= bucket === 'A' ? 'selected' : '' %>>A: 속전속결 (~30일)</option>
              <option value="B" <%= bucket === 'B' ? 'selected' : '' %>>B: 중기 (31~50일)</option>
              <option value="C" <%= bucket === 'C' ? 'selected' : '' %>>C: 장기 (51~70일)</option>
              <option value="D" <%= bucket === 'D' ? 'selected' : '' %>>D: 느린 (71~90일)</option>
            </select>
          </div>
          <div class="col-6 col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100">
              <i class="bi bi-search me-1"></i>검색
            </button>
          </div>
          <div class="col-12 col-md-2 text-end">
            <a href="/pattern" class="btn btn-outline-secondary btn-sm w-100">초기화</a>
          </div>
        </form>

        <div class="text-secondary small mb-2">
          총 <strong><%= totalEvents %></strong>건
          <% if (totalEvents > 0) { %>
            · <%= (page - 1) * pageSize + 1 %>~<%= Math.min(page * pageSize, totalEvents) %> 표시 (페이지 <%= page %>/<%= totalPages %>)
          <% } %>
          <% if (query || bucket !== 'all') { %>
            <span class="text-warning">(필터 적용 중)</span>
          <% } %>
        </div>

        <% if (pagedEvents.length === 0) { %>
          <div class="alert alert-light small mb-0">조건에 맞는 이벤트가 없습니다.</div>
        <% } else { %>
          <% pagedEvents.forEach(function(e) {
            const regimeCls = e.regime === '강세' ? 'regime-bull' : (e.regime === '약세' ? 'regime-bear' : 'regime-side');
            const ignMd = e.ignitionDate.slice(4,6) + '/' + e.ignitionDate.slice(6,8);
            const pkMd = e.peakDate.slice(4,6) + '/' + e.peakDate.slice(6,8);
          %>
            <div class="item-card">
              <div class="row1">
                <div class="name-block">
                  <a class="deep-link" href="/?query=<%= encodeURIComponent(e.code) %>" target="_blank" rel="noopener" title="딥다이브 분석 (새 탭)">
                    <span class="nm"><%= e.name %></span>
                    <span class="cd"><%= e.code %></span>
                    <i class="bi bi-box-arrow-up-right arr"></i>
                  </a>
                  <% if (e.inProgress) { %><span class="badge bg-warning text-dark ms-1" style="font-size:0.62rem;">진행중</span><% } %>
                </div>
                <span class="magnitude-pill">+<%= (e.magnitude * 100).toFixed(0) %>%</span>
              </div>
              <div class="row2">
                <span>시총 <strong><%= (e.marketCap / 1e8).toFixed(0) %>억</strong></span>
                <span><%= ignMd %> → <%= pkMd %> <strong><%= e.duration %>일</strong></span>
                <span class="<%= regimeCls %>"><%= e.regime %></span>
              </div>
              <div class="row3">
                <span>회전율 <strong><%= e.features?.turnover ?? '-' %></strong></span>
                <span>양/음봉 <strong><%= e.features?.bullBearRatio ?? '-' %></strong></span>
              </div>
            </div>
          <% }) %>

          <% if (totalPages > 1) {
            function pageUrl(p) {
              const params = new URLSearchParams();
              if (query) params.set("q", query);
              if (bucket !== "all") params.set("bucket", bucket);
              params.set("page", p);
              return "/pattern?" + params.toString();
            }
            // 표시할 페이지 번호 — 현재 페이지 ±2
            const start = Math.max(1, page - 2);
            const end = Math.min(totalPages, page + 2);
          %>
            <nav class="mt-3">
              <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= pageUrl(1) %>">«</a>
                </li>
                <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= pageUrl(Math.max(1, page - 1)) %>">‹</a>
                </li>
                <% for (let p = start; p <= end; p++) { %>
                  <li class="page-item <%= p === page ? 'active' : '' %>">
                    <a class="page-link" href="<%= pageUrl(p) %>"><%= p %></a>
                  </li>
                <% } %>
                <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= pageUrl(Math.min(totalPages, page + 1)) %>">›</a>
                </li>
                <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= pageUrl(totalPages) %>">»</a>
                </li>
              </ul>
            </nav>
          <% } %>
        <% } %>
      </div>
    <% } %>

    <div class="text-center text-secondary small mt-4">
      <a href="/admin" class="text-decoration-none text-secondary">
        <i class="bi bi-gear me-1"></i>관리자 페이지에서 시드/분석 실행
      </a>
    </div>
  </div>
</body>
</html>
