<%
  function fmtNum(n, digits) {
    if (n === null || n === undefined || Number.isNaN(Number(n))) return "-";
    return Number(n).toLocaleString("ko-KR", { maximumFractionDigits: digits ?? 0 });
  }
  function fmtPct(n) {
    if (n === null || n === undefined || Number.isNaN(Number(n))) return "-";
    const v = Number(n);
    const sign = v > 0 ? "+" : "";
    return sign + v.toFixed(2) + "%";
  }
  function changeColor(n) {
    const v = Number(n);
    if (v > 0) return "#dc2626";
    if (v < 0) return "#2563eb";
    return "#475569";
  }
  function scoreColor(s) {
    const v = Number(s) || 0;
    if (v >= 70) return "#16a34a";
    if (v >= 50) return "#ca8a04";
    return "#64748b";
  }
  function escapeHtml(s) {
    return String(s ?? "").replace(/[&<>"']/g, (c) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
    })[c]);
  }
  function fmtMarketCap(eok) {
    if (!eok || Number.isNaN(Number(eok))) return "-";
    const v = Number(eok);
    if (v >= 10000) return (v / 10000).toFixed(1) + "조";
    return Math.round(v).toLocaleString("ko-KR") + "억";
  }
  function badge(label, score) {
    const v = Number(score) || 0;
    const active = v >= 70;
    const color = active ? "#ffffff" : "#94a3b8";
    const bg = active ? "#0ea5e9" : "#e2e8f0";
    return `<span style="display:inline-block;padding:1px 6px;margin-right:3px;border-radius:4px;font-size:10px;font-weight:700;color:${color};background:${bg};">${label}</span>`;
  }
%><!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>스윙 스캔 <%= dateStr %></title>
</head>
<body style="margin:0;padding:0;background:#f3f5fb;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Apple SD Gothic Neo','Malgun Gothic',sans-serif;color:#1f2937;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background:#f3f5fb;padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="640" cellspacing="0" cellpadding="0" border="0" style="max-width:640px;width:100%;background:#ffffff;border-radius:14px;box-shadow:0 6px 18px rgba(15,23,42,0.06);overflow:hidden;">

          <tr>
            <td style="padding:24px 28px 16px 28px;background:linear-gradient(135deg,#0ea5e9 0%,#6366f1 100%);color:#ffffff;">
              <div style="font-size:13px;letter-spacing:0.5px;opacity:0.85;">SWING SCAN · <%= dateStr %></div>
              <div style="font-size:20px;font-weight:700;margin-top:4px;">오늘의 스윙 후보 상위 <%= top.length %>종목</div>
            </td>
          </tr>

          <% if (market && (market.kospi || market.kosdaq)) { %>
          <tr>
            <td style="padding:14px 28px;background:#f8fafc;border-bottom:1px solid #e2e8f0;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <% if (market.kospi) { %>
                  <td width="50%" style="font-size:13px;">
                    <span style="color:#64748b;font-weight:600;">코스피</span>
                    <span style="margin-left:8px;font-weight:700;color:#0f172a;"><%= fmtNum(market.kospi.price, 2) %></span>
                    <span style="margin-left:8px;font-weight:600;color:<%= changeColor(market.kospi.changeRate) %>;"><%= fmtPct(market.kospi.changeRate) %></span>
                  </td>
                  <% } %>
                  <% if (market.kosdaq) { %>
                  <td width="50%" style="font-size:13px;">
                    <span style="color:#64748b;font-weight:600;">코스닥</span>
                    <span style="margin-left:8px;font-weight:700;color:#0f172a;"><%= fmtNum(market.kosdaq.price, 2) %></span>
                    <span style="margin-left:8px;font-weight:600;color:<%= changeColor(market.kosdaq.changeRate) %>;"><%= fmtPct(market.kosdaq.changeRate) %></span>
                  </td>
                  <% } %>
                </tr>
              </table>
            </td>
          </tr>
          <% } %>

          <tr>
            <td style="padding:18px 16px 8px 16px;">
              <% top.forEach(function(item, i) { %>
                <% var sm = item.scoreModel || {}; %>
                <% var ne = item.nightlyExtras || {}; %>
                <% var displayScore = ne.nightlyTotal != null ? ne.nightlyTotal : sm.totalScore; %>
                <% var yhPct = ne.yearHighRatio != null ? Math.round(ne.yearHighRatio * 100) : null; %>
                <% var detailUrl = baseUrl + "/?query=" + encodeURIComponent(item.shortCode); %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:12px;border:1px solid #e2e8f0;border-radius:10px;border-collapse:separate;">
                <tr>
                  <td style="padding:12px 14px 10px 14px;background:#fafbfd;border-radius:10px 10px 0 0;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td valign="top" style="width:30px;color:#94a3b8;font-weight:700;font-size:14px;line-height:1.2;">
                          #<%= i + 1 %>
                        </td>
                        <td valign="top" style="line-height:1.3;">
                          <a href="<%= detailUrl %>" style="color:#0f172a;font-weight:700;text-decoration:none;font-size:15px;"><%= escapeHtml(item.name) %></a>
                          <div style="color:#94a3b8;font-size:11px;margin-top:3px;white-space:nowrap;">
                            <%= escapeHtml(item.shortCode) %><% if (item.market && item.market !== "-") { %> · <%= escapeHtml(item.market) %><% } %><% if (ne.marketCap) { %> · <%= fmtMarketCap(ne.marketCap) %><% } %>
                          </div>
                        </td>
                        <td align="right" valign="top" style="white-space:nowrap;width:80px;">
                          <span style="display:inline-block;min-width:36px;padding:4px 10px;border-radius:6px;font-weight:700;color:#ffffff;background:<%= scoreColor(displayScore) %>;font-size:13px;">
                            <%= fmtNum(displayScore, 0) %>
                          </span>
                        </td>
                      </tr>
                      <% if (sm.verdict || ne.flow || ne.dryUp || ne.squeeze) { %>
                      <tr>
                        <td colspan="3" style="padding-top:8px;line-height:1.4;">
                          <%- badge("수급", ne.flow && ne.flow.score) %>
                          <%- badge("마름", ne.dryUp && ne.dryUp.score) %>
                          <%- badge("수렴", ne.squeeze && ne.squeeze.score) %>
                          <% if (sm.verdict) { %>
                            <span style="color:#64748b;font-size:11px;margin-left:6px;"><%= escapeHtml(sm.verdict) %></span>
                          <% } %>
                        </td>
                      </tr>
                      <% } %>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:10px 14px 12px 14px;border-top:1px solid #f1f5f9;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td valign="top" align="left" style="line-height:1.3;">
                          <div style="color:#94a3b8;font-size:10px;">현재가</div>
                          <div style="font-weight:700;color:#0f172a;font-size:14px;"><%= fmtNum(item.currentPrice, 0) %></div>
                        </td>
                        <td valign="top" align="center" style="line-height:1.3;">
                          <div style="color:#94a3b8;font-size:10px;">등락</div>
                          <div style="font-weight:700;color:<%= changeColor(item.changeRate) %>;font-size:14px;"><%= fmtPct(item.changeRate) %></div>
                        </td>
                        <td valign="top" align="center" style="line-height:1.3;">
                          <div style="color:#94a3b8;font-size:10px;">52주高 대비</div>
                          <div style="font-weight:600;color:#475569;font-size:14px;"><% if (yhPct != null) { %><%= yhPct %>%<% } else { %>-<% } %></div>
                        </td>
                        <td valign="top" align="right" style="line-height:1.3;">
                          <div style="color:#94a3b8;font-size:10px;">추천 매수가</div>
                          <% if (sm.buyPrice) { %>
                            <div style="font-weight:700;color:#0f172a;font-size:14px;"><%= fmtNum(sm.buyPrice, 0) %></div>
                            <% if (sm.buyGapPercent !== null && sm.buyGapPercent !== undefined) { %>
                              <div style="color:#64748b;font-size:10px;font-weight:500;"><%= fmtPct(sm.buyGapPercent) %></div>
                            <% } %>
                          <% } else { %>
                            <div style="color:#cbd5e1;font-size:14px;">-</div>
                          <% } %>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              <% }) %>
            </td>
          </tr>

          <tr>
            <td style="padding:14px 28px 22px 28px;color:#94a3b8;font-size:11px;line-height:1.7;">
              본 메일은 정보 제공 목적이며 투자 권유가 아닙니다. 점수는 거래량·추세·수급·마름·수렴 등 10개 지표의 가중 합산이며, 시총 500억 미만은 제외됩니다. <strong>수급</strong>=외인+기관 5/10일 누적 순매수, <strong>마름</strong>=거래량 위축 + 가격 횡보, <strong>수렴</strong>=5/20/60일 이평선 수렴 (각 70점 이상 시 강조).
            </td>
          </tr>

          <tr>
            <td style="padding:16px 28px;background:#f8fafc;border-top:1px solid #e2e8f0;font-size:11px;color:#64748b;text-align:center;">
              <a href="<%= baseUrl %>/scan" style="color:#6366f1;text-decoration:none;font-weight:600;">전체 스캔 보기</a>
              <span style="margin:0 8px;color:#cbd5e1;">·</span>
              <a href="<%= unsubscribeUrl %>" style="color:#64748b;text-decoration:underline;">구독 취소</a>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
