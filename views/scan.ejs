<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>단타 스캔 — 거래대금/체결강도 상위</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  />

  <style>
    :root {
      --brand-gradient: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%);
      --soft-bg: #f3f5fb;
      --muted: #64748b;
    }
    body {
      margin: 0;
      background: var(--soft-bg);
      color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo",
        "Malgun Gothic", sans-serif;
    }
    .app-header {
      background: var(--brand-gradient);
      color: #fff;
      padding: 28px 0 56px;
      margin-bottom: -40px;
    }
    .app-header h1 { font-weight: 700; letter-spacing: -0.5px; margin: 0; font-size: 1.5rem; }
    .app-header .subtitle { opacity: 0.85; font-size: 0.9rem; margin-top: 4px; }
    .glass-card {
      border: 0;
      border-radius: 18px;
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
      background: #fff;
    }
    .score-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 28px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.85rem;
      color: #fff;
    }
    .score-strong { background: #16a34a; }
    .score-good   { background: #65a30d; }
    .score-mid    { background: #ca8a04; }
    .score-weak   { background: #94a3b8; }
    .source-badge {
      font-size: 0.7rem;
      padding: 2px 6px;
      border-radius: 8px;
      background: #eef2ff;
      color: #4338ca;
      margin-right: 4px;
    }
    .range-bound-badge {
      display: inline-block;
      padding: 1px 6px;
      border-radius: 6px;
      background: #e0e7ff;
      color: #4338ca;
      font-size: 0.68rem;
      font-weight: 600;
      margin-left: 4px;
      vertical-align: middle;
    }
    .num-cell { font-variant-numeric: tabular-nums; }
    .pos-rate { color: #dc2626; font-weight: 600; }
    .neg-rate { color: #2563eb; font-weight: 600; }
    .loading-overlay {
      position: fixed; inset: 0;
      background: rgba(15, 23, 42, 0.45);
      display: none;
      align-items: center; justify-content: center;
      z-index: 1080;
      color: #fff; font-size: 1rem;
    }
    .loading-overlay.show { display: flex; flex-direction: column; gap: 12px; }
    .spinner-border { width: 2.5rem; height: 2.5rem; }
    .verdict-cell { font-weight: 600; font-size: 0.85rem; }
    .table thead th { font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.4px; }
    .table tbody td { vertical-align: middle; font-size: 0.9rem; }

    .scan-help { font-size: 0.82rem; }
    .scan-help-mode {
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 10px 12px;
      background: #fafbff;
      height: 100%;
    }
    .scan-help-mode .mode-title {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 6px;
      font-size: 0.88rem;
    }
    .scan-help-mode .mode-title.short { color: #dc2626; }
    .scan-help-mode .mode-title.swing { color: #2563eb; }
    .scan-help-mode dl {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: 2px 10px;
      margin: 0;
    }
    .scan-help-mode dt { color: var(--muted); font-weight: 500; }
    .scan-help-mode dd { margin: 0; color: #334155; }
    .scan-help-tip {
      border-left: 3px solid #6366f1;
      background: #eef2ff;
      border-radius: 8px;
      padding: 8px 12px;
      color: #1e293b;
      line-height: 1.55;
    }
    .scan-help-tip .pool-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      padding: 2px 6px;
      border-radius: 6px;
      background: #fff;
      border: 1px solid #c7d2fe;
      color: #4338ca;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      margin-right: 4px;
    }
    .scan-help-detail {
      margin-top: 8px;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      background: #fff;
      font-size: 0.82rem;
    }
    .scan-help-detail > summary {
      list-style: none;
      cursor: pointer;
      padding: 8px 12px;
      font-weight: 600;
      color: #1e293b;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .scan-help-detail > summary::-webkit-details-marker { display: none; }
    .scan-help-detail > summary::before {
      content: "\25B8";
      color: #94a3b8;
      transition: transform 0.15s;
      display: inline-block;
    }
    .scan-help-detail[open] > summary::before { transform: rotate(90deg); }
    .scan-help-detail .detail-body {
      padding: 4px 14px 12px;
      color: #334155;
      line-height: 1.6;
    }
    .scan-help-detail .detail-step {
      margin-top: 6px;
    }
    .scan-help-detail .detail-step-title {
      font-weight: 700;
      color: #0f172a;
      margin-bottom: 2px;
    }
    .scan-help-detail table.weight-table {
      width: 100%;
      margin: 6px 0 4px;
      font-size: 0.78rem;
      border-collapse: collapse;
    }
    .scan-help-detail table.weight-table td {
      padding: 3px 8px;
      border-bottom: 1px dashed #e2e8f0;
    }
    .scan-help-detail table.weight-table tr:last-child td { border-bottom: 0; }
    .scan-help-detail table.weight-table td.weight-cell {
      width: 56px;
      text-align: right;
      font-variant-numeric: tabular-nums;
      font-weight: 600;
      color: #4338ca;
    }
    .scan-help-detail .verdict-line {
      margin-top: 6px;
      color: #475569;
      font-size: 0.78rem;
    }
    .scan-help-detail .verdict-line .v-pill {
      display: inline-block;
      padding: 1px 7px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
      margin: 0 3px;
    }
    .scan-help-detail .verdict-line .v-pill.s-strong { background: #dcfce7; color: #166534; }
    .scan-help-detail .verdict-line .v-pill.s-good   { background: #ecfccb; color: #4d7c0f; }
    .scan-help-detail .verdict-line .v-pill.s-mid    { background: #fef3c7; color: #92400e; }
    .scan-help-detail .verdict-line .v-pill.s-weak   { background: #f1f5f9; color: #475569; }

    .result-card {
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 12px;
      background: #fff;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .result-card:hover {
      border-color: #c7d2fe;
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.08);
    }
    .result-card .rank-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      height: 22px;
      padding: 0 6px;
      border-radius: 999px;
      background: #f1f5f9;
      color: #64748b;
      font-size: 0.72rem;
      font-weight: 600;
      margin-right: 6px;
    }
    .result-card .stock-name {
      font-weight: 700;
      font-size: 0.95rem;
      color: #1e293b;
    }
    .result-card .stock-code {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 2px;
    }
    .result-card .price-line {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin: 8px 0 6px;
    }
    .result-card .price-line .price {
      font-weight: 700;
      font-size: 1.05rem;
      font-variant-numeric: tabular-nums;
    }
    .result-card .badges-row {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-bottom: 6px;
    }
    .result-card .meta-row {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.5;
    }
    .result-card .meta-row strong { color: #334155; }
    .result-card .verdict-pill {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 999px;
      background: #eef2ff;
      color: #4338ca;
      font-size: 0.72rem;
      font-weight: 600;
    }
    .result-card .card-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px dashed #e2e8f0;
    }
  </style>
</head>
<body>
  <header class="app-header">
    <div class="container-fluid px-3 px-lg-5 d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h1><i class="bi bi-radar me-2"></i>단타 스캔</h1>
        <div class="subtitle">거래대금 상위 + 체결강도 상위 합집합 → 단타 점수로 정렬</div>
      </div>
      <div class="d-flex gap-2 align-self-center flex-wrap">
        <a href="/backtest" class="btn btn-light btn-sm">
          <i class="bi bi-clipboard-data me-1"></i>백테스팅
        </a>
        <a href="/subscribe" class="btn btn-light btn-sm">
          <i class="bi bi-envelope-paper me-1"></i>메일 구독
        </a>
        <a href="/" class="btn btn-light btn-sm">
          <i class="bi bi-arrow-left me-1"></i>딥다이브로
        </a>
      </div>
    </div>
  </header>

  <main class="container-fluid px-3 px-lg-5 pb-5">
    <div class="glass-card p-3 p-lg-4 mb-4">
      <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <span class="small text-secondary">현재 자동 모드:</span>
        <span class="badge <%= autoMode === 'short' ? 'bg-danger' : 'bg-primary' %>">
          <%= autoMode === 'short' ? '단타 (장중)' : '스윙 (휴장/장마감)' %>
        </span>
        <span class="small text-secondary">실효 모드:</span>
        <span class="badge bg-dark"><%= options.effectiveMode === 'short' ? '단타' : '스윙' %></span>
      </div>

      <form method="POST" action="/scan" id="scanForm" class="row g-2 align-items-end">
        <div class="col-12 col-md-3">
          <label class="form-label small text-secondary mb-1">모드</label>
          <select name="mode" class="form-select form-select-sm">
            <option value="auto"  <%= options.mode === 'auto'  ? 'selected' : '' %>>자동 (시간대 기반)</option>
            <option value="short" <%= options.mode === 'short' ? 'selected' : '' %>>단타 강제</option>
            <option value="swing" <%= options.mode === 'swing' ? 'selected' : '' %>>스윙 강제</option>
          </select>
        </div>
        <div class="col-6 col-md-2">
          <label class="form-label small text-secondary mb-1"
                 title="평가 대상 풀 크기. 클수록 더 많은 종목을 분석해 숨은 강한 후보를 발굴하지만 시간이 오래 걸립니다.">
            탐색 풀 크기 <i class="bi bi-info-circle text-muted" style="font-size: 0.7rem;"></i>
          </label>
          <input type="number" name="candidateLimit" class="form-control form-control-sm"
                 value="<%= options.candidateLimit %>" min="5" max="60"
                 title="평가 대상 풀 크기. 클수록 더 많은 종목을 분석해 숨은 강한 후보를 발굴하지만 시간이 오래 걸립니다." />
        </div>
        <div class="col-6 col-md-3 d-flex align-items-center pt-3">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="includeMinute" name="includeMinute"
                   <%= options.includeMinute ? "checked" : "" %> />
            <label class="form-check-label small" for="includeMinute">분봉 (단타 전용)</label>
          </div>
        </div>
        <div class="col-12 col-md-4 text-md-end">
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-search me-1"></i>스캔 시작
          </button>
        </div>
      </form>
      <div class="scan-help mt-3">
        <div class="row g-2">
          <div class="col-md-6">
            <div class="scan-help-mode">
              <div class="mode-title short"><i class="bi bi-lightning-charge me-1"></i>단타</div>
              <dl>
                <dt>대상</dt><dd>거래대금 + 체결강도 상위</dd>
                <dt>분석</dt><dd>1단계 후보 → 2단계 가중 점수 (5요소)</dd>
                <dt>소요</dt><dd>약 1~2분</dd>
              </dl>
            </div>
          </div>
          <div class="col-md-6">
            <div class="scan-help-mode">
              <div class="mode-title swing"><i class="bi bi-graph-up me-1"></i>스윙</div>
              <dl>
                <dt>대상</dt><dd>거래대금 + 거래증가율 상위</dd>
                <dt>분석</dt><dd>1단계 후보 → 2단계 가중 점수 (10요소)</dd>
                <dt>소요</dt><dd>약 2~3분</dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="scan-help-tip mt-2">
          <i class="bi bi-info-circle me-1"></i>
          <strong>탐색 풀 크기</strong>는 결과 개수가 아니라 <em>평가 대상 풀 크기</em>입니다.
          <span class="pool-badge">25</span>안전한 후보 위주
          <span class="mx-2 text-muted">→</span>
          <span class="pool-badge">60</span>숨은 강자까지 발굴 (시간 ↑)
        </div>

        <details class="scan-help-detail">
          <summary>단타 점수 산출 방식 자세히 보기</summary>
          <div class="detail-body">
            <div class="detail-step">
              <div class="detail-step-title">1단계 — 후보 선정</div>
              KIS의 <strong>거래대금 순위</strong>와 <strong>체결강도 순위</strong> 두 랭킹을
              가져와 <em>합집합</em>으로 후보 풀을 만듭니다. 풀 크기는 위의 "탐색 풀 크기" 입력값.
            </div>

            <div class="detail-step">
              <div class="detail-step-title">2단계 — 종목별 점수 (가중 합산)</div>
              후보 각각에 대해 아래 5개 지표를 0~100 점으로 매기고 가중치로 합산해 총점을 계산합니다.
              <table class="weight-table">
                <tr>
                  <td class="weight-cell">30%</td>
                  <td><strong>체결강도</strong> — KIS <code>cttr</code> 값 (≥150 → 95점, ≥100 → 70점)</td>
                </tr>
                <tr>
                  <td class="weight-cell">20%</td>
                  <td><strong>매수/매도 비율</strong> — 매수체결량 ÷ 매도체결량 (≥1.5 → 90점)</td>
                </tr>
                <tr>
                  <td class="weight-cell">20%</td>
                  <td><strong>분봉 모멘텀</strong> — 최근 N분 평균이 직전 N분 대비 얼마나 올랐는지 + 회귀 기울기</td>
                </tr>
                <tr>
                  <td class="weight-cell">15%</td>
                  <td><strong>장중 위치</strong> — 오늘 고저 범위에서 현재가 위치 (하단일수록 가점)</td>
                </tr>
                <tr>
                  <td class="weight-cell">15%</td>
                  <td><strong>등락률 밴드</strong> — 5~10% 구간이 최고점, 너무 튀거나 빠지면 페널티</td>
                </tr>
              </table>
              <div class="text-muted" style="font-size: 0.74rem;">
                ※ 체결강도는 1단계(후보 선정)와 2단계(점수)에 모두 반영되므로 영향력이 가장 큽니다.
              </div>
            </div>

            <div class="verdict-line">
              <strong>판정:</strong>
              <span class="v-pill s-strong">≥75 단타 유망</span>
              <span class="v-pill s-good">≥60 관심</span>
              <span class="v-pill s-mid">≥45 중립</span>
              <span class="v-pill s-weak">&lt;45 약함</span>
            </div>
          </div>
        </details>

        <details class="scan-help-detail">
          <summary>스윙 점수 산출 방식 자세히 보기</summary>
          <div class="detail-body">
            <div class="detail-step">
              <div class="detail-step-title">1단계 — 후보 선정</div>
              KIS의 <strong>거래대금 순위</strong>와 <strong>거래증가율 순위</strong> 두 랭킹을
              가져와 <em>합집합</em>으로 후보 풀을 만듭니다. 풀 크기는 위의 "탐색 풀 크기" 입력값.
            </div>

            <div class="detail-step">
              <div class="detail-step-title">2단계 — 종목별 점수 (가중 합산)</div>
              후보 각각에 대해 <strong>일·주·월·연봉 시리즈</strong>를
              조회한 뒤 아래 10개 지표를 0~100 점으로 매기고 가중치로 합산해 총점(100점 만점)을 계산합니다.
              결과는 총점 내림차순으로 정렬됩니다.
              <table class="weight-table">
                <tr><td class="weight-cell">18</td><td><strong>거래량</strong> — 오늘/주/월/연 거래량 vs 평균, 양음봉·종가 위치 가중</td></tr>
                <tr><td class="weight-cell">12</td><td><strong>가격 위치</strong> — 일/주/월/연 고저 범위에서 현재가 위치 (하단~중하단 선호)</td></tr>
                <tr><td class="weight-cell">12</td><td><strong>매집 (dryUp)</strong> — 거래량이 마르면서 박스권 형성 → 매집 가능성</td></tr>
                <tr><td class="weight-cell">12</td><td><strong>추세 추종 (trendFollow)</strong> — 20일·60일선 위, 정배열, 신고가 갱신 여부 (강세 종목 잡기)</td></tr>
                <tr><td class="weight-cell">10</td><td><strong>매물대 (resistance)</strong> — 최근 120일 거래량 히스토그램, 현재가 위쪽 매물 비율</td></tr>
                <tr><td class="weight-cell">10</td><td><strong>스퀴즈 (squeeze)</strong> — 변동성 압축 정도 (분출 직전 패턴)</td></tr>
                <tr><td class="weight-cell">8</td><td><strong>추세 (trend)</strong> — 현재가와 5/20/60일 + 4/12주 SMA 관계</td></tr>
                <tr><td class="weight-cell">8</td><td><strong>변동성</strong> — 20일 변동폭 (낮을수록 +, 반비례)</td></tr>
                <tr><td class="weight-cell">5</td><td><strong>RSI</strong> — 14기간 RSI</td></tr>
                <tr><td class="weight-cell">5</td><td><strong>MACD</strong> — 12/26/9 MACD</td></tr>
              </table>
              <div class="text-muted" style="font-size: 0.74rem;">
                ※ 가중치 합 100 (정규화 불필요). 백테스팅과 정확히 같은 척도.
                수급(flow) 점수는 historical 데이터 부재로 모델에서 제외.
                <br>Phase 2 — 추세 추종(trendFollow) 컴포넌트 추가로 강세 종목도 점수 받도록 보완.
                <br>Phase 3 — 단기 폭등 페널티 (5일 +10/15/20/25% 시 -5/-10/-15/-20점) 으로 단기 천장 매수 함정 거름.
                <br>Phase 5 — 추세 약한 종목 (<strong>60일 수익률 10% 미만</strong> OR <strong>오늘 종가 < 60일 신고가의 95%</strong>) 에 <strong>📊 박스권</strong> 라벨 표시. 추세 추종 모델은 박스권/V자 회복 도중에 천장 매수 함정에 빠지는 한계가 백테스트로 확인됨. 라벨 종목은 추세 매매 관점으로는 비추 — 박스권 매매 관점으로 별도 판단 권장.
              </div>
            </div>
          </div>
        </details>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger small"><pre class="mb-0" style="white-space: pre-wrap;"><%= error %></pre></div>
    <% } %>

    <% if (scanResult) { %>
      <div class="glass-card p-3 p-lg-4">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
          <div>
            <div class="fw-bold">
              결과 <%= scanResult.results.length %>건
              <span class="badge <%= scanResult.mode === 'swing' ? 'bg-primary' : 'bg-danger' %> ms-2">
                <%= scanResult.mode === 'swing' ? '스윙' : '단타' %>
              </span>
            </div>
            <div class="small text-secondary">
              스캔 시각 <%= new Date(scanResult.scannedAt).toLocaleString("ko-KR") %>
              <% if (scanResult.fromCache) { %><span class="badge bg-info ms-1">캐시</span><% } %>
              <% if (scanResult.includeMinute && scanResult.mode === 'short') { %>
                <span class="badge bg-secondary ms-1">분봉 포함</span>
              <% } %>
            </div>
          </div>
        </div>

        <% if (scanResult.mode === 'swing') { %>
          <!-- 모바일/태블릿 카드 -->
          <div class="d-lg-none d-flex flex-column gap-2">
            <% scanResult.results.forEach(function(r, i) { %>
              <% var hasErr = !!r.error;
                 var sc = !hasErr ? r.scoreModel.totalScore : 0;
                 var cls = sc >= 75 ? 'score-strong' : sc >= 60 ? 'score-good' : sc >= 45 ? 'score-mid' : 'score-weak'; %>
              <div class="result-card">
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <div class="flex-grow-1" style="min-width: 0;">
                    <div>
                      <span class="rank-num">#<%= i + 1 %></span>
                      <span class="stock-name"><%= r.name || r.shortCode %></span>
                      <% if (r.stockType === 'weakTrend') { %>
                        <span class="range-bound-badge" title="60일 박스권 또는 V자 회복 도중 (수익률 낮거나 신고가 미달) — 추세 추종 모델 신뢰도 낮음. 박스권 매매 관점으로 보세요.">📊 박스권</span>
                      <% } %>
                    </div>
                    <div class="stock-code"><%= r.shortCode %><% if (r.market) { %> · <%= r.market %><% } %></div>
                  </div>
                  <% if (!hasErr) { %>
                    <span class="score-pill <%= cls %>"><%= sc %></span>
                  <% } %>
                </div>
                <% if (hasErr) { %>
                  <div class="text-danger small mt-2">오류: <%= r.error %></div>
                <% } else { %>
                  <div class="price-line">
                    <span class="price"><%= (r.currentPrice || 0).toLocaleString() %>원</span>
                    <span class="num-cell <%= r.changeRate >= 0 ? 'pos-rate' : 'neg-rate' %>">
                      <%= r.changeRate >= 0 ? "+" : "" %><%= r.changeRate.toFixed(2) %>%
                    </span>
                    <span class="ms-auto verdict-pill"><%= r.scoreModel.verdict %></span>
                  </div>
                  <div class="badges-row">
                    <% (r.sources || []).forEach(function(s) { %>
                      <span class="source-badge"><%= s %></span>
                    <% }) %>
                  </div>
                  <div class="meta-row">
                    거래 <strong><%= r.scoreModel.components.volume %></strong> ·
                    위치 <strong><%= r.scoreModel.components.position %></strong> ·
                    추세 <strong><%= r.scoreModel.components.trend %></strong> ·
                    매물 <strong><%= r.scoreModel.components.resistance %></strong>
                  </div>
                  <div class="card-foot">
                    <div class="meta-row">
                      <% if (r.scoreModel.buyPrice) { %>
                        <i class="bi bi-cash-coin me-1"></i>매수 <strong><%= r.scoreModel.buyPrice.toLocaleString() %>원</strong>
                        <span class="text-muted">(<%= r.scoreModel.buyTier %>, -<%= r.scoreModel.buyGapPercent %>%)</span>
                      <% } else { %>
                        <span class="text-muted">매수가 산출 불가</span>
                      <% } %>
                    </div>
                    <div class="d-flex gap-1">
                      <form method="POST" action="/search" class="m-0">
                        <input type="hidden" name="stockQuery" value="<%= r.shortCode %>" />
                        <input type="hidden" name="from" value="scan" />
                        <input type="hidden" name="scanMode" value="<%= options.effectiveMode %>" />
                        <input type="hidden" name="scanLimit" value="<%= options.candidateLimit %>" />
                        <input type="hidden" name="scanIncludeMinute" value="<%= options.includeMinute ? '1' : '0' %>" />
                        <button type="submit" class="btn btn-outline-primary btn-sm" title="딥다이브">
                          <i class="bi bi-graph-up"></i>
                        </button>
                      </form>
                      <form method="POST" action="/backtest" class="m-0">
                        <input type="hidden" name="query" value="<%= r.shortCode %>" />
                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="백테스트">
                          <i class="bi bi-clipboard-data"></i>
                        </button>
                      </form>
                    </div>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <!-- 단타 모바일/태블릿 카드 -->
          <div class="d-lg-none d-flex flex-column gap-2">
            <% scanResult.results.forEach(function(r, i) { %>
              <% var hasErr = !!r.error;
                 var sc = !hasErr ? r.score.totalScore : 0;
                 var cls = sc >= 75 ? 'score-strong' : sc >= 60 ? 'score-good' : sc >= 45 ? 'score-mid' : 'score-weak'; %>
              <div class="result-card">
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <div class="flex-grow-1" style="min-width: 0;">
                    <div>
                      <span class="rank-num">#<%= i + 1 %></span>
                      <span class="stock-name"><%= r.name || r.shortCode %></span>
                      <% if (r.stockType === 'weakTrend') { %>
                        <span class="range-bound-badge" title="60일 박스권 또는 V자 회복 도중 (수익률 낮거나 신고가 미달) — 추세 추종 모델 신뢰도 낮음. 박스권 매매 관점으로 보세요.">📊 박스권</span>
                      <% } %>
                    </div>
                    <div class="stock-code"><%= r.shortCode %><% if (r.market) { %> · <%= r.market %><% } %></div>
                  </div>
                  <% if (!hasErr) { %>
                    <span class="score-pill <%= cls %>"><%= sc %></span>
                  <% } %>
                </div>
                <% if (hasErr) { %>
                  <div class="text-danger small mt-2">오류: <%= r.error %></div>
                <% } else { %>
                  <div class="price-line">
                    <span class="price"><%= (r.currentPrice || 0).toLocaleString() %>원</span>
                    <span class="num-cell <%= r.changeRate >= 0 ? 'pos-rate' : 'neg-rate' %>">
                      <%= r.changeRate >= 0 ? "+" : "" %><%= r.changeRate.toFixed(2) %>%
                    </span>
                    <span class="ms-auto verdict-pill"><%= r.score.verdict %></span>
                  </div>
                  <div class="badges-row">
                    <% (r.sources || []).forEach(function(s) { %>
                      <span class="source-badge"><%= s %></span>
                    <% }) %>
                  </div>
                  <div class="meta-row">
                    체결강도 <strong><%= r.chegyeolStrength ? r.chegyeolStrength.toFixed(1) : "-" %></strong> ·
                    매수/매도 <strong><%= r.buySellRatio !== null && r.buySellRatio !== undefined ? r.buySellRatio.toFixed(2) : "-" %></strong>
                  </div>
                  <div class="meta-row">
                    체강 <strong><%= r.score.components.cheg.score %></strong> ·
                    모멘텀 <strong><%= r.score.components.momentum.score %></strong> ·
                    일중 <strong><%= r.score.components.intraday.score %></strong>
                  </div>
                  <div class="card-foot">
                    <div></div>
                    <div class="d-flex gap-1">
                      <form method="POST" action="/search" class="m-0">
                        <input type="hidden" name="stockQuery" value="<%= r.shortCode %>" />
                        <input type="hidden" name="from" value="scan" />
                        <input type="hidden" name="scanMode" value="<%= options.effectiveMode %>" />
                        <input type="hidden" name="scanLimit" value="<%= options.candidateLimit %>" />
                        <input type="hidden" name="scanIncludeMinute" value="<%= options.includeMinute ? '1' : '0' %>" />
                        <button type="submit" class="btn btn-outline-primary btn-sm" title="딥다이브">
                          <i class="bi bi-graph-up"></i>
                        </button>
                      </form>
                      <form method="POST" action="/backtest" class="m-0">
                        <input type="hidden" name="query" value="<%= r.shortCode %>" />
                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="백테스트">
                          <i class="bi bi-clipboard-data"></i>
                        </button>
                      </form>
                    </div>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>

        <!-- 데스크탑 테이블 -->
        <div class="table-responsive d-none d-lg-block">
          <% if (scanResult.mode === 'swing') { %>
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>종목</th>
                  <th class="text-end">현재가</th>
                  <th class="text-end">등락</th>
                  <th>출처</th>
                  <th class="text-center">총점</th>
                  <th>판정</th>
                  <th>세부 (거래/위치/추세/매물대)</th>
                  <th class="text-end">추천 매수가</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% scanResult.results.forEach(function(r, i) { %>
                  <tr>
                    <td class="text-secondary small"><%= i + 1 %></td>
                    <td>
                      <div class="fw-semibold">
                        <%= r.name || r.shortCode %>
                        <% if (r.stockType === 'weakTrend') { %>
                          <span class="range-bound-badge" title="60일 박스권 또는 V자 회복 도중. 추세 추종 모델 신뢰도 낮음 — 박스권 매매 관점으로 보세요.">📊 박스권</span>
                        <% } %>
                      </div>
                      <div class="small text-secondary"><%= r.shortCode %><% if (r.market) { %> · <%= r.market %><% } %></div>
                    </td>
                    <% if (r.error) { %>
                      <td colspan="8" class="text-danger small">오류: <%= r.error %></td>
                    <% } else { %>
                      <td class="text-end num-cell"><%= (r.currentPrice || 0).toLocaleString() %></td>
                      <td class="text-end num-cell <%= r.changeRate >= 0 ? 'pos-rate' : 'neg-rate' %>">
                        <%= r.changeRate >= 0 ? "+" : "" %><%= r.changeRate.toFixed(2) %>%
                      </td>
                      <td>
                        <% (r.sources || []).forEach(function(s) { %>
                          <span class="source-badge"><%= s %></span>
                        <% }) %>
                      </td>
                      <td class="text-center">
                        <% var sc = r.scoreModel.totalScore;
                           var cls = sc >= 75 ? 'score-strong' : sc >= 60 ? 'score-good' : sc >= 45 ? 'score-mid' : 'score-weak'; %>
                        <span class="score-pill <%= cls %>"><%= sc %></span>
                      </td>
                      <td class="verdict-cell"><%= r.scoreModel.verdict %></td>
                      <td class="small text-secondary">
                        <%= r.scoreModel.components.volume %> ·
                        <%= r.scoreModel.components.position %> ·
                        <%= r.scoreModel.components.trend %> ·
                        <%= r.scoreModel.components.resistance %>
                      </td>
                      <td class="text-end num-cell">
                        <% if (r.scoreModel.buyPrice) { %>
                          <%= r.scoreModel.buyPrice.toLocaleString() %>
                          <span class="small text-secondary">(<%= r.scoreModel.buyTier %>, -<%= r.scoreModel.buyGapPercent %>%)</span>
                        <% } else { %>-<% } %>
                      </td>
                      <td>
                        <div class="d-flex gap-1">
                          <form method="POST" action="/search" class="m-0">
                            <input type="hidden" name="stockQuery" value="<%= r.shortCode %>" />
                            <input type="hidden" name="from" value="scan" />
                            <input type="hidden" name="scanMode" value="<%= options.effectiveMode %>" />
                            <input type="hidden" name="scanLimit" value="<%= options.candidateLimit %>" />
                            <input type="hidden" name="scanIncludeMinute" value="<%= options.includeMinute ? '1' : '0' %>" />
                            <button type="submit" class="btn btn-outline-primary btn-sm" title="딥다이브">
                              <i class="bi bi-graph-up"></i>
                            </button>
                          </form>
                          <form method="POST" action="/backtest" class="m-0">
                            <input type="hidden" name="query" value="<%= r.shortCode %>" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm" title="백테스트">
                              <i class="bi bi-clipboard-data"></i>
                            </button>
                          </form>
                        </div>
                      </td>
                    <% } %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>종목</th>
                  <th class="text-end">현재가</th>
                  <th class="text-end">등락</th>
                  <th class="text-end">체결강도</th>
                  <th class="text-end">매수/매도</th>
                  <th>출처</th>
                  <th class="text-center">점수</th>
                  <th>판정</th>
                  <th>주요 신호</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% scanResult.results.forEach(function(r, i) { %>
                  <tr>
                    <td class="text-secondary small"><%= i + 1 %></td>
                    <td>
                      <div class="fw-semibold"><%= r.name || r.shortCode %></div>
                      <div class="small text-secondary"><%= r.shortCode %><% if (r.market) { %> · <%= r.market %><% } %></div>
                    </td>
                    <% if (r.error) { %>
                      <td colspan="9" class="text-danger small">오류: <%= r.error %></td>
                    <% } else { %>
                      <td class="text-end num-cell"><%= (r.currentPrice || 0).toLocaleString() %></td>
                      <td class="text-end num-cell <%= r.changeRate >= 0 ? 'pos-rate' : 'neg-rate' %>">
                        <%= r.changeRate >= 0 ? "+" : "" %><%= r.changeRate.toFixed(2) %>%
                      </td>
                      <td class="text-end num-cell"><%= r.chegyeolStrength ? r.chegyeolStrength.toFixed(1) : "-" %></td>
                      <td class="text-end num-cell">
                        <%= r.buySellRatio !== null && r.buySellRatio !== undefined ? r.buySellRatio.toFixed(2) : "-" %>
                      </td>
                      <td>
                        <% (r.sources || []).forEach(function(s) { %>
                          <span class="source-badge"><%= s %></span>
                        <% }) %>
                      </td>
                      <td class="text-center">
                        <% var sc = r.score.totalScore;
                           var cls = sc >= 75 ? 'score-strong' : sc >= 60 ? 'score-good' : sc >= 45 ? 'score-mid' : 'score-weak'; %>
                        <span class="score-pill <%= cls %>"><%= sc %></span>
                      </td>
                      <td class="verdict-cell"><%= r.score.verdict %></td>
                      <td class="small text-secondary">
                        체강 <%= r.score.components.cheg.score %> ·
                        모멘텀 <%= r.score.components.momentum.score %> ·
                        일중 <%= r.score.components.intraday.score %>
                      </td>
                      <td>
                        <div class="d-flex gap-1">
                          <form method="POST" action="/search" class="m-0">
                            <input type="hidden" name="stockQuery" value="<%= r.shortCode %>" />
                            <input type="hidden" name="from" value="scan" />
                            <input type="hidden" name="scanMode" value="<%= options.effectiveMode %>" />
                            <input type="hidden" name="scanLimit" value="<%= options.candidateLimit %>" />
                            <input type="hidden" name="scanIncludeMinute" value="<%= options.includeMinute ? '1' : '0' %>" />
                            <button type="submit" class="btn btn-outline-primary btn-sm" title="딥다이브">
                              <i class="bi bi-graph-up"></i>
                            </button>
                          </form>
                          <form method="POST" action="/backtest" class="m-0">
                            <input type="hidden" name="query" value="<%= r.shortCode %>" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm" title="백테스트">
                              <i class="bi bi-clipboard-data"></i>
                            </button>
                          </form>
                        </div>
                      </td>
                    <% } %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    <% } else if (!error) { %>
      <div class="text-center text-secondary py-5">
        <i class="bi bi-radar" style="font-size: 2.5rem;"></i>
        <div class="mt-2">위 폼에서 "스캔 시작"을 누르면 약 1~2분 동안 KIS API를 조회합니다.</div>
      </div>
    <% } %>
  </main>

  <div class="loading-overlay" id="loadingOverlay">
    <div class="spinner-border" role="status"></div>
    <div>KIS API 조회 중... 약 1~2분 걸립니다</div>
  </div>

  <script>
    (function() {
      var form = document.getElementById("scanForm");
      var modeSel = form?.querySelector('select[name="mode"]');
      var minuteCb = document.getElementById("includeMinute");
      var minuteLabel = minuteCb?.parentElement;
      var autoMode = "<%= autoMode %>";

      function effective() {
        var v = modeSel?.value || "auto";
        return v === "auto" ? autoMode : v;
      }
      function syncMinute() {
        if (!minuteCb) return;
        var disabled = effective() === "swing";
        minuteCb.disabled = disabled;
        if (minuteLabel) minuteLabel.style.opacity = disabled ? "0.45" : "1";
      }
      modeSel?.addEventListener("change", syncMinute);
      syncMinute();

      form?.addEventListener("submit", function() {
        document.getElementById("loadingOverlay")?.classList.add("show");
      });
    })();
  </script>
</body>
</html>
