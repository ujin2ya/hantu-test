<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>주식앱 스타일 차트 + 점수화</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root {
      --brand-gradient: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
      --soft-bg: #f3f5fb;
      --muted: #64748b;
    }

    html, body { height: 100%; }

    body {
      margin: 0;
      background: var(--soft-bg);
      color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo",
        "Malgun Gothic", sans-serif;
    }

    .app-header {
      background: var(--brand-gradient);
      color: #fff;
      padding: 28px 0 56px;
      margin-bottom: -40px;
    }

    .app-header h1 {
      font-weight: 700;
      letter-spacing: -0.5px;
      margin: 0;
      font-size: 1.75rem;
    }

    .app-header .subtitle {
      opacity: 0.85;
      font-size: 0.95rem;
      margin-top: 4px;
    }

    .glass-card {
      border: 0;
      border-radius: 18px;
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
      background: #fff;
    }

    .metric-card {
      border: 0;
      border-radius: 16px;
      background: #fff;
      box-shadow: 0 4px 14px rgba(15, 23, 42, 0.06);
      height: 100%;
    }

    .metric-card .metric-label {
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.2px;
    }

    .metric-card .metric-value {
      font-size: 1.6rem;
      font-weight: 700;
      word-break: break-word;
    }

    .metric-card .metric-sub {
      font-size: 0.85rem;
      color: var(--muted);
      margin-top: 4px;
    }

    .metric-card.metric-accent {
      background: var(--brand-gradient);
      color: #fff;
    }

    .metric-card.metric-accent .metric-label,
    .metric-card.metric-accent .metric-sub {
      color: rgba(255, 255, 255, 0.85);
    }

    .section-title {
      font-size: 1.05rem;
      font-weight: 700;
      margin: 0;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-title .bi {
      color: #2563eb;
    }

    .weight-item {
      background: #f8fafc;
      border-radius: 12px;
      padding: 12px 12px 10px;
    }

    .weight-item label {
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .chart-wrap {
      position: relative;
      width: 100%;
      height: 340px;
    }

    .pill {
      background: #f8fafc;
      border-radius: 12px;
      padding: 10px 12px;
    }

    .pill strong {
      display: block;
      font-size: 0.72rem;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 600;
    }

    .pill span {
      font-size: 1rem;
      font-weight: 700;
    }

    .position-card {
      background: #f8fafc;
      border-radius: 12px;
      padding: 14px;
      height: 100%;
    }

    .position-card .title {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .position-card .percent {
      font-size: 1.4rem;
      font-weight: 700;
      margin: 4px 0 2px;
    }

    .position-card .desc {
      font-size: 0.85rem;
      color: #475569;
    }

    .meta-item {
      background: #f8fafc;
      border-radius: 12px;
      padding: 12px 14px;
      height: 100%;
    }

    .meta-item strong {
      display: block;
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 600;
    }

    .meta-item .value {
      font-size: 1rem;
      font-weight: 600;
      word-break: break-word;
    }

    .explain-box {
      background: #f8fafc;
      border-radius: 12px;
      padding: 18px;
      height: 100%;
    }

    .explain-box h3 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .zone-list {
      padding-left: 18px;
      margin: 0;
      line-height: 1.7;
    }

    .muted-text {
      color: var(--muted);
      font-size: 0.82rem;
      line-height: 1.55;
    }

    .ai-card {
      background: linear-gradient(135deg, #fafbff 0%, #f3f5fb 100%);
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      padding: 16px 18px;
      font-size: 0.92rem;
      line-height: 1.65;
      color: #1f2937;
    }
    .ai-card p { margin: 0 0 10px; }
    .ai-card p:last-child { margin-bottom: 0; }
    .ai-section-h {
      font-weight: 700;
      font-size: 0.92rem;
      margin: 14px 0 6px;
      color: #1e293b;
      border-left: 3px solid #6366f1;
      padding-left: 8px;
    }
    .ai-section-h:first-child { margin-top: 0; }
    .ai-mode-badge {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 999px;
      margin-bottom: 12px;
      color: #fff;
    }
    .ai-mode-badge.short { background: #dc2626; }
    .ai-mode-badge.swing { background: #2563eb; }
    .ai-sources-list {
      list-style: none;
      padding-left: 0;
      margin: 0;
      font-size: 0.78rem;
      line-height: 1.55;
    }
    .ai-sources-list li { margin-bottom: 2px; }
    .ai-sources-list a {
      color: #4f46e5;
      text-decoration: none;
      word-break: break-all;
    }
    .ai-sources-list a:hover { text-decoration: underline; }
    .material-link-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      border-radius: 999px;
      background: #f1f5f9;
      color: #334155;
      font-size: 0.78rem;
      font-weight: 500;
      text-decoration: none;
      border: 1px solid #e2e8f0;
      transition: background 0.15s;
    }
    .material-link-chip:hover {
      background: #e2e8f0;
      color: #1e293b;
      text-decoration: none;
    }

    .btn-search {
      background: var(--brand-gradient);
      color: #fff;
      border: 0;
      border-radius: 10px;
      padding: 8px 16px;
      font-size: 0.95rem;
      font-weight: 600;
      white-space: nowrap;
      transition: transform 0.08s ease, box-shadow 0.2s ease;
    }

    .btn-search:hover {
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 10px 20px rgba(37, 99, 235, 0.28);
    }

    .btn-search:focus { color: #fff; }

    .form-control, .form-select {
      border-radius: 10px;
    }

    .form-control:focus, .form-select:focus {
      border-color: #7c3aed;
      box-shadow: 0 0 0 0.2rem rgba(124, 58, 237, 0.15);
    }

    .verdict-badge {
      display: inline-block;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 0.78rem;
      font-weight: 600;
      margin-top: 6px;
    }

    .recommend-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 0.82rem;
      font-weight: 500;
    }

    .recommend-badge.recommend-aggressive { background: #dcfce7; color: #166534; }
    .recommend-badge.recommend-neutral { background: #dbeafe; color: #1e40af; }
    .recommend-badge.recommend-conservative { background: #fef3c7; color: #92400e; }

    .buy-tier {
      background: #f8fafc;
      border-radius: 14px;
      padding: 16px;
      height: 100%;
      border: 2px solid transparent;
      transition: border-color 0.15s ease, background 0.15s ease;
    }

    .buy-tier.active {
      border-color: #2563eb;
      background: #eff6ff;
      box-shadow: 0 4px 14px rgba(37, 99, 235, 0.12);
    }

    .buy-tier .tier-label {
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 600;
      letter-spacing: 0.2px;
    }

    .buy-tier.active .tier-label {
      color: #1e40af;
    }

    .buy-tier .tier-price {
      font-size: 1.55rem;
      font-weight: 700;
      margin: 4px 0 2px;
      word-break: break-word;
    }

    .buy-tier .tier-gap {
      font-size: 0.82rem;
      color: #2563eb;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .buy-tier .tier-desc {
      font-size: 0.82rem;
      color: #475569;
      line-height: 1.45;
    }

    .buy-tier .tier-band {
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 500;
      margin-left: 2px;
    }

    .buy-tier.active .tier-band {
      color: #3b82f6;
    }

    .buy-tabs {
      gap: 6px;
      flex-wrap: wrap;
    }

    .buy-tabs .nav-link {
      color: var(--muted);
      font-weight: 600;
      font-size: 0.85rem;
      border-radius: 10px;
      padding: 6px 14px;
      background: #f1f5f9;
      border: 0;
    }

    .buy-tabs .nav-link.active {
      background: var(--brand-gradient);
      color: #fff;
    }

    .buy-tabs .nav-link:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    #loading-overlay {
      position: fixed;
      inset: 0;
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
      background: rgba(15, 23, 42, 0.35);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      color: #fff;
    }

    #loading-overlay.active { display: flex; }

    #loading-overlay .spinner-border {
      width: 3.2rem;
      height: 3.2rem;
      border-width: 0.35rem;
    }

    #loading-overlay .loading-text {
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 0.3px;
    }

    @media (max-width: 991.98px) {
      .app-header { padding: 22px 0 48px; margin-bottom: -34px; }
      .app-header h1 { font-size: 1.3rem; }
      .app-header .subtitle { font-size: 0.85rem; }
      .chart-wrap { height: 280px; }
    }

    @media (max-width: 575.98px) {
      .app-header { padding: 18px 0 42px; margin-bottom: -30px; }
      .app-header h1 { font-size: 1.15rem; letter-spacing: -0.3px; }
      .app-header .subtitle { font-size: 0.78rem; }

      .section-title { font-size: 0.95rem; }

      .metric-card { border-radius: 14px; }
      .metric-card .metric-label { font-size: 0.72rem; }
      .metric-card .metric-value { font-size: 1.15rem; }
      .metric-card .metric-sub { font-size: 0.78rem; }

      .position-card { padding: 12px; }
      .position-card .title { font-size: 0.72rem; }
      .position-card .percent { font-size: 1.15rem; }
      .position-card .desc { font-size: 0.78rem; }

      .meta-item { padding: 10px 12px; }
      .meta-item strong { font-size: 0.7rem; }
      .meta-item .value { font-size: 0.9rem; }

      .pill { padding: 8px 10px; }
      .pill strong { font-size: 0.66rem; }
      .pill span { font-size: 0.9rem; }

      .weight-item { padding: 8px 10px; }
      .weight-item label { font-size: 0.72rem; margin-bottom: 4px; }
      /* iOS 사파리는 포커스 시 16px 미만 입력에 자동 줌을 건다 — 줌 방지 */
      .weight-item .form-control-sm { font-size: 16px; padding: 6px 8px; }

      .explain-box { padding: 14px; }
      .explain-box h3 { font-size: 0.95rem; }

      .verdict-badge { font-size: 0.72rem; padding: 3px 10px; }

      .recommend-badge { font-size: 0.72rem; padding: 4px 10px; }

      .buy-tier { padding: 12px; }
      .buy-tier .tier-label { font-size: 0.75rem; }
      .buy-tier .tier-price { font-size: 1.25rem; }
      .buy-tier .tier-gap { font-size: 0.78rem; }
      .buy-tier .tier-desc { font-size: 0.78rem; }
      .buy-tier .tier-band { font-size: 0.66rem; display: block; margin-left: 0; margin-top: 2px; }

      .buy-tabs .nav-link { font-size: 0.78rem; padding: 5px 10px; }

      .chart-wrap { height: 240px; }

      .btn-search { padding: 10px 16px; font-size: 1rem; }
    }
  </style>
</head>
<body>
  <%
    const safeQuery = query || "";
    const safeError = error || null;
    const safeSelected = selected || null;
    const safeCurrentData = currentData || null;
    const safeCandidates = Array.isArray(candidates) ? candidates : [];
    const safeDailySeries = dailySeries || null;
    const safeWeeklySeries = weeklySeries || null;
    const safeMonthlySeries = monthlySeries || null;
    const safeYearlySeries = yearlySeries || null;
    const safeSummary = summary || null;
    const safeScoreModel = scoreModel || null;
    const safeWeights = weights || {
      volume: 30,
      position: 20,
      trend: 10,
      rsi: 5,
      macd: 5,
      resistance: 20,
      volatility: 10,
    };

    function fmtNumber(value) {
      return Number(value || 0).toLocaleString();
    }
  %>

  <header class="app-header">
    <div class="container-fluid px-3 px-lg-5 d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h1><i class="bi bi-graph-up-arrow me-2"></i>주식앱 스타일 차트 + 점수화</h1>
        <div class="subtitle">한국투자증권 Open API · 일/주/월/연봉 + 7요소 가중치 점수</div>
      </div>
      <a href="/scan" class="btn btn-light btn-sm align-self-center">
        <i class="bi bi-radar me-1"></i>단타 스캔
      </a>
    </div>
  </header>

  <main class="container-fluid px-3 px-lg-5 pb-5">
    <div class="glass-card p-3 p-lg-4 mb-4">
      <form id="search-form" method="post" action="/search">
        <div class="row g-2 align-items-stretch mb-3">
          <div class="col-12 col-lg">
            <div class="input-group input-group-lg">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-secondary"></i>
              </span>
              <input
                type="text"
                name="stockQuery"
                class="form-control border-start-0"
                placeholder="종목명 또는 종목코드 (예: 삼성전자, 005930)"
                value="<%= safeQuery %>"
                autocomplete="off"
                required
              />
            </div>
          </div>
          <div class="col-12 col-lg-auto">
            <button type="submit" class="btn btn-search w-100 w-lg-auto">
              <i class="bi bi-lightning-charge-fill me-1"></i>조회
            </button>
          </div>
        </div>

        <div class="row g-2 row-cols-2 row-cols-md-4 row-cols-xl-7">
          <% const weightFields = [
            { key: 'volume', name: 'volumeWeight', label: '거래량' },
            { key: 'position', name: 'positionWeight', label: '위치' },
            { key: 'trend', name: 'trendWeight', label: '추세' },
            { key: 'rsi', name: 'rsiWeight', label: 'RSI' },
            { key: 'macd', name: 'macdWeight', label: 'MACD' },
            { key: 'resistance', name: 'resistanceWeight', label: '매물 압력' },
            { key: 'volatility', name: 'volatilityWeight', label: '변동성' },
          ]; %>
          <% weightFields.forEach(function(f) { %>
            <div class="col">
              <div class="weight-item">
                <label><%= f.label %> 가중치</label>
                <input
                  type="number"
                  class="form-control form-control-sm"
                  name="<%= f.name %>"
                  value="<%= safeWeights[f.key] %>"
                  min="0"
                  max="100"
                />
              </div>
            </div>
          <% }) %>
        </div>

        <div class="muted-text mt-3">
          예시 기본값: 거래량 30 / 위치 20 / 추세 10 / RSI 5 / MACD 5 / 매물 압력 20 / 변동성 10.<br />
          단타형이면 거래량·추세·RSI·MACD 비중을 높이고, 보수형이면 매물 압력·위치 비중을 높이는 방식이 좋다.
        </div>
      </form>
    </div>

    <% if (safeError) { %>
      <div class="alert alert-danger d-flex align-items-start gap-2 rounded-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
        <div style="white-space: pre-wrap;"><%= safeError %></div>
      </div>
    <% } %>

    <% if (safeCandidates.length > 1 && safeSelected) { %>
      <div class="alert alert-warning d-flex align-items-start gap-2 rounded-4" role="alert">
        <i class="bi bi-info-circle-fill mt-1"></i>
        <div>
          유사한 종목이 여러 개 있어 첫 번째 종목인
          <strong><%= safeSelected.name %></strong>
          을 조회했습니다.
        </div>
      </div>
    <% } %>

    <% if (safeCurrentData && safeDailySeries && safeWeeklySeries && safeMonthlySeries && safeYearlySeries && safeScoreModel) { %>

      <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-currency-dollar me-1"></i>현재가</div>
            <div class="metric-value"><%= fmtNumber(safeCurrentData.currentPrice) %>원</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-arrow-up-right me-1"></i>등락률</div>
            <div class="metric-value"><%= safeCurrentData.changeRate %>%</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-bar-chart-fill me-1"></i>오늘 거래량</div>
            <div class="metric-value"><%= fmtNumber(safeCurrentData.todayVolume) %></div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-activity me-1"></i>20일 평균 대비</div>
            <div class="metric-value"><%= safeSummary ? safeSummary.todayRatio : "-" %>배</div>
          </div>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-12 col-xl-3">
          <div class="metric-card metric-accent p-3">
            <div class="metric-label">종합 점수</div>
            <div class="metric-value"><%= safeScoreModel.totalScore %>점</div>
            <span class="verdict-badge"><%= safeScoreModel.verdict %></span>
          </div>
        </div>
        <% const subScores = [
          { key: 'volume', label: '거래량', icon: 'bi-bar-chart' },
          { key: 'position', label: '위치', icon: 'bi-geo-alt' },
          { key: 'trend', label: '추세', icon: 'bi-graph-up' },
          { key: 'rsi', label: 'RSI', icon: 'bi-speedometer2' },
          { key: 'macd', label: 'MACD', icon: 'bi-soundwave' },
          { key: 'resistance', label: '매물 압력', icon: 'bi-shield-exclamation' },
          { key: 'volatility', label: '변동성', icon: 'bi-tornado' },
        ]; %>
        <% subScores.forEach(function(s) { %>
          <div class="col-6 col-md-4 col-lg-3 col-xl">
            <div class="metric-card p-3">
              <div class="metric-label"><i class="bi <%= s.icon %> me-1"></i><%= s.label %> 점수</div>
              <div class="metric-value"><%= safeScoreModel[s.key].score %>점</div>
            </div>
          </div>
        <% }) %>
      </div>

      <% const buyRec = safeScoreModel.buyRecommendation;
         const tierOrder = ['aggressive', 'neutral', 'conservative'];
         const variants = [
           { key: 'fixed', label: '고정 밴드', icon: 'bi-bounding-box', enabled: true },
           { key: 'atr', label: '변동성(ATR) 기반', icon: 'bi-activity', enabled: !!buyRec.atr },
         ]; %>
      <div class="glass-card p-3 p-lg-4 mb-4">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
          <h2 class="section-title mb-0"><i class="bi bi-cash-coin"></i>추천 매수 구간</h2>
          <span class="recommend-badge recommend-<%= buyRec.recommendedTier %>">
            권고: <strong><%= buyRec.fixed.tiers[buyRec.recommendedTier].label %></strong>
          </span>
        </div>

        <ul class="nav nav-pills buy-tabs mb-3" role="tablist">
          <% variants.forEach(function(v, idx) { %>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link <%= idx === 0 ? 'active' : '' %>"
                data-bs-toggle="pill"
                data-bs-target="#buy-pane-<%= v.key %>"
                type="button"
                role="tab"
                <%= v.enabled ? '' : 'disabled' %>
              >
                <i class="bi <%= v.icon %> me-1"></i><%= v.label %>
              </button>
            </li>
          <% }) %>
        </ul>

        <div class="tab-content">
          <% variants.forEach(function(v, idx) { %>
            <div
              id="buy-pane-<%= v.key %>"
              class="tab-pane fade <%= idx === 0 ? 'show active' : '' %>"
              role="tabpanel"
            >
              <% if (!v.enabled) { %>
                <div class="muted-text">ATR 계산에 필요한 데이터가 부족합니다.</div>
              <% } else { %>
                <% const variantData = buyRec[v.key]; %>
                <div class="muted-text mb-3">
                  <% if (v.key === 'fixed') { %>
                    <strong>고정 밴드 방식</strong> — 모든 종목에 동일한 괴리 범위(공격 -1~-5% / 중립 -5~-10% / 보수 -10~-18%)를 적용합니다. 예측 가능한 기준이지만 종목의 실제 변동성은 반영하지 않습니다.
                  <% } else { %>
                    <strong>변동성(ATR) 기반 방식</strong> — 이 종목의 14일 평균 진폭(ATR)이 <strong><%= variantData.atrPercent %>%</strong>(≈<%= fmtNumber(variantData.atrValue) %>원)입니다. 밴드가 이에 비례해 자동 조정되어 저변동 종목은 타이트하게, 고변동 종목은 넓게 잡힙니다.
                  <% } %>
                </div>
                <div class="row g-3">
                  <% tierOrder.forEach(function(k) { %>
                    <% const t = variantData.tiers[k]; %>
                    <div class="col-12 col-md-4">
                      <div class="buy-tier<%= buyRec.recommendedTier === k ? ' active' : '' %>">
                        <div class="tier-label"><%= t.label %> <span class="tier-band">(<%= t.bandLabel %>)</span></div>
                        <div class="tier-price"><%= fmtNumber(t.price) %>원</div>
                        <div class="tier-gap">현재가 대비 <%= t.gapPercent %>% 하회</div>
                        <div class="tier-desc"><%= t.description %></div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>

        <div class="muted-text mt-3"><%= buyRec.tierExplanation %></div>
        <div class="muted-text mt-1">
          ※ 최근 60일 거래량 히스토그램 + 14일 ATR에 기반한 추정값입니다. 실제 체결가/시장 상황과 다를 수 있으며 투자 조언이 아닙니다.
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-12 col-xl-7">
          <div class="glass-card p-3 p-lg-4 h-100">
            <h2 class="section-title mb-3"><i class="bi bi-info-square"></i>종목 기본 정보</h2>
            <div class="row g-2 row-cols-2 row-cols-md-4">
              <div class="col"><div class="meta-item"><strong>종목명</strong><div class="value"><%= safeCurrentData.stockName %></div></div></div>
              <div class="col"><div class="meta-item"><strong>종목코드</strong><div class="value"><%= safeCurrentData.stockCode %></div></div></div>
              <div class="col"><div class="meta-item"><strong>시장</strong><div class="value"><%= safeCurrentData.market %></div></div></div>
              <div class="col"><div class="meta-item"><strong>전일종가</strong><div class="value"><%= fmtNumber(safeCurrentData.prevClose) %></div></div></div>
              <div class="col"><div class="meta-item"><strong>시가</strong><div class="value"><%= fmtNumber(safeCurrentData.openPrice) %></div></div></div>
              <div class="col"><div class="meta-item"><strong>고가</strong><div class="value"><%= fmtNumber(safeCurrentData.highPrice) %></div></div></div>
              <div class="col"><div class="meta-item"><strong>저가</strong><div class="value"><%= fmtNumber(safeCurrentData.lowPrice) %></div></div></div>
              <div class="col"><div class="meta-item"><strong>외국인 비율</strong><div class="value"><%= safeCurrentData.foreignRate %>%</div></div></div>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-5">
          <div class="glass-card p-3 p-lg-4 h-100">
            <h2 class="section-title mb-3"><i class="bi bi-crosshair"></i>현재 위치 요약</h2>
            <div class="row g-2 row-cols-2">
              <div class="col">
                <div class="position-card">
                  <div class="title">일봉 위치</div>
                  <div class="percent"><%= safeDailySeries.position.positionPercent %>%</div>
                  <div class="desc"><%= safeDailySeries.position.zoneLabel %></div>
                </div>
              </div>
              <div class="col">
                <div class="position-card">
                  <div class="title">주봉 위치</div>
                  <div class="percent"><%= safeWeeklySeries.position.positionPercent %>%</div>
                  <div class="desc"><%= safeWeeklySeries.position.zoneLabel %></div>
                </div>
              </div>
              <div class="col">
                <div class="position-card">
                  <div class="title">월봉 위치</div>
                  <div class="percent"><%= safeMonthlySeries.position.positionPercent %>%</div>
                  <div class="desc"><%= safeMonthlySeries.position.zoneLabel %></div>
                </div>
              </div>
              <div class="col">
                <div class="position-card">
                  <div class="title">연봉 위치</div>
                  <div class="percent"><%= safeYearlySeries.position.positionPercent %>%</div>
                  <div class="desc"><%= safeYearlySeries.position.zoneLabel %></div>
                </div>
              </div>
            </div>
            <div class="muted-text mt-3">
              각 차트는 종가선과 거래량 막대를 함께 보여주고, 빨간 점선은 현재가 위치입니다.
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <% const charts = [
          { id: 'dailyChart', title: '일봉 차트', icon: 'bi-calendar-day', series: safeDailySeries },
          { id: 'weeklyChart', title: '주봉 차트', icon: 'bi-calendar-week', series: safeWeeklySeries },
          { id: 'monthlyChart', title: '월봉 차트', icon: 'bi-calendar-month', series: safeMonthlySeries },
          { id: 'yearlyChart', title: '연봉 차트', icon: 'bi-calendar', series: safeYearlySeries },
        ]; %>
        <% charts.forEach(function(c) { %>
          <div class="col-12 col-xl-6">
            <div class="glass-card p-3 p-lg-4 h-100">
              <h2 class="section-title mb-3"><i class="bi <%= c.icon %>"></i><%= c.title %></h2>
              <div class="chart-wrap"><canvas id="<%= c.id %>"></canvas></div>
              <div class="row g-2 row-cols-2 row-cols-md-4 mt-2">
                <div class="col"><div class="pill"><strong>위치</strong><span><%= c.series.position.positionPercent %>%</span></div></div>
                <div class="col"><div class="pill"><strong>구간</strong><span><%= c.series.position.zoneLabel %></span></div></div>
                <div class="col"><div class="pill"><strong>최저가</strong><span><%= fmtNumber(c.series.position.minPrice) %></span></div></div>
                <div class="col"><div class="pill"><strong>최고가</strong><span><%= fmtNumber(c.series.position.maxPrice) %></span></div></div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="glass-card p-3 p-lg-4 mb-4">
        <h2 class="section-title mb-3"><i class="bi bi-journal-text"></i>점수 설명 / 물린 매물대 추정</h2>
        <div class="row g-3">
          <div class="col-12 col-lg-6">
            <div class="explain-box">
              <h3>점수 설명</h3>
              <ul class="zone-list">
                <li><strong>거래량:</strong> <%= safeScoreModel.volume.explanation %></li>
                <li><strong>위치:</strong> <%= safeScoreModel.position.explanation %></li>
                <li><strong>추세:</strong> <%= safeScoreModel.trend.explanation %></li>
                <li><strong>매물 압력:</strong> <%= safeScoreModel.resistance.explanation %></li>
                <li><strong>변동성:</strong> <%= safeScoreModel.volatility.explanation %></li>
              </ul>
              <div class="muted-text mt-2">
                지금 버전은 규칙 기반 점수화다. 다음 단계에서는 세부 특징을 더 쪼개고, 조건부 보너스/패널티를 늘려서 정교하게 만들 수 있다.
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-6">
            <div class="explain-box">
              <h3>사람들이 많이 물렸을 가능성이 높은 가격대</h3>
              <% if (!safeScoreModel.trappedZones || safeScoreModel.trappedZones.length === 0) { %>
                <div class="muted-text">현재가 위 뚜렷한 매물대가 적습니다.</div>
              <% } else { %>
                <ol class="zone-list">
                  <% safeScoreModel.trappedZones.forEach(function(zone) { %>
                    <li>
                      <strong><%= fmtNumber(zone.start) %> ~ <%= fmtNumber(zone.end) %>원</strong>
                      <span class="muted-text">(추정 거래량: <%= fmtNumber(zone.volume) %>)</span>
                    </li>
                  <% }) %>
                </ol>
                <div class="muted-text mt-2">
                  최근 일봉 120개 기준으로 가격대별 누적 거래량을 근사 계산한 값이다. 실제 개인별 매수단가와 같지는 않지만, 본전 매도 압력이 몰릴 가능성이 있는 구간으로 볼 수 있다.
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card p-3 p-lg-4 mt-4">
        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
          <h2 class="section-title mb-0"><i class="bi bi-robot"></i>AI 전략 코멘트</h2>
          <div class="btn-group btn-group-sm" role="group">
            <button type="button" class="btn btn-outline-danger" id="aiBtnShort">
              <i class="bi bi-lightning-charge me-1"></i>단타 코멘트
            </button>
            <button type="button" class="btn btn-outline-primary" id="aiBtnSwing">
              <i class="bi bi-graph-up me-1"></i>스윙 코멘트
            </button>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mb-2">
          <a class="material-link-chip"
             href="https://finance.naver.com/item/news.nhn?code=<%= currentData.stockCode %>"
             target="_blank" rel="noopener noreferrer"
             title="네이버 금융 — 뉴스/공시 탭">
            <i class="bi bi-newspaper"></i>네이버 뉴스·공시
          </a>
          <a class="material-link-chip"
             href="https://dart.fss.or.kr/dsab007/main.do?selectKey=<%= currentData.stockCode %>"
             target="_blank" rel="noopener noreferrer"
             title="전자공시시스템 DART">
            <i class="bi bi-file-earmark-text"></i>DART 공시
          </a>
        </div>
        <div class="muted-text mb-3" style="font-size: 0.78rem;">
          ⚠️ AI(Gemini Flash) 해석은 참고용이며 투자권유가 아닙니다. 매매 판단과 책임은 본인에게 있습니다.
        </div>
        <div id="aiCommentResult" style="display: none;"></div>
        <div id="aiCommentEmpty" class="muted-text">
          버튼을 누르면 위 점수와 차트 요약을 바탕으로 AI가 단타/스윙 관점의 해석을 생성합니다 (5~15초).
        </div>
      </div>

      <%
        const aiSnapshot = {
          name: currentData.stockName,
          code: currentData.stockCode,
          market: currentData.market,
          currentPrice: currentData.currentPrice,
          changeRate: currentData.changeRate,
          todayHigh: currentData.highPrice,
          todayLow: currentData.lowPrice,
          chegyeolStrength: currentData.chegyeolStrength,
          buySellRatio: currentData.buySellRatio,
          totalScore: safeScoreModel.totalScore,
          verdict: safeScoreModel.verdict,
          components: {
            volume:     { score: safeScoreModel.volume.score,     explanation: safeScoreModel.volume.explanation },
            position:   { score: safeScoreModel.position.score,   explanation: safeScoreModel.position.explanation },
            trend:      { score: safeScoreModel.trend.score,      explanation: safeScoreModel.trend.explanation },
            rsi:        { score: safeScoreModel.rsi.score,        explanation: safeScoreModel.rsi.explanation },
            macd:       { score: safeScoreModel.macd.score,       explanation: safeScoreModel.macd.explanation },
            resistance: { score: safeScoreModel.resistance.score, explanation: safeScoreModel.resistance.explanation },
            volatility: { score: safeScoreModel.volatility.score, explanation: safeScoreModel.volatility.explanation },
          },
          positions: {
            daily:   safeDailySeries?.position   || null,
            weekly:  safeWeeklySeries?.position  || null,
            monthly: safeMonthlySeries?.position || null,
            yearly:  safeYearlySeries?.position  || null,
          },
          trappedZones: safeScoreModel.trappedZones || [],
          buyRecommendation: safeScoreModel.buyRecommendation || null,
        };
      %>
      <script id="ai-snapshot-data" type="application/json"><%- JSON.stringify(aiSnapshot) %></script>
      <script id="ai-auto-mode" type="text/plain"><%= autoMode || 'swing' %></script>

      <script id="daily-series-data" type="application/json"><%- JSON.stringify(safeDailySeries) %></script>
      <script id="weekly-series-data" type="application/json"><%- JSON.stringify(safeWeeklySeries) %></script>
      <script id="monthly-series-data" type="application/json"><%- JSON.stringify(safeMonthlySeries) %></script>
      <script id="yearly-series-data" type="application/json"><%- JSON.stringify(safeYearlySeries) %></script>

      <script>
        window.addEventListener("DOMContentLoaded", function () {
          function parseJson(id) {
            const el = document.getElementById(id);
            if (!el) return null;
            try {
              return JSON.parse(el.textContent || "null");
            } catch (e) {
              return null;
            }
          }

          function createMixedChart(canvasId, series, lineColor) {
            const canvas = document.getElementById(canvasId);
            if (!canvas || !series || !window.Chart) return;

            const ctx = canvas.getContext("2d");
            const lastIndex = series.closePrices.length - 1;

            new Chart(ctx, {
              data: {
                labels: series.labels,
                datasets: [
                  {
                    type: "bar",
                    label: "거래량",
                    data: series.volumes || [],
                    yAxisID: "yVolume",
                    backgroundColor: "rgba(148, 163, 184, 0.45)",
                    borderWidth: 0,
                    order: 2
                  },
                  {
                    type: "line",
                    label: "종가",
                    data: series.closePrices,
                    yAxisID: "yPrice",
                    borderColor: lineColor,
                    backgroundColor: lineColor,
                    borderWidth: 2,
                    tension: 0.2,
                    fill: false,
                    pointRadius: series.closePrices.map((_, idx) => idx === lastIndex ? 5 : 0),
                    pointHoverRadius: series.closePrices.map((_, idx) => idx === lastIndex ? 6 : 3),
                    pointBackgroundColor: series.closePrices.map((_, idx) =>
                      idx === lastIndex ? "rgba(239, 68, 68, 1)" : lineColor
                    ),
                    order: 1
                  },
                  {
                    type: "line",
                    label: "현재가",
                    data: series.currentPriceLine,
                    yAxisID: "yPrice",
                    borderColor: "rgba(239, 68, 68, 0.9)",
                    borderWidth: 1.5,
                    borderDash: [6, 6],
                    pointRadius: 0,
                    tension: 0,
                    fill: false,
                    order: 0
                  }
                ]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: "index", intersect: false },
                plugins: {
                  legend: { position: "top" },
                  tooltip: {
                    callbacks: {
                      label: function(context) {
                        return `${context.dataset.label}: ${Number(context.raw || 0).toLocaleString()}`;
                      }
                    }
                  }
                },
                scales: {
                  x: { ticks: { maxTicksLimit: 8 } },
                  yPrice: {
                    type: "linear",
                    position: "left",
                    beginAtZero: false,
                    ticks: { callback: function(value) { return Number(value).toLocaleString(); } }
                  },
                  yVolume: {
                    type: "linear",
                    position: "right",
                    beginAtZero: true,
                    grid: { drawOnChartArea: false },
                    ticks: { callback: function(value) { return Number(value).toLocaleString(); } }
                  }
                }
              }
            });
          }

          const dailySeries = parseJson("daily-series-data");
          const weeklySeries = parseJson("weekly-series-data");
          const monthlySeries = parseJson("monthly-series-data");
          const yearlySeries = parseJson("yearly-series-data");

          createMixedChart("dailyChart", dailySeries, "rgba(37, 99, 235, 1)");
          createMixedChart("weeklyChart", weeklySeries, "rgba(16, 185, 129, 1)");
          createMixedChart("monthlyChart", monthlySeries, "rgba(245, 158, 11, 1)");
          createMixedChart("yearlyChart", yearlySeries, "rgba(139, 92, 246, 1)");
        });
      </script>
    <% } %>
  </main>

  <div id="loading-overlay" role="status" aria-live="polite">
    <div class="spinner-border text-light" aria-hidden="true"></div>
    <div class="loading-text">종목 데이터를 불러오는 중입니다...</div>
    <div class="small text-white-50">KIS API 호출 특성상 수 초가 걸릴 수 있습니다.</div>
  </div>

  <script>
    (function () {
      const overlay = document.getElementById("loading-overlay");
      const form = document.getElementById("search-form");

      function showOverlay() {
        if (overlay) overlay.classList.add("active");
      }
      function hideOverlay() {
        if (overlay) overlay.classList.remove("active");
      }

      if (form && overlay) {
        form.addEventListener("submit", function () {
          showOverlay();
        });
      }

      // 뒤로가기로 복원되었을 때 오버레이가 남아있지 않도록 처리
      window.addEventListener("pageshow", hideOverlay);
      window.addEventListener("DOMContentLoaded", hideOverlay);
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    (function () {
      const snapshotEl = document.getElementById("ai-snapshot-data");
      if (!snapshotEl) return;
      let snapshot = null;
      try { snapshot = JSON.parse(snapshotEl.textContent || "null"); } catch (_) {}
      if (!snapshot) return;

      const btnShort = document.getElementById("aiBtnShort");
      const btnSwing = document.getElementById("aiBtnSwing");
      const resultBox = document.getElementById("aiCommentResult");
      const emptyBox = document.getElementById("aiCommentEmpty");
      const autoModeEl = document.getElementById("ai-auto-mode");
      const autoMode = (autoModeEl?.textContent || "swing").trim();

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function (c) {
          return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c];
        });
      }

      function renderMarkdown(md) {
        const lines = String(md || "").split(/\r?\n/);
        const out = [];
        let para = [];
        function flushPara() {
          if (para.length) {
            out.push('<p>' + para.join("<br>") + '</p>');
            para = [];
          }
        }
        for (const raw of lines) {
          const line = raw.trim();
          if (!line) { flushPara(); continue; }
          const h = line.match(/^#{2,6}\s+(.+)$/);
          if (h) {
            flushPara();
            out.push('<h6 class="ai-section-h">' + escapeHtml(h[1]) + '</h6>');
          } else {
            para.push(escapeHtml(line));
          }
        }
        flushPara();
        return out.join("");
      }

      function setBusy(busy) {
        [btnShort, btnSwing].forEach(function (b) { if (b) b.disabled = busy; });
      }

      async function callAi(mode) {
        setBusy(true);
        emptyBox.style.display = "none";
        resultBox.style.display = "block";
        resultBox.innerHTML =
          '<div class="text-secondary small d-flex align-items-center gap-2">' +
          '<span class="spinner-border spinner-border-sm"></span> AI 응답을 기다리는 중입니다...</div>';
        try {
          const res = await fetch("/ai/comment", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ mode: mode, snapshot: snapshot }),
          });
          const data = await res.json();
          if (!res.ok) {
            resultBox.innerHTML =
              '<div class="alert alert-warning small mb-0">AI 호출 실패: ' +
              escapeHtml(data.error || res.statusText) + "</div>";
            return;
          }
          const modeLabel = mode === "short" ? "단타" : "스윙";
          const cachedBadge = data.cached
            ? '<span class="badge bg-info ms-2" style="font-size: 0.65rem;">캐시</span>'
            : '';
          const sources = Array.isArray(data.sources) ? data.sources : [];
          let sourcesHtml = '';
          if (sources.length) {
            const items = sources.map(function (s, i) {
              const title = escapeHtml(s.title || s.uri || '');
              const uri = escapeHtml(s.uri || '#');
              return '<li><a href="' + uri + '" target="_blank" rel="noopener noreferrer">' +
                '[' + (i + 1) + '] ' + title + '</a></li>';
            }).join('');
            sourcesHtml =
              '<div class="ai-sources mt-3 pt-2 border-top">' +
                '<div class="muted-text mb-1" style="font-size: 0.75rem;">' +
                  '<i class="bi bi-link-45deg me-1"></i>출처 (Google 검색)' +
                '</div>' +
                '<ol class="ai-sources-list">' + items + '</ol>' +
              '</div>';
          }
          resultBox.innerHTML =
            '<div class="ai-card">' +
              '<div class="ai-mode-badge ' + (mode === "short" ? "short" : "swing") + '">' +
                modeLabel + " 관점" +
              '</div>' + cachedBadge +
              renderMarkdown(data.text) +
              sourcesHtml +
            '</div>';
        } catch (err) {
          resultBox.innerHTML =
            '<div class="alert alert-danger small mb-0">네트워크 오류: ' +
            escapeHtml(err.message || String(err)) + "</div>";
        } finally {
          setBusy(false);
        }
      }

      btnShort?.addEventListener("click", function () { callAi("short"); });
      btnSwing?.addEventListener("click", function () { callAi("swing"); });

      if (autoMode === "short" || autoMode === "swing") {
        setTimeout(function () { callAi(autoMode); }, 100);
      }
    })();
  </script>
</body>
</html>
