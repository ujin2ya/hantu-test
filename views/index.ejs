<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>주식앱 스타일 차트 + 점수화</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 24px;
      font-family: Arial, sans-serif;
      background: #f5f7fb;
      color: #1f2937;
    }

    .container {
      max-width: 1480px;
      margin: 0 auto;
    }

    h1 {
      margin: 0 0 20px;
      font-size: 28px;
    }

    .search-box, .section, .card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    }

    .search-box {
      padding: 20px;
      margin-bottom: 20px;
    }

    .search-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    input[type="text"], input[type="number"] {
      padding: 14px;
      border: 1px solid #d7dce5;
      border-radius: 10px;
      font-size: 16px;
    }

    input[type="text"] {
      flex: 1;
      min-width: 240px;
    }

    input[type="number"] {
      width: 100%;
    }

    button {
      padding: 14px 20px;
      border: none;
      border-radius: 10px;
      background: #2563eb;
      color: #fff;
      font-size: 16px;
      cursor: pointer;
    }

    button:hover {
      background: #1d4ed8;
    }

    .weight-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 12px;
    }

    .weight-item {
      background: #f8fafc;
      border-radius: 12px;
      padding: 12px;
    }

    .weight-item label {
      display: block;
      font-size: 13px;
      color: #64748b;
      margin-bottom: 8px;
    }

    .error {
      background: #fee2e2;
      color: #991b1b;
      border-radius: 12px;
      padding: 14px;
      margin-bottom: 20px;
      white-space: pre-wrap;
    }

    .info {
      background: #fff7ed;
      color: #9a3412;
      border-radius: 12px;
      padding: 14px;
      margin-bottom: 20px;
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 20px;
    }

    .score-grid {
      display: grid;
      grid-template-columns: 1.2fr repeat(7, 1fr);
      gap: 16px;
      margin-bottom: 20px;
    }

    .card {
      padding: 18px;
    }

    .card-label {
      font-size: 13px;
      color: #6b7280;
      margin-bottom: 10px;
    }

    .card-value {
      font-size: 28px;
      font-weight: bold;
      word-break: break-word;
    }

    .section {
      padding: 20px;
      margin-bottom: 20px;
    }

    .section h2 {
      margin: 0 0 16px;
      font-size: 20px;
    }

    .top-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .meta-item {
      background: #f8fafc;
      border-radius: 12px;
      padding: 14px;
      word-break: break-word;
    }

    .meta-item strong {
      display: block;
      margin-bottom: 6px;
      color: #475569;
      font-size: 13px;
    }

    .position-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .position-card {
      background: #f8fafc;
      border-radius: 12px;
      padding: 14px;
    }

    .position-card .title {
      font-size: 13px;
      color: #64748b;
      margin-bottom: 8px;
    }

    .position-card .percent {
      font-size: 26px;
      font-weight: bold;
      margin-bottom: 6px;
    }

    .position-card .desc {
      font-size: 14px;
      color: #475569;
    }

    .chart-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .chart-wrap {
      position: relative;
      width: 100%;
      height: 360px;
    }

    .muted {
      color: #64748b;
      font-size: 13px;
      margin-top: 10px;
      line-height: 1.5;
    }

    .summary-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-top: 14px;
    }

    .summary-pill {
      background: #f8fafc;
      border-radius: 12px;
      padding: 12px;
    }

    .summary-pill strong {
      display: block;
      font-size: 12px;
      color: #64748b;
      margin-bottom: 6px;
    }

    .summary-pill span {
      font-size: 18px;
      font-weight: bold;
    }

    .explain-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .explain-box {
      background: #f8fafc;
      border-radius: 12px;
      padding: 16px;
    }

    .explain-box h3 {
      margin: 0 0 10px;
      font-size: 16px;
    }

    .zone-list {
      margin: 0;
      padding-left: 18px;
      line-height: 1.7;
    }

    .small {
      font-size: 12px;
      color: #64748b;
    }

    @media (max-width: 1200px) {
      .top-grid,
      .chart-grid,
      .meta-grid,
      .card-grid,
      .score-grid,
      .summary-row,
      .position-grid,
      .weight-grid,
      .explain-grid {
        grid-template-columns: 1fr;
      }

      .chart-wrap {
        height: 300px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeQuery = query || "";
    const safeError = error || null;
    const safeSelected = selected || null;
    const safeCurrentData = currentData || null;
    const safeCandidates = Array.isArray(candidates) ? candidates : [];
    const safeDailySeries = dailySeries || null;
    const safeWeeklySeries = weeklySeries || null;
    const safeMonthlySeries = monthlySeries || null;
    const safeYearlySeries = yearlySeries || null;
    const safeSummary = summary || null;
    const safeScoreModel = scoreModel || null;
    const safeWeights = weights || {
      volume: 30,
      position: 20,
      trend: 10,
      rsi: 5,
      macd: 5,
      resistance: 20,
      volatility: 10,
    };

    function fmtNumber(value) {
      return Number(value || 0).toLocaleString();
    }
  %>

  <div class="container">
    <h1>주식앱 스타일 차트 + 점수화</h1>

    <div class="search-box">
      <form method="post" action="/search">
        <div class="search-row">
          <input
            type="text"
            name="stockName"
            placeholder="예: 로킷헬스케어"
            value="<%= safeQuery %>"
          />
          <button type="submit">조회</button>
        </div>

        <div class="weight-grid">
          <div class="weight-item">
            <label>거래량 가중치</label>
            <input type="number" name="volumeWeight" value="<%= safeWeights.volume %>" min="0" max="100" />
          </div>
          <div class="weight-item">
            <label>위치 가중치</label>
            <input type="number" name="positionWeight" value="<%= safeWeights.position %>" min="0" max="100" />
          </div>
          <div class="weight-item">
            <label>추세 가중치</label>
            <input type="number" name="trendWeight" value="<%= safeWeights.trend %>" min="0" max="100" />
          </div>
          <div class="weight-item">
            <label>RSI 가중치</label>
            <input type="number" name="rsiWeight" value="<%= safeWeights.rsi %>" min="0" max="100" />
          </div>
          <div class="weight-item">
            <label>MACD 가중치</label>
            <input type="number" name="macdWeight" value="<%= safeWeights.macd %>" min="0" max="100" />
          </div>
          <div class="weight-item">
            <label>매물 압력 가중치</label>
            <input type="number" name="resistanceWeight" value="<%= safeWeights.resistance %>" min="0" max="100" />
          </div>
          <div class="weight-item">
            <label>변동성 가중치</label>
            <input type="number" name="volatilityWeight" value="<%= safeWeights.volatility %>" min="0" max="100" />
          </div>
        </div>

        <div class="muted">
          예시 기본값: 거래량 30 / 위치 20 / 추세 10 / RSI 5 / MACD 5 / 매물 압력 20 / 변동성 10.<br />
          단타형이면 거래량·추세·RSI·MACD 비중을 높이고, 보수형이면 매물 압력·위치 비중을 높이는 방식이 좋다.
        </div>
      </form>
    </div>

    <% if (safeError) { %>
      <div class="error"><%= safeError %></div>
    <% } %>

    <% if (safeCandidates.length > 1 && safeSelected) { %>
      <div class="info">
        유사한 종목이 여러 개 있어 첫 번째 종목인
        <strong><%= safeSelected.name %></strong>
        을 조회했습니다.
      </div>
    <% } %>

    <% if (safeCurrentData && safeDailySeries && safeWeeklySeries && safeMonthlySeries && safeYearlySeries && safeScoreModel) { %>
      <div class="card-grid">
        <div class="card">
          <div class="card-label">현재가</div>
          <div class="card-value"><%= fmtNumber(safeCurrentData.currentPrice) %>원</div>
        </div>
        <div class="card">
          <div class="card-label">등락률</div>
          <div class="card-value"><%= safeCurrentData.changeRate %>%</div>
        </div>
        <div class="card">
          <div class="card-label">오늘 거래량</div>
          <div class="card-value"><%= fmtNumber(safeCurrentData.todayVolume) %></div>
        </div>
        <div class="card">
          <div class="card-label">20일 평균 대비</div>
          <div class="card-value"><%= safeSummary ? safeSummary.todayRatio : "-" %>배</div>
        </div>
      </div>

      <div class="score-grid">
        <div class="card">
          <div class="card-label">종합 점수</div>
          <div class="card-value"><%= safeScoreModel.totalScore %>점</div>
          <div class="muted"><%= safeScoreModel.verdict %></div>
        </div>
        <div class="card">
          <div class="card-label">거래량 점수</div>
          <div class="card-value"><%= safeScoreModel.volume.score %>점</div>
        </div>
        <div class="card">
          <div class="card-label">위치 점수</div>
          <div class="card-value"><%= safeScoreModel.position.score %>점</div>
        </div>
        <div class="card">
          <div class="card-label">추세 점수</div>
          <div class="card-value"><%= safeScoreModel.trend.score %>점</div>
        </div>
        <div class="card">
          <div class="card-label">RSI 점수</div>
          <div class="card-value"><%= safeScoreModel.rsi.score %>점</div>
        </div>
        <div class="card">
          <div class="card-label">MACD 점수</div>
          <div class="card-value"><%= safeScoreModel.macd.score %>점</div>
        </div>
        <div class="card">
          <div class="card-label">매물 압력 점수</div>
          <div class="card-value"><%= safeScoreModel.resistance.score %>점</div>
        </div>
        <div class="card">
          <div class="card-label">변동성 점수</div>
          <div class="card-value"><%= safeScoreModel.volatility.score %>점</div>
        </div>
      </div>

      <div class="top-grid">
        <div class="section">
          <h2>종목 기본 정보</h2>
          <div class="meta-grid">
            <div class="meta-item"><strong>종목명</strong><%= safeCurrentData.stockName %></div>
            <div class="meta-item"><strong>종목코드</strong><%= safeCurrentData.stockCode %></div>
            <div class="meta-item"><strong>시장</strong><%= safeCurrentData.market %></div>
            <div class="meta-item"><strong>전일종가</strong><%= fmtNumber(safeCurrentData.prevClose) %></div>
            <div class="meta-item"><strong>시가</strong><%= fmtNumber(safeCurrentData.openPrice) %></div>
            <div class="meta-item"><strong>고가</strong><%= fmtNumber(safeCurrentData.highPrice) %></div>
            <div class="meta-item"><strong>저가</strong><%= fmtNumber(safeCurrentData.lowPrice) %></div>
            <div class="meta-item"><strong>외국인 비율</strong><%= safeCurrentData.foreignRate %>%</div>
          </div>
        </div>

        <div class="section">
          <h2>현재 위치 요약</h2>
          <div class="position-grid">
            <div class="position-card">
              <div class="title">일봉 위치</div>
              <div class="percent"><%= safeDailySeries.position.positionPercent %>%</div>
              <div class="desc"><%= safeDailySeries.position.zoneLabel %></div>
            </div>
            <div class="position-card">
              <div class="title">주봉 위치</div>
              <div class="percent"><%= safeWeeklySeries.position.positionPercent %>%</div>
              <div class="desc"><%= safeWeeklySeries.position.zoneLabel %></div>
            </div>
            <div class="position-card">
              <div class="title">월봉 위치</div>
              <div class="percent"><%= safeMonthlySeries.position.positionPercent %>%</div>
              <div class="desc"><%= safeMonthlySeries.position.zoneLabel %></div>
            </div>
            <div class="position-card">
              <div class="title">연봉 위치</div>
              <div class="percent"><%= safeYearlySeries.position.positionPercent %>%</div>
              <div class="desc"><%= safeYearlySeries.position.zoneLabel %></div>
            </div>
          </div>
          <div class="muted">
            각 차트는 종가선과 거래량 막대를 함께 보여주고, 빨간 점선은 현재가 위치입니다.
          </div>
        </div>
      </div>

      <div class="chart-grid">
        <div class="section">
          <h2>일봉 차트</h2>
          <div class="chart-wrap"><canvas id="dailyChart"></canvas></div>
          <div class="summary-row">
            <div class="summary-pill"><strong>위치</strong><span><%= safeDailySeries.position.positionPercent %>%</span></div>
            <div class="summary-pill"><strong>구간</strong><span><%= safeDailySeries.position.zoneLabel %></span></div>
            <div class="summary-pill"><strong>최저가</strong><span><%= fmtNumber(safeDailySeries.position.minPrice) %></span></div>
            <div class="summary-pill"><strong>최고가</strong><span><%= fmtNumber(safeDailySeries.position.maxPrice) %></span></div>
          </div>
        </div>

        <div class="section">
          <h2>주봉 차트</h2>
          <div class="chart-wrap"><canvas id="weeklyChart"></canvas></div>
          <div class="summary-row">
            <div class="summary-pill"><strong>위치</strong><span><%= safeWeeklySeries.position.positionPercent %>%</span></div>
            <div class="summary-pill"><strong>구간</strong><span><%= safeWeeklySeries.position.zoneLabel %></span></div>
            <div class="summary-pill"><strong>최저가</strong><span><%= fmtNumber(safeWeeklySeries.position.minPrice) %></span></div>
            <div class="summary-pill"><strong>최고가</strong><span><%= fmtNumber(safeWeeklySeries.position.maxPrice) %></span></div>
          </div>
        </div>

        <div class="section">
          <h2>월봉 차트</h2>
          <div class="chart-wrap"><canvas id="monthlyChart"></canvas></div>
          <div class="summary-row">
            <div class="summary-pill"><strong>위치</strong><span><%= safeMonthlySeries.position.positionPercent %>%</span></div>
            <div class="summary-pill"><strong>구간</strong><span><%= safeMonthlySeries.position.zoneLabel %></span></div>
            <div class="summary-pill"><strong>최저가</strong><span><%= fmtNumber(safeMonthlySeries.position.minPrice) %></span></div>
            <div class="summary-pill"><strong>최고가</strong><span><%= fmtNumber(safeMonthlySeries.position.maxPrice) %></span></div>
          </div>
        </div>

        <div class="section">
          <h2>연봉 차트</h2>
          <div class="chart-wrap"><canvas id="yearlyChart"></canvas></div>
          <div class="summary-row">
            <div class="summary-pill"><strong>위치</strong><span><%= safeYearlySeries.position.positionPercent %>%</span></div>
            <div class="summary-pill"><strong>구간</strong><span><%= safeYearlySeries.position.zoneLabel %></span></div>
            <div class="summary-pill"><strong>최저가</strong><span><%= fmtNumber(safeYearlySeries.position.minPrice) %></span></div>
            <div class="summary-pill"><strong>최고가</strong><span><%= fmtNumber(safeYearlySeries.position.maxPrice) %></span></div>
          </div>
        </div>
      </div>

      <div class="section">
        <h2>점수 설명 / 물린 매물대 추정</h2>
        <div class="explain-grid">
          <div class="explain-box">
            <h3>점수 설명</h3>
            <ul class="zone-list">
              <li><strong>거래량:</strong> <%= safeScoreModel.volume.explanation %></li>
              <li><strong>위치:</strong> <%= safeScoreModel.position.explanation %></li>
              <li><strong>추세:</strong> <%= safeScoreModel.trend.explanation %></li>
              <li><strong>매물 압력:</strong> <%= safeScoreModel.resistance.explanation %></li>
              <li><strong>변동성:</strong> <%= safeScoreModel.volatility.explanation %></li>
            </ul>
            <div class="muted">
              지금 버전은 규칙 기반 점수화다. 다음 단계에서는 세부 특징을 더 쪼개고, 조건부 보너스/패널티를 늘려서 정교하게 만들 수 있다.
            </div>
          </div>

          <div class="explain-box">
            <h3>사람들이 많이 물렸을 가능성이 높은 가격대</h3>
            <% if (!safeScoreModel.trappedZones || safeScoreModel.trappedZones.length === 0) { %>
              <div class="muted">현재가 위 뚜렷한 매물대가 적습니다.</div>
            <% } else { %>
              <ol class="zone-list">
                <% safeScoreModel.trappedZones.forEach(function(zone) { %>
                  <li>
                    <strong><%= fmtNumber(zone.start) %> ~ <%= fmtNumber(zone.end) %>원</strong>
                    <span class="small">(추정 거래량: <%= fmtNumber(zone.volume) %>)</span>
                  </li>
                <% }) %>
              </ol>
              <div class="muted">
                최근 일봉 120개 기준으로 가격대별 누적 거래량을 근사 계산한 값이다. 실제 개인별 매수단가와 같지는 않지만, 본전 매도 압력이 몰릴 가능성이 있는 구간으로 볼 수 있다.
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <script id="daily-series-data" type="application/json"><%- JSON.stringify(safeDailySeries) %></script>
      <script id="weekly-series-data" type="application/json"><%- JSON.stringify(safeWeeklySeries) %></script>
      <script id="monthly-series-data" type="application/json"><%- JSON.stringify(safeMonthlySeries) %></script>
      <script id="yearly-series-data" type="application/json"><%- JSON.stringify(safeYearlySeries) %></script>

      <script>
        window.addEventListener("DOMContentLoaded", function () {
          function parseJson(id) {
            const el = document.getElementById(id);
            if (!el) return null;
            try {
              return JSON.parse(el.textContent || "null");
            } catch (e) {
              return null;
            }
          }

          function createMixedChart(canvasId, series, lineColor) {
            const canvas = document.getElementById(canvasId);
            if (!canvas || !series || !window.Chart) return;

            const ctx = canvas.getContext("2d");
            const lastIndex = series.closePrices.length - 1;

            new Chart(ctx, {
              data: {
                labels: series.labels,
                datasets: [
                  {
                    type: "bar",
                    label: "거래량",
                    data: series.volumes || [],
                    yAxisID: "yVolume",
                    backgroundColor: "rgba(148, 163, 184, 0.45)",
                    borderWidth: 0,
                    order: 2
                  },
                  {
                    type: "line",
                    label: "종가",
                    data: series.closePrices,
                    yAxisID: "yPrice",
                    borderColor: lineColor,
                    backgroundColor: lineColor,
                    borderWidth: 2,
                    tension: 0.2,
                    fill: false,
                    pointRadius: series.closePrices.map((_, idx) => idx === lastIndex ? 5 : 0),
                    pointHoverRadius: series.closePrices.map((_, idx) => idx === lastIndex ? 6 : 3),
                    pointBackgroundColor: series.closePrices.map((_, idx) =>
                      idx === lastIndex ? "rgba(239, 68, 68, 1)" : lineColor
                    ),
                    order: 1
                  },
                  {
                    type: "line",
                    label: "현재가",
                    data: series.currentPriceLine,
                    yAxisID: "yPrice",
                    borderColor: "rgba(239, 68, 68, 0.9)",
                    borderWidth: 1.5,
                    borderDash: [6, 6],
                    pointRadius: 0,
                    tension: 0,
                    fill: false,
                    order: 0
                  }
                ]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                  mode: "index",
                  intersect: false
                },
                plugins: {
                  legend: {
                    position: "top"
                  },
                  tooltip: {
                    callbacks: {
                      label: function(context) {
                        return `${context.dataset.label}: ${Number(context.raw || 0).toLocaleString()}`;
                      }
                    }
                  }
                },
                scales: {
                  x: {
                    ticks: {
                      maxTicksLimit: 8
                    }
                  },
                  yPrice: {
                    type: "linear",
                    position: "left",
                    beginAtZero: false,
                    ticks: {
                      callback: function(value) {
                        return Number(value).toLocaleString();
                      }
                    }
                  },
                  yVolume: {
                    type: "linear",
                    position: "right",
                    beginAtZero: true,
                    grid: {
                      drawOnChartArea: false
                    },
                    ticks: {
                      callback: function(value) {
                        return Number(value).toLocaleString();
                      }
                    }
                  }
                }
              }
            });
          }

          const dailySeries = parseJson("daily-series-data");
          const weeklySeries = parseJson("weekly-series-data");
          const monthlySeries = parseJson("monthly-series-data");
          const yearlySeries = parseJson("yearly-series-data");

          createMixedChart("dailyChart", dailySeries, "rgba(37, 99, 235, 1)");
          createMixedChart("weeklyChart", weeklySeries, "rgba(16, 185, 129, 1)");
          createMixedChart("monthlyChart", monthlySeries, "rgba(245, 158, 11, 1)");
          createMixedChart("yearlyChart", yearlySeries, "rgba(139, 92, 246, 1)");
        });
      </script>
    <% } %>
  </div>
</body>
</html>