              <div class="col"><div class="meta-item"><strong>고가</strong><div class="value"><%= fmtNumber(safeCurrentData.highPrice) %></div></div></div>
              <div class="col"><div class="meta-item"><strong>저가</strong><div class="value"><%= fmtNumber(safeCurrentData.lowPrice) %></div></div></div>
