      <div class="row g-3 mb-4">
        <% const charts = [
          { id: 'dailyChart', title: '일봉 차트', icon: 'bi-calendar-day', series: safeDailySeries },
          { id: 'weeklyChart', title: '주봉 차트', icon: 'bi-calendar-week', series: safeWeeklySeries },
          { id: 'monthlyChart', title: '월봉 차트', icon: 'bi-calendar-month', series: safeMonthlySeries },
