      <%
        const _safeBuy = safeScoreModel.buyRecommendation;
        const _gradeColor = _safeBuy?.gradeColor || 'warn';
        const _gradeBg = _gradeColor === 'good' ? '#dcfce7' : _gradeColor === 'bad' ? '#fee2e2' : '#fef3c7';
        const _gradeFg = _gradeColor === 'good' ? '#166534' : _gradeColor === 'bad' ? '#991b1b' : '#92400e';
      %>
      <div class="glass-card p-3 p-lg-4 mb-4" style="border-left: 4px solid <%= _gradeFg %>;">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-3">
