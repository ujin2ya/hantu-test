<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= stockMeta ? stockMeta.name + ' — 차트 & AI 분석' : '종목 검색' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/luxon@3.4.4/build/global/luxon.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@1.3.1/dist/chartjs-adapter-luxon.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-chart-financial@0.2.1/dist/chartjs-chart-financial.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>
  <style>
    :root { --pos: #047857; --neg: #dc2626; --muted: #64748b; }
    * { box-sizing: border-box; }
    html, body { background: #f8fafc; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Malgun Gothic", sans-serif; color: #0f172a; margin: 0; -webkit-text-size-adjust: 100%; }
    .wrap { max-width: 720px; margin: 0 auto; padding: 12px 12px 60px; }

    /* 검색 (간단) */
    .search-bar { display: flex; gap: 6px; margin-bottom: 10px; }
    .search-bar input { flex: 1; padding: 9px 12px; background: white; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 14px; }
    .search-bar button { padding: 9px 14px; background: #2563eb; color: white; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; }
    .nav-back { color: #64748b; font-size: 12px; text-decoration: none; padding: 4px 0; display: inline-block; }

    .card { background: white; border: 1px solid #e2e8f0; border-radius: 10px; padding: 12px 14px; margin-bottom: 10px; }
    .card h2 { font-size: 14px; color: #0f172a; margin: 0 0 8px 0; font-weight: 700; }

    /* 종목 헤더 - 컴팩트 */
    .header-card { padding: 14px; }
    .header-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; margin-bottom: 4px; }
    .header-name { font-size: 19px; font-weight: 700; }
    .header-code { color: var(--muted); font-size: 13px; }
    .header-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .price-block { margin-top: 10px; }
    .price-main { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
    .price-big { font-size: 28px; font-weight: 800; line-height: 1; color: #0f172a; }
    .price-unit { font-size: 14px; font-weight: 600; color: #64748b; margin-left: 2px; }
    .price-change { font-size: 14px; font-weight: 700; }
    .price-change.pos { color: var(--pos); }
    .price-change.neg { color: var(--neg); }
    .price-sub-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
    .badge-tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .price-sub-text { font-size: 11px; color: var(--muted); }

    .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .badge-EARLY_QVA { background: #ecfdf5; color: #047857; border: 1px solid #10b981; }
    .badge-VVI_FIRED { background: #eff6ff; color: #1e40af; border: 1px solid #3b82f6; }
    .badge-BREAKOUT_SUCCESS { background: #ecfdf5; color: #064e3b; border: 1px solid #047857; }
    .badge-FAILED { background: #f1f5f9; color: #475569; }
    .badge-confirmed { background: #dbeafe; color: #1e40af; border: 1px solid #3b82f6; }

    /* 차트 — KB증권식 깔끔한 일봉 차트 */
    .chart-card { padding: 10px 8px 12px; background: #ffffff; }
    .chart-title { font-size: 13px; font-weight: 600; color: #0f172a; padding: 0 6px 6px; display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
    .chart-sub-title { font-size: 11px; font-weight: 500; color: #777; padding: 6px 6px 2px; margin-top: 4px; }
    .chart-legend { display: flex; flex-wrap: wrap; gap: 8px 12px; font-size: 10px; color: var(--muted); padding: 0 6px; margin-top: 6px; }
    .chart-legend .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; vertical-align: middle; margin-right: 3px; border: 1px solid #ffffff; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.1); }
    .chart-price-wrap { position: relative; height: 360px; background: #fafbfc; border-radius: 4px; }
    .chart-volume-wrap { position: relative; height: 90px; margin-top: 2px; }
    .chart-value-wrap { position: relative; height: 110px; margin-top: 2px; background: #fafbfc; border-radius: 4px; }
    .why-card h2 { color: #047857; }
    .why-section { background: #f0fdf4; border-left: 3px solid #10b981; padding: 8px 12px; border-radius: 6px; margin-bottom: 8px; }
    .why-section-title { font-size: 13px; font-weight: 700; color: #064e3b; margin-bottom: 4px; }
    .why-section ul { margin: 0; padding-left: 18px; font-size: 12px; line-height: 1.7; color: #1e293b; }

    /* AI 분석 안내 */
    .ai-loading-notice { background: #fef3c7; border-left: 3px solid #f59e0b; padding: 8px 10px; border-radius: 6px; margin-bottom: 10px; font-size: 11px; color: #78350f; line-height: 1.5; }
    .ai-card h2 { color: #1e40af; }
    .ai-card .summary-text { font-size: 13px; line-height: 1.7; background: #f8fafc; padding: 10px 12px; border-radius: 6px; border-left: 3px solid #60a5fa; color: #1e293b; }
    .ai-card ul { font-size: 13px; line-height: 1.7; padding-left: 18px; margin: 6px 0; color: #1e293b; }
    .ai-card .cautions { color: #78350f; }
    .ai-card .ai-footnote { font-size: 11px; color: var(--muted); margin-top: 8px; }
    .ai-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .ai-badge.ai-type { background: #ede9fe; color: #5b21b6; }
    .ai-badge.ai-strong-h { background: #fee2e2; color: #991b1b; }
    .ai-badge.ai-strong-m { background: #fef3c7; color: #78350f; }
    .ai-badge.ai-strong-l { background: #f1f5f9; color: #475569; }
    .ai-badge.ai-fresh { background: #dbeafe; color: #1e40af; }

    .footer-disclaimer { background: #422006; color: #fde68a; padding: 12px 14px; border-radius: 8px; font-size: 12px; line-height: 1.6; margin-top: 12px; }
    .footer-disclaimer strong { color: #fbbf24; }

    .empty-state { color: var(--muted); font-size: 13px; text-align: center; padding: 24px 0; }
    .ret-pos { color: var(--pos); font-weight: 600; }
    .ret-neg { color: var(--neg); font-weight: 600; }

    @media (min-width: 720px) {
      .wrap { padding: 16px 18px 60px; }
      .header-name { font-size: 22px; }
      .price-big { font-size: 28px; }
      .chart-price-wrap { height: 440px; }
      .chart-volume-wrap { height: 110px; }
      .chart-value-wrap { height: 130px; }
    }
  </style>
</head>
<body>
  <div class="wrap">

    <a href="/qva-watchlist" class="nav-back"><i class="bi bi-arrow-left me-1"></i>운영 보드로</a>

    <div class="search-bar">
      <form method="post" action="/search" style="display:flex;gap:6px;flex:1;">
        <input type="text" name="stockQuery" value="<%= query || '' %>" placeholder="종목명 또는 6자리 코드" />
        <button type="submit"><i class="bi bi-search"></i></button>
      </form>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger" style="font-size:13px;padding:10px 12px;"><%= error %></div>
    <% } %>

    <% if (candidates && candidates.length > 1) { %>
    <div class="card">
      <div style="font-size:12px;color:#64748b;margin-bottom:6px;">여러 종목이 일치합니다</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px;">
        <% candidates.forEach(function(c) { %>
          <a class="btn btn-outline-secondary btn-sm" href="/?query=<%= c.shortCode %>" style="font-size:12px;"><%= c.name %> <%= c.shortCode %></a>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (stockMeta) {
      var changeRate = stockMeta.changeRate || 0;
      var changeClass = changeRate > 0 ? 'pos' : (changeRate < 0 ? 'neg' : '');
      var changeText = (changeRate > 0 ? '+' : '') + changeRate.toFixed(2) + '%';
      var qw = qvaWatchData;
    %>

      <!-- AI 로딩 안내 -->
      <div class="ai-loading-notice">
        💡 AI 뉴스·공시 분석이 포함돼 있어 첫 조회 시 10~30초 걸릴 수 있습니다 (재조회는 캐시로 즉시 표시).
      </div>

      <!-- ============ 종목 헤더 (컴팩트) ============ -->
      <div class="card header-card">
        <div class="header-row">
          <span class="header-name"><%= stockMeta.name %></span>
          <span class="header-code"><%= stockMeta.code %></span>
          <% if (qw && qw.mainStage) { %>
            <span class="badge badge-<%= qw.mainStage %>"><%= qw.mainStageLabel || qw.mainStage %></span>
          <% } %>
          <% if (breakoutData && breakoutData.confirmedQvaPass) { %>
            <span class="badge badge-confirmed" title="QVA 이후 가격 유지·저점 상승·거래대금 흐름 한 번 더 확인됨">QVA 확인 통과</span>
          <% } %>
        </div>
        <div class="header-meta">
          <%= stockMeta.market || '-' %>
          <% if (stockMeta.marketCap) { %> · 시총 <%= (stockMeta.marketCap / 1e8).toLocaleString() %>억<% } %>
        </div>
        <% if (priceInfo) {
          var dispPrice = priceInfo.displayPriceType === 'INTRADAY_CURRENT' ? priceInfo.displayPrice : priceInfo.lastClose;
          var basePrice = chartRows && chartRows.length >= 2 ? chartRows[chartRows.length - 2].close : null;
          var changeAmount = basePrice ? (dispPrice - basePrice) : null;
          var arrow = changeRate > 0 ? '▲' : (changeRate < 0 ? '▼' : '─');
          var dateLbl = priceInfo.latestTradingDate.slice(0,4) + '-' + priceInfo.latestTradingDate.slice(4,6) + '-' + priceInfo.latestTradingDate.slice(6,8);
        %>
        <div class="price-block">
          <div class="price-main">
            <span class="price-big"><%= dispPrice.toLocaleString() %><span class="price-unit">원</span></span>
            <span class="price-change <%= changeClass %>"><%= arrow %>
              <% if (changeAmount != null) { %><%= Math.abs(changeAmount).toLocaleString() %>원 <% } %>
              <%= changeText %>
            </span>
          </div>
          <div class="price-sub-row">
            <% if (priceInfo.displayPriceType === 'INTRADAY_CURRENT') { %>
              <span class="badge-tag" style="background:#dcfce7;color:#15803d;">🟢 장중 현재가</span>
              <span class="price-sub-text">전일 종가 <%= priceInfo.lastClose.toLocaleString() %>원 (<%= dateLbl %>)</span>
            <% } else { %>
              <span class="badge-tag" style="background:#f1f5f9;color:#475569;">📅 <%= dateLbl %> 종가</span>
              <% if (chartRows && chartRows.length > 0) {
                var lr = chartRows[chartRows.length - 1];
              %>
                <span class="price-sub-text">고 <%= lr.high.toLocaleString() %> · 저 <%= lr.low.toLocaleString() %> · 거래량 <%= (lr.volume/10000).toFixed(0) %>만</span>
              <% } %>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>

      <!-- ============ QVA / VVI 분석 차트 ============ -->
      <% if (chartRows && chartRows.length > 0) {
        var hasAnyEvent = (qvaEpisodes && qvaEpisodes.length > 0) ||
                         (qvaWatchData && (qvaWatchData.firstEarlyQvaDate || qvaWatchData.qvaSignalDate)) ||
                         (breakoutData && (breakoutData.vviDate || breakoutData.breakoutDate));
      %>
      <div class="card chart-card">
        <div class="chart-title">
          <div>
            <div style="font-weight:700;font-size:14px;">일봉 차트</div>
            <div style="font-size:10px;color:#94a3b8;font-weight:400;margin-top:2px;">전일 종가 대비 상승=빨강, 하락=파랑 · QVA / VVI / 돌파 성공 위치를 작은 점으로 표시</div>
          </div>
          <button id="refresh-chart-btn" type="button" data-code="<%= stockMeta.code %>"
            style="background:#2563eb;color:white;border:none;padding:6px 10px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:4px;flex-shrink:0;">
            <span class="refresh-spin">↻</span> 갱신
          </button>
        </div>
        <div id="refresh-status" style="font-size:11px;color:#94a3b8;padding:0 6px 4px;display:none;"></div>

        <!-- ============ 시그널 요약 박스 — KB증권식 간결 ============ -->
        <% if (qvaEpisodes && qvaEpisodes.length > 0) {
          var latest = qvaEpisodes[qvaEpisodes.length - 1];
          function fmtSig(d) { return d ? d.slice(0,4)+'-'+d.slice(4,6)+'-'+d.slice(6,8) : null; }
        %>
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:8px 12px;margin:6px 6px 10px;font-size:12px;line-height:1.7;">
          <div style="font-weight:600;color:#475569;margin-bottom:4px;font-size:11px;">시그널 요약</div>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:2px 12px;">
            <div><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#10b981;border:1px solid #fff;box-shadow:0 0 0 0.5px rgba(0,0,0,0.1);vertical-align:middle;margin-right:4px;"></span>QVA <strong style="color:#047857;"><%= fmtSig(latest.firstSignalDate) || '-' %></strong></div>
            <div><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#f59e0b;border:1px solid #fff;box-shadow:0 0 0 0.5px rgba(0,0,0,0.1);vertical-align:middle;margin-right:4px;"></span>VVI <% if (breakoutData && breakoutData.vviDate) { %><strong style="color:#92400e;"><%= fmtSig(breakoutData.vviDate) %></strong><% } else { %><span class="muted">-</span><% } %></div>
            <div><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#dc2626;border:1px solid #fff;box-shadow:0 0 0 0.5px rgba(0,0,0,0.1);vertical-align:middle;margin-right:4px;"></span>돌파 성공 <% if (breakoutData && breakoutData.breakoutDate) { %><strong style="color:#991b1b;"><%= fmtSig(breakoutData.breakoutDate) %></strong><% } else { %><span class="muted">-</span><% } %></div>
            <% if (qvaWatchData && qvaWatchData.positionStatusLabel) { %>
            <div>현재 위치 <strong style="color:#1e40af;"><%= qvaWatchData.positionStatusLabel %></strong></div>
            <% } %>
          </div>
        </div>
        <% } %>

        <% if (!hasAnyEvent) { %>
        <div style="background:#fef3c7;border-left:3px solid #f59e0b;padding:8px 10px;border-radius:6px;margin:6px;font-size:11px;color:#78350f;line-height:1.5;">
          ⚠️ 이 종목은 현재 QVA/VVI 이벤트가 연결되지 않아 기본 시세 차트만 표시합니다.
        </div>
        <% } %>

        <!-- 컨트롤: VVI 고가선 토글 (VVI 데이터 있을 때만) -->
        <% if (breakoutData && breakoutData.vviHigh) { %>
        <div style="padding:0 6px 6px;display:flex;gap:6px;flex-wrap:wrap;">
          <button id="toggle-vvi-high" type="button"
            style="background:#f1f5f9;color:#475569;border:1px solid #cbd5e1;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:500;cursor:pointer;"
            data-active="false">
            ◻ VVI 고가선 보기
          </button>
        </div>
        <% } %>

        <!-- 가격 캔들 차트 -->
        <div class="chart-price-wrap"><canvas id="priceChart"></canvas></div>

        <!-- 거래대금 -->
        <div id="value-chart-section">
          <div class="chart-sub-title">거래대금 <span style="font-weight:400;color:#94a3b8;">· 20일 평균선</span></div>
          <div class="chart-value-wrap"><canvas id="valueChart"></canvas></div>
        </div>

        <!-- 범례 — KB증권식 간결 -->
        <div class="chart-legend">
          <span><span class="dot" style="background:#10b981"></span>QVA</span>
          <span><span class="dot" style="background:#f59e0b"></span>VVI</span>
          <span><span class="dot" style="background:#dc2626"></span>돌파 성공</span>
          <span style="margin-left:8px;color:#bbb;">|</span>
          <span style="color:rgba(220,38,38,0.65);">━ MA5</span>
          <span style="color:rgba(37,99,235,0.65);">━ MA20</span>
          <span style="color:rgba(22,163,74,0.55);">━ MA60</span>
        </div>
        <div class="chart-legend" style="font-size:10px;color:#64748b;margin-top:-4px;border-top:1px dashed #e2e8f0;padding-top:6px;">
          <span title="당일 종가가 전일 종가보다 높음"><span class="dot" style="background:#dc2626"></span>상승일 거래대금</span>
          <span title="당일 종가가 전일 종가보다 낮음"><span class="dot" style="background:#2563eb"></span>하락일 거래대금</span>
          <span style="color:#94a3b8;">이벤트일은 초록(QVA) / 주황(VVI) / 빨강(돌파)으로 강조</span>
        </div>
      </div>
      <% } %>

      <!-- ============ 차트 아래 설명 ============ -->
      <% if (qvaEpisodes && qvaEpisodes.length > 0) { %>
      <div class="card" style="background:#f0fdf4;border-left:3px solid #10b981;">
        <div style="font-size:12px;line-height:1.7;color:#064e3b;">
          📌 QVA는 저점권에서 잔잔하던 거래량·거래대금이 직전 20일 흐름을 확실히 뛰어넘은 날을 가리킵니다.
          아직 대상승 전이라는 점이 핵심이며, 차트에서는 그 첫 신호일을 <strong>초록 동그라미</strong>로 표시합니다.
          같은 종목에 과거 QVA 흔적이 있었다면 옅은 색으로 함께 보여줍니다.
        </div>
      </div>
      <% } %>

      <!-- ============ 왜 QVA로 잡혔나 ============ -->
      <%
        var latestEp = (qvaEpisodes && qvaEpisodes.length > 0) ? qvaEpisodes[qvaEpisodes.length - 1] : null;
        var priorCount = qvaEpisodes ? Math.max(0, qvaEpisodes.length - 1) : 0;
        // 우선순위: episode 있으면 episode 기준 표시, 없으면 live earlyQvaData 기준 (둘 다 없으면 진단 박스)
        var eqWhy = latestEp ? latestEp.why : (earlyQvaData && earlyQvaData.passed ? earlyQvaData.why : null);
        var eqLabel = latestEp ? latestEp.firstSignalGradeLabel : (earlyQvaData && earlyQvaData.passed ? earlyQvaData.gradeLabel : null);
        var eqScore = latestEp ? latestEp.firstSignalScore : (earlyQvaData && earlyQvaData.passed ? earlyQvaData.score : null);
      %>
      <% if (eqWhy) { %>
      <div class="card why-card">
        <h2 style="color:#047857;"><i class="bi bi-question-circle me-1"></i>왜 QVA로 잡혔나</h2>
        <div style="background:#ecfdf5;border-left:3px solid #047857;padding:8px 12px;border-radius:6px;margin-bottom:10px;font-size:12px;line-height:1.7;color:#064e3b;">
          저점권에서 잔잔하던 거래량·거래대금을 크게 뛰어넘은 날입니다.
          아직 대상승 전 위치였기 때문에 QVA로 분류됩니다.
        </div>
        <div style="display:flex;gap:6px;align-items:baseline;margin-bottom:10px;flex-wrap:wrap;">
          <span class="badge badge-EARLY_QVA" style="padding:4px 10px;font-size:13px;font-weight:700;">
            <%= eqLabel %> · 점수 <%= eqScore %>
          </span>
        </div>

        <!-- 잡힌 날 vs 오늘 시점 상태 표시 -->
        <% if (latestEp) {
          function fmtD(d) { return d.slice(0,4)+'-'+d.slice(4,6)+'-'+d.slice(6,8); }
          var stillToday = latestEp.stillPassingToday;
          var daysSince = latestEp.daysSinceFirstSignal != null ? latestEp.daysSinceFirstSignal : 0;
          var statusBg = stillToday ? '#dcfce7' : '#fef3c7';
          var statusBorder = stillToday ? '#16a34a' : '#f59e0b';
          var statusColor = stillToday ? '#14532d' : '#78350f';
        %>
        <div style="background:<%= statusBg %>;border-left:3px solid <%= statusBorder %>;padding:9px 12px;border-radius:6px;margin-bottom:10px;font-size:12px;line-height:1.7;color:<%= statusColor %>;">
          <strong>📅 QVA 잡힌 날: <%= fmtD(latestEp.firstSignalDate) %></strong>
          <% if (daysSince === 0) { %> (오늘 신호) <% } else { %> · <%= daysSince %>거래일 경과 <% } %>
          <br>
          <% if (stillToday) { %>
            ✅ 오늘 시점에도 QVA 조건을 다시 만족합니다.
          <% } else { %>
            ⏳ 오늘 시점에서 다시 평가하면 조건을 다시 만족하지는 않지만(가격/거래대금이 변했음),
            잡힌 흐름은 추적 중입니다. <strong>아래 수치는 잡힌 날(<%= fmtD(latestEp.firstSignalDate) %>) 기준</strong>입니다.
          <% } %>
        </div>

        <div class="why-section" style="background:#ecfdf5;border-left-color:#047857;">
          <div class="why-section-title">📊 이번 QVA 흐름</div>
          <ul>
            <li>첫 신호: <strong><%= fmtD(latestEp.firstSignalDate) %></strong></li>
            <li>가장 강한 신호: <strong><%= fmtD(latestEp.bestSignalDate) %></strong> (점수 <%= latestEp.scoreMax %>)</li>
            <li>마지막 신호: <strong><%= fmtD(latestEp.lastSignalDate) %></strong></li>
            <li>지속: <strong><%= latestEp.durationDays %>거래일</strong>, <%= latestEp.signalCount %>회 발화</li>
            <li>최근 120일 내 이전 QVA 흐름: <strong><%= priorCount %>회</strong></li>
            <% if (latestEp.convertedToVvi) { %><li>✅ 이 흐름은 <strong>VVI까지 진행</strong>됨</li><% } %>
            <% if (latestEp.convertedToBreakout) { %><li>🔥 이 흐름은 <strong>돌파 성공까지 진행</strong>됨</li><% } %>
          </ul>
        </div>
        <% } %>

        <% eqWhy.forEach(function(section, i) { %>
          <div class="why-section">
            <div class="why-section-title"><%= i+1 %>. <%= section.icon %> <%= section.title %></div>
            <ul>
              <% section.items.forEach(function(it) { %>
                <li><%= it %></li>
              <% }); %>
            </ul>
          </div>
        <% }); %>

        <!-- 단계 타임라인 -->
        <% if (latestEp && (latestEp.convertedToVvi || latestEp.convertedToBreakout)) {
          function fmtD2(d) { return d.slice(0,4)+'-'+d.slice(4,6)+'-'+d.slice(6,8); }
          function daysBetween(a, b) {
            const ai = chartData ? null : null; // not available server-side easily
            return null;
          }
        %>
        <div class="why-section" style="background:#fff;border:1px solid #e2e8f0;border-left:3px solid #94a3b8;">
          <div class="why-section-title">🛤️ 단계 타임라인</div>
          <div style="font-size:12px;line-height:1.9;color:#0f172a;font-family:monospace;">
            🟢 QVA 발생 &nbsp;&nbsp;&nbsp;&nbsp;<%= fmtD2(latestEp.firstSignalDate) %><br>
            &nbsp;&nbsp;↓<br>
            <% if (latestEp.vviDate) { %>
            ⏳ VVI 발생 &nbsp;&nbsp;&nbsp;&nbsp;<%= fmtD2(latestEp.vviDate) %><br>
            &nbsp;&nbsp;↓<br>
            <% } %>
            <% if (latestEp.breakoutDate) { %>
            🔥 돌파 성공 &nbsp;&nbsp;&nbsp;<%= fmtD2(latestEp.breakoutDate) %><br>
            <% } %>
          </div>
        </div>
        <% } %>

        <!-- 도움말: QVA는 어떤 신호인가 -->
        <div style="background:#eff6ff;border-left:3px solid #3b82f6;padding:8px 12px;border-radius:6px;margin-top:10px;font-size:11px;line-height:1.7;color:#1e3a8a;">
          💡 QVA는 저점권에서 기존 거래량·거래대금을 확실히 뛰어넘는 수급 흔적이 나타난 관심 후보입니다.
          다만 과거에 이미 크게 급등한 뒤 무너진 종목의 잔파동은 제외합니다.
          매수 신호가 아니라 관심 후보를 찾기 위한 단계입니다.
          차트의 QVA일은 그 흐름이 <strong>처음 시작된 날(firstSignalDate)</strong>입니다.
        </div>

        <!-- 도움말: QVA → VVI → 돌파 흐름 -->
        <div style="background:#fef3c7;border-left:3px solid #f59e0b;padding:8px 12px;border-radius:6px;margin-top:8px;font-size:11px;line-height:1.7;color:#78350f;">
          ⚠️ <strong>관심 후보 → 확인 단계</strong> 흐름입니다.
          QVA는 관심 후보 시작점, VVI는 거래대금이 더 강하게 확인된 단계, 돌파 성공은 VVI 다음날 고가를 1% 이상 돌파하고 종가가 유지된 후속 확인 후보입니다.
          최종 판단은 사용자가 직접 합니다.
        </div>

        <!-- 디버그 폴드: episode 상세 + dayBefore reject 사유 + 윈도우 상수 -->
        <% if (qvaWindows || latestEp) { %>
        <details style="margin-top:8px;font-size:11px;color:#64748b;">
          <summary style="cursor:pointer;color:#2563eb;">🔧 디버그 — QVA 날짜 결정 로직</summary>
          <% if (latestEp) {
            function dbg(d) { return d ? d.slice(0,4)+'-'+d.slice(4,6)+'-'+d.slice(6,8) : '-'; }
          %>
          <div style="background:#f8fafc;padding:8px 10px;border-radius:4px;margin-top:4px;font-family:monospace;line-height:1.7;">
            <strong>이번 episode</strong><br>
            firstSignalDate: <%= dbg(latestEp.firstSignalDate) %><br>
            bestSignalDate: <%= dbg(latestEp.bestSignalDate) %><br>
            lastSignalDate: <%= dbg(latestEp.lastSignalDate) %><br>
            episodeStart: <%= dbg(latestEp.firstSignalDate) %><br>
            episodeEnd: <%= dbg(latestEp.lastSignalDate) %><br>
            firstSignalScore: <%= latestEp.firstSignalScore %> / 100<br>
            bestSignalScore: <%= latestEp.bestScore %> / 100<br>
            signalCount: <%= latestEp.signalCount %>회<br>
            durationDays: <%= latestEp.durationDays %>거래일<br>
            whyDisplayedDateChosen: 화면/표 기본 표시는 firstSignalDate (최초 포착일) 기준
          </div>
          <% if (latestEp.dayBeforeChecks && latestEp.dayBeforeChecks.length > 0) { %>
          <div style="margin-top:6px;background:#fef3c7;padding:8px 10px;border-radius:4px;font-family:monospace;line-height:1.7;font-size:10px;color:#78350f;">
            <strong>왜 더 일찍 안 잡혔나? (firstSignalDate 직전 7일 reject 사유)</strong><br>
            <% latestEp.dayBeforeChecks.forEach(function(c) { %>
              [D-<%= c.daysBefore %>] <%= dbg(c.date) %> · score=<%= c.score %> · <%= c.passed ? '✅ passed' : '❌' %><br>
              <% if (!c.passed && c.excludeReasons.length > 0) { %>
                &nbsp;&nbsp;&nbsp;&nbsp;<%= c.excludeReasons.slice(0, 3).join(' / ') %><br>
              <% } %>
            <% }); %>
          </div>
          <% } %>
          <% } %>
          <% if (qvaWindows) { %>
          <div style="background:#f8fafc;padding:8px 10px;border-radius:4px;margin-top:6px;font-family:monospace;line-height:1.7;">
            <strong>QVA 기준 기간 상수</strong><br>
            qvaCoreWindow = <%= qvaWindows.qvaCoreWindow %><br>
            qvaContextWindow = <%= qvaWindows.qvaContextWindow %><br>
            qvaEpisodeMergeWindow = <%= qvaWindows.qvaEpisodeMergeWindow %><br>
            qvaTrackingWindow = <%= qvaWindows.qvaTrackingWindow %>
          </div>
          <div style="margin-top:6px;line-height:1.6;">
            QVA의 핵심 판단은 최근 20거래일 흐름을 기준으로 합니다.
            너무 짧으면 잡음이 많아지고, 너무 길면 신호가 늦어질 수 있기 때문입니다.
            대신 더 큰 자리 판단을 위해 60거래일 배경 흐름도 함께 참고합니다.
          </div>
          <% } %>
        </details>
        <% } %>
      </div>
      <% } else if (earlyQvaData && !earlyQvaData.passed && (!qvaEpisodes || qvaEpisodes.length === 0)) { %>
      <!-- episode 없음 + 오늘도 만족 안함 → 이 종목은 최근 QVA 흔적 자체가 없음 -->
      <div class="card">
        <h2 style="color:#475569;"><i class="bi bi-question-circle me-1"></i>QVA 진단</h2>
        <div style="font-size:13px;color:#64748b;margin-bottom:6px;">이 종목은 최근 120거래일 안에 QVA 신호가 잡힌 적이 없고, 오늘 시점에도 QVA 조건을 만족하지 않습니다.</div>
        <% if (earlyQvaData.excludeReasons && earlyQvaData.excludeReasons.length > 0) { %>
        <details style="font-size:12px;color:#64748b;">
          <summary style="cursor:pointer;color:#2563eb;">오늘 시점 제외 사유 보기</summary>
          <ul style="margin-top:4px;padding-left:18px;">
            <% earlyQvaData.excludeReasons.forEach(function(r) { %><li><%= r %></li><% }); %>
          </ul>
        </details>
        <% } %>
      </div>
      <% } %>

      <!-- ============ AI 뉴스·공시 분석 ============ -->
      <% if (materialAnalysis && !materialAnalysis.error) { var ma = materialAnalysis; %>
      <div class="card ai-card">
        <h2><i class="bi bi-newspaper me-1"></i>AI 뉴스·공시 분석</h2>

        <!-- 메타 배지 -->
        <% if (ma.materialType || ma.materialStrength || ma.freshness) { %>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;">
          <% if (ma.materialType) { %><span class="ai-badge ai-type"><%= ma.materialType %></span><% } %>
          <% if (ma.materialStrength) {
              var sCls = ma.materialStrength === '강함' ? 'ai-strong-h' : (ma.materialStrength === '약함' ? 'ai-strong-l' : 'ai-strong-m');
          %><span class="ai-badge <%= sCls %>">강도 <%= ma.materialStrength %></span><% } %>
          <% if (ma.freshness) { %><span class="ai-badge ai-fresh"><%= ma.freshness %></span><% } %>
        </div>
        <% } %>

        <!-- 핵심 재료 한 줄 -->
        <% if (ma.keyMaterial) { %>
          <div style="font-size:14px;font-weight:700;color:#1e40af;background:#eff6ff;padding:10px 12px;border-radius:6px;border-left:3px solid #3b82f6;line-height:1.55;">
            💡 <%= ma.keyMaterial %>
          </div>
        <% } %>

        <!-- 뉴스 요약 -->
        <% if (ma.newsSummary) { %>
          <h3 style="font-size:12px;color:#475569;margin:12px 0 4px 0;font-weight:600;">📰 뉴스 요약</h3>
          <div style="font-size:13px;line-height:1.7;color:#1e293b;background:#f8fafc;padding:8px 12px;border-radius:6px;">
            <%= ma.newsSummary %>
          </div>
        <% } %>

        <!-- 공시 요약 -->
        <% if (ma.disclosureSummary && ma.disclosureSummary !== '해당 없음') { %>
          <h3 style="font-size:12px;color:#475569;margin:12px 0 4px 0;font-weight:600;">📋 공시 요약</h3>
          <div style="font-size:13px;line-height:1.7;color:#1e293b;background:#f8fafc;padding:8px 12px;border-radius:6px;">
            <%= ma.disclosureSummary %>
          </div>
        <% } %>

        <!-- 가격-재료 연결 해석 -->
        <% if (ma.priceReaction) { %>
          <h3 style="font-size:12px;color:#475569;margin:12px 0 4px 0;font-weight:600;">📈 가격 반응 해석</h3>
          <div style="font-size:13px;line-height:1.7;color:#1e293b;background:#f8fafc;padding:8px 12px;border-radius:6px;">
            <%= ma.priceReaction %>
          </div>
        <% } %>

        <!-- 리스크 -->
        <% if (ma.risks && ma.risks.length > 0) { %>
          <h3 style="font-size:12px;color:#92400e;margin:12px 0 4px 0;font-weight:600;">⚠️ 리스크</h3>
          <ul style="margin:0;padding-left:18px;font-size:13px;line-height:1.7;color:#78350f;">
            <% ma.risks.forEach(function(r) { %>
              <li><%= r %></li>
            <% }); %>
          </ul>
        <% } %>

        <!-- 한 줄 결론 -->
        <% if (ma.oneLineConclusion) { %>
          <div style="margin-top:12px;background:#fef3c7;color:#78350f;padding:10px 12px;border-radius:6px;border-left:3px solid #f59e0b;font-size:13px;font-weight:600;line-height:1.55;">
            🎯 <%= ma.oneLineConclusion %>
          </div>
        <% } %>

        <!-- 출처 -->
        <% if (ma.sources && ma.sources.length > 0) { %>
          <h3 style="font-size:11px;color:#94a3b8;margin:10px 0 4px 0;font-weight:600;">출처</h3>
          <div style="font-size:11px;line-height:1.7;color:#64748b;">
            <% ma.sources.forEach(function(s, i) {
              var isUrl = typeof s === 'string' && s.match(/^https?:\/\//);
            %>
              <% if (isUrl) { %>
                <a href="<%= s %>" target="_blank" rel="noopener" style="color:#2563eb;text-decoration:none;display:block;word-break:break-all;">[<%= i+1 %>] <%= s %></a>
              <% } else { %>
                <span style="display:block;">[<%= i+1 %>] <%= s %></span>
              <% } %>
            <% }); %>
          </div>
        <% } %>

        <div class="ai-footnote">
          ※ 자동 수집된 공개 정보 기반. 정확성은 출처에서 직접 확인.
          <% if (ma.cached) { %>· <span style="color:#10b981;">캐시</span><% } %>
          <% if (ma.generatedAt) { %>· <%= new Date(ma.generatedAt).toLocaleString('ko-KR') %><% } %>
          <% if (ma.model) { %>· <%= ma.model %><% } %>
        </div>
      </div>
      <% } else if (materialAnalysis && materialAnalysis.error) { %>
      <div class="card">
        <h2><i class="bi bi-newspaper me-1"></i>AI 뉴스·공시 분석</h2>
        <div class="empty-state">분석 호출 중 오류: <%= materialAnalysis.error %></div>
      </div>
      <% } else { %>
      <div class="card">
        <h2><i class="bi bi-newspaper me-1"></i>AI 뉴스·공시 분석</h2>
        <div class="empty-state">AI 분석 데이터가 없습니다 (GEMINI_API_KEY 설정 또는 캐시 확인 필요).</div>
      </div>
      <% } %>

      <!-- ============ 하단 주의 ============ -->
      <div class="footer-disclaimer">
        <strong>⚠️ 매수 추천이 아닙니다.</strong> 이 화면은 차트 흐름과 공개 뉴스·공시를 바탕으로 후보를 이해하기 위한 참고 정보입니다. 실제 판단은 사용자가 직접 해야 합니다.
      </div>

      <!-- 차트 데이터 + Chart.js 초기화 (캔들 + annotation + episode 박스) -->
      <% if (chartRows && chartRows.length > 0) { %>
      <script>
        const chartData = <%- JSON.stringify(chartRows) %>;
        const breakout = <%- JSON.stringify(breakoutData || {}) %>;
        const qvaEpisodes = <%- JSON.stringify(qvaEpisodes || []) %>;
        const qvaWindows = <%- JSON.stringify(qvaWindows || {}) %>;
        const earlyQvaSignals = <%- JSON.stringify(earlyQvaData && earlyQvaData.signals ? earlyQvaData.signals : null) %>;
        const earlyQvaScore = <%- JSON.stringify(earlyQvaData ? earlyQvaData.score : null) %>;
        const vviDate = <%- JSON.stringify(breakoutData ? breakoutData.vviDate : null) %>;
        const breakoutDate = <%- JSON.stringify(breakoutData ? breakoutData.breakoutDate : null) %>;

        function fmtChartDate(d) {
          if (!d || d.length !== 8) return d;
          return d.slice(0,4) + '-' + d.slice(4,6) + '-' + d.slice(6,8);
        }
        // YYYYMMDD → ms epoch
        function toEpoch(d) {
          if (!d || d.length !== 8) return null;
          return new Date(+d.slice(0,4), +d.slice(4,6) - 1, +d.slice(6,8)).getTime();
        }

        // 최근 120일만 기본 표시 (사용자 spec: 기본 120, 추후 60/120/250 토글)
        const DEFAULT_DAYS = 120;
        const sliceStart = Math.max(0, chartData.length - DEFAULT_DAYS);
        const view = chartData.slice(sliceStart);

        const labels = view.map(r => fmtChartDate(r.date));
        // 한국식 캔들 — 전일 종가 대비 상승/하락 기준으로 색이 칠해지도록
        // chartjs-chart-financial 0.2.1은 close vs open 비교로 색을 결정.
        // 우리는 close vs prevClose 비교를 원하므로, candle 데이터의 open을 prevClose로 강제.
        // (실제 시가는 candleOriginalOpen에 따로 보관해 툴팁에서 표시)
        const candleData = view.map((r, i) => {
          const prev = i > 0 ? view[i - 1].close : r.open;
          return { x: toEpoch(r.date), o: prev, h: r.high, l: r.low, c: r.close };
        });
        const candleOriginalOpen = view.map(r => r.open);
        const closes = view.map(r => r.close);
        const ma5 = view.map((r, i) => ({ x: toEpoch(r.date), y: r.ma5 }));
        const ma20 = view.map((r, i) => ({ x: toEpoch(r.date), y: r.ma20 }));
        const ma60 = view.map((r, i) => ({ x: toEpoch(r.date), y: r.ma60 }));
        const volumes = view.map(r => ({ x: toEpoch(r.date), y: r.volume || 0 }));
        const values = view.map(r => ({ x: toEpoch(r.date), y: r.valueApprox || (r.close * (r.volume || 0)) }));

        // 거래량/거래대금 5일/20일 평균
        function smaArr(arr, period) {
          const out = arr.map(v => null);
          for (let i = period - 1; i < arr.length; i++) {
            let s = 0;
            for (let j = i - period + 1; j <= i; j++) s += arr[j];
            out[i] = s / period;
          }
          return out;
        }
        const volSma5 = smaArr(view.map(r => r.volume || 0), 5).map((v, i) => ({ x: toEpoch(view[i].date), y: v }));
        const volSma20 = smaArr(view.map(r => r.volume || 0), 20).map((v, i) => ({ x: toEpoch(view[i].date), y: v }));
        const valSma5 = smaArr(view.map(r => r.valueApprox || 0), 5).map((v, i) => ({ x: toEpoch(view[i].date), y: v }));
        const valSma20 = smaArr(view.map(r => r.valueApprox || 0), 20).map((v, i) => ({ x: toEpoch(view[i].date), y: v }));

        // 한국식 캔들 색 (chartjs-chart-financial v0.2.1 quirk: 라이브러리는
        //   close<open(음봉) → backgroundColors.up
        //   close>open(양봉) → backgroundColors.down
        // 으로 키 의미가 트레이더 관습과 반대다. 한국식(양봉=빨강, 음봉=파랑)을 만들려면
        // up=파랑, down=빨강 으로 넣어야 한다.
        const KO_RED = '#dc2626';   // 양봉 (close > open)
        const KO_BLUE = '#2563eb';  // 음봉 (close < open)
        const KO_GRAY = '#94a3b8';  // 보합
        const candleColorMap = { up: KO_BLUE, down: KO_RED, unchanged: KO_GRAY };

        // QVA episode firstSignalDate 셋 — episode당 firstSignalDate 1개만 강조
        // (사용자 spec: 같은 흐름에서 후속 발화는 별도 신호로 표시하지 않음)
        const qvaFirstDates = new Set();
        qvaEpisodes.forEach(ep => {
          qvaFirstDates.add(ep.firstSignalDate);
        });

        // 거래대금 색: 이벤트일 강조 (QVA=진초록, VVI=주황, 돌파=빨강)
        function eventBarColor(date, baseUp, baseDown, prevClose, close) {
          if (qvaFirstDates.has(date)) return '#10b981';
          if (date === vviDate) return '#f59e0b';
          if (date === breakoutDate) return '#dc2626';
          return close >= prevClose ? baseUp : baseDown;
        }
        function eventBarBorder(date) {
          if (qvaFirstDates.has(date) || date === vviDate || date === breakoutDate) return '#0f172a';
          return 'transparent';
        }
        function eventBarBorderWidth(date) {
          return (qvaFirstDates.has(date) || date === vviDate || date === breakoutDate) ? 1.5 : 0;
        }
        // 거래대금 막대 — 한국식: 전일 종가 대비 상승=빨강, 하락=파랑 (KB증권식 alpha 0.65)
        const valueColors = view.map((r, i) => {
          const prev = i > 0 ? view[i - 1].close : r.close;
          return eventBarColor(r.date, 'rgba(220,38,38,0.65)', 'rgba(37,99,235,0.65)', prev, r.close);
        });
        const valueBorders = view.map(r => eventBarBorder(r.date));
        const valueBorderWidths = view.map(r => eventBarBorderWidth(r.date));

        // 이벤트 인덱스 + epoch
        function findIdx(date) { return date ? view.findIndex(r => r.date === date) : -1; }
        const vviIdx = findIdx(vviDate);
        const breakoutIdx = findIdx(breakoutDate);
        const vviEpoch = toEpoch(vviDate);
        const breakoutEpoch = toEpoch(breakoutDate);

        // 가격 차트 annotation 빌드 (단순화: 시그널은 점으로, 세로선/날짜라벨/박스 모두 토글로 이동)
        const priceAnnotations = {};

        // 차트 view 구간(최근 120일) 안의 episode만 활용 (점/박스 동기화)
        const viewFirstDate = view.length > 0 ? view[0].date : null;
        const visibleEpisodes = qvaEpisodes.filter(ep => ep.lastSignalDate >= viewFirstDate);

        // ─── episode 박스는 표시하지 않음 (사용자 요청: 세로선/구간 박스 제거) ───
        // visibleEpisodes는 시그널 마커 위치 계산에만 사용

        // ─── 토글: VVI 고가선 (기본 OFF, 흐리게) ───
        if (breakout.vviHigh) {
          priceAnnotations.vviHighLine = {
            type: 'line', yMin: breakout.vviHigh, yMax: breakout.vviHigh,
            borderColor: 'rgba(245,158,11,0.30)', borderWidth: 1, borderDash: [3, 3],
            display: false,
          };
        }

        // ─── 기준 진입가 (KB식 보조선처럼 옅게) ───
        if (breakout.breakoutEntryPrice1Pct) {
          priceAnnotations.entryLine = {
            type: 'line', yMin: breakout.breakoutEntryPrice1Pct, yMax: breakout.breakoutEntryPrice1Pct,
            borderColor: 'rgba(59,130,246,0.30)', borderWidth: 1, borderDash: [3, 4],
            label: { display: true, content: '기준 진입가', position: 'end',
                     backgroundColor: 'rgba(59,130,246,0.55)', color: 'white',
                     font: { size: 9 }, padding: { top: 1, bottom: 1, left: 4, right: 4 }, borderRadius: 3 }
          };
        }

        // ─── 시그널 마커 — annotation point (작은 컬러 점, 흰 테두리) ───
        // QVA = 캔들 아래쪽 / VVI/돌파 = 캔들 위쪽

        // QVA — firstSignalDate (최근 진하게, 과거 연하게)
        visibleEpisodes.forEach((ep, i) => {
          const isLatest = ep.isLatest;
          const fRow = view.find(r => r.date === ep.firstSignalDate);
          if (fRow) {
            priceAnnotations['ep' + i + 'First'] = {
              type: 'point',
              xValue: toEpoch(ep.firstSignalDate),
              yValue: fRow.low,
              backgroundColor: isLatest ? '#10b981' : 'rgba(134,239,172,0.7)',
              borderColor: 'white',
              borderWidth: 1,
              radius: isLatest ? 6 : 5,
              yAdjust: 12,  // 캔들 아래쪽
              z: 10,
            };
          }
        });

        // VVI 점 (주황) — 캔들 위
        if (vviDate) {
          const vRow = view.find(r => r.date === vviDate);
          if (vRow) {
            priceAnnotations.vviPoint = {
              type: 'point',
              xValue: toEpoch(vviDate),
              yValue: vRow.high,
              backgroundColor: '#f59e0b',
              borderColor: 'white',
              borderWidth: 1,
              radius: 6,
              yAdjust: -12,
              z: 10,
            };
          }
        }

        // 돌파 성공 점 (빨강) — 캔들 위
        if (breakoutDate) {
          const brRow = view.find(r => r.date === breakoutDate);
          if (brRow) {
            priceAnnotations.breakoutPoint = {
              type: 'point',
              xValue: toEpoch(breakoutDate),
              yValue: brRow.high,
              backgroundColor: '#dc2626',
              borderColor: 'white',
              borderWidth: 1,
              radius: 6,
              yAdjust: -12,
              z: 10,
            };
          }
        }

        // ─── 가격 차트 (KB증권식 일봉 차트) ───
        const priceCtx = document.getElementById('priceChart').getContext('2d');
        const priceChart = new Chart(priceCtx, {
          type: 'candlestick',
          data: {
            datasets: [
              {
                label: '일봉',
                data: candleData,
                // chartjs-chart-financial 0.2.1 quirk:
                //   close < open(open=prevClose) → backgroundColors.up   = 음봉/하락 = 파랑
                //   close > open(open=prevClose) → backgroundColors.down = 양봉/상승 = 빨강
                backgroundColors: candleColorMap,
                borderColors: candleColorMap,
                borderWidth: 1,
                // KB증권식: 캔들 본체 살짝 좁게 (간격 띄우기)
                categoryPercentage: 0.85,
                barPercentage: 0.7,
                order: 10,
              },
              // MA — 흐리게 (opacity 0.40) + 1.2px
              { label: 'MA5', type: 'line', data: ma5,
                borderColor: 'rgba(220,38,38,0.40)', borderWidth: 1.2, pointRadius: 0, order: 5, parsing: false, tension: 0 },
              { label: 'MA20', type: 'line', data: ma20,
                borderColor: 'rgba(37,99,235,0.40)', borderWidth: 1.2, pointRadius: 0, order: 4, parsing: false, tension: 0 },
              { label: 'MA60', type: 'line', data: ma60,
                borderColor: 'rgba(22,163,74,0.35)', borderWidth: 1.2, pointRadius: 0, order: 3, parsing: false, tension: 0 },
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: { display: false },
              annotation: { annotations: priceAnnotations },
              tooltip: {
                backgroundColor: 'rgba(15,23,42,0.95)',
                titleColor: '#f1f5f9',
                bodyColor: '#e2e8f0',
                borderColor: '#334155',
                borderWidth: 1,
                padding: 10,
                callbacks: {
                  title: function(items) {
                    if (!items.length) return '';
                    const ts = items[0].parsed.x;
                    const d = new Date(ts);
                    return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
                  },
                  label: function(item) {
                    // MA 라인은 숨김 (값만 보여줘서 산만함)
                    if (item.dataset.label && item.dataset.label.startsWith('MA')) return null;
                    if (item.dataset.label === '일봉') {
                      const r = item.raw;
                      const ts = r.x;
                      const idx = view.findIndex(rr => toEpoch(rr.date) === ts);
                      if (idx < 0) return null;
                      const row = view[idx];
                      const realOpen = candleOriginalOpen[idx];   // 실제 시가 (변형 전)
                      const prevClose = idx > 0 ? view[idx - 1].close : null;
                      const changeRate = prevClose ? ((row.close / prevClose - 1) * 100).toFixed(2) : null;
                      const changeAmt = prevClose ? (row.close - prevClose) : null;
                      const sign = changeAmt > 0 ? '▲' : changeAmt < 0 ? '▼' : '─';
                      const lines = [
                        '시  ' + realOpen.toLocaleString() + '원',
                        '고  ' + row.high.toLocaleString() + '원',
                        '저  ' + row.low.toLocaleString() + '원',
                        '종  ' + row.close.toLocaleString() + '원',
                      ];
                      if (changeRate !== null) {
                        lines.push('전일대비 ' + sign + ' ' + (changeAmt > 0 ? '+' : '') + Math.abs(changeAmt).toLocaleString() + '원 (' + (changeRate > 0 ? '+' : '') + changeRate + '%)');
                      }
                      if (row.volume) {
                        const vol = row.volume;
                        lines.push('거래량   ' + (vol >= 1e4 ? (vol/1e4).toFixed(0) + '만주' : vol.toLocaleString() + '주'));
                      }
                      if (row.valueApprox) {
                        const val = row.valueApprox;
                        lines.push('거래대금 ' + (val >= 1e8 ? (val/1e8).toFixed(1) + '억' : (val/1e4).toFixed(0) + '만') + '원');
                      }
                      return lines;
                    }
                    return null;
                  },
                  afterBody: function(items) {
                    if (!items.length) return '';
                    const ts = items[0].parsed.x;
                    const lines = [];
                    const tsDateStr = (function(){
                      const d = new Date(ts);
                      return d.getFullYear() + String(d.getMonth()+1).padStart(2,'0') + String(d.getDate()).padStart(2,'0');
                    })();
                    // QVA — episode firstSignalDate (간결하게)
                    for (const ep of visibleEpisodes) {
                      if (ep.firstSignalDate === tsDateStr) {
                        lines.push('');
                        lines.push('● QVA  점수 ' + ep.scoreMax + '/100');
                        if (earlyQvaSignals && ep.isLatest) {
                          if (earlyQvaSignals.valueRatioMedian != null) {
                            lines.push('  거래대금 ×' + earlyQvaSignals.valueRatioMedian.toFixed(1) + ' (20일 중앙값)');
                          }
                          lines.push('  20일 저점 대비 +' + earlyQvaSignals.returnFromLow20.toFixed(1) + '%');
                        }
                        lines.push('  저점권에서 기존 거래량·거래대금을 뛰어넘은 관심 후보');
                        break;
                      }
                    }
                    if (ts === vviEpoch && breakout.vviHigh) {
                      lines.push('');
                      lines.push('● VVI');
                      lines.push('  VVI 고가 ' + breakout.vviHigh.toLocaleString() + '원');
                      if (breakout.vviHigh && breakout.vviClose && breakout.vviLow) {
                        const loc = ((breakout.vviClose - breakout.vviLow) / (breakout.vviHigh - breakout.vviLow) * 100).toFixed(0);
                        lines.push('  종가 위치 ' + loc + '%');
                      }
                      lines.push('  거래대금이 강하게 붙은 확인 단계');
                    }
                    if (ts === breakoutEpoch) {
                      lines.push('');
                      lines.push('● 돌파 성공');
                      if (breakout.breakoutEntryPrice1Pct) lines.push('  기준가 ' + Math.round(breakout.breakoutEntryPrice1Pct).toLocaleString() + '원');
                      lines.push('  종가 유지: ' + (breakout.breakoutSuccess ? '예' : '아니오'));
                    }
                    return lines;
                  }
                }
              }
            },
            scales: {
              y: {
                position: 'right',     // KB증권식: 가격 축은 오른쪽
                ticks: {
                  callback: v => v.toLocaleString(),
                  font: { size: 10 },
                  color: '#777',
                  padding: 4,
                },
                grid: { color: '#f1f3f5', drawBorder: false }
              },
              x: {
                type: 'time',
                time: { unit: 'month', displayFormats: { month: 'yy-MM' } },
                ticks: { display: false },
                grid: { display: false, drawBorder: false }
              }
            }
          }
        });

        // ─── 거래량 차트 — 사용자 spec에 따라 별도 차트 제거 (가격 차트 툴팁에서만 표시) ───
        // (volumeChart canvas는 마크업에서 제거됨)

        // ─── 거래대금 차트 (KB증권식 단순화) ───
        const valueCtx = document.getElementById('valueChart').getContext('2d');
        new Chart(valueCtx, {
          data: {
            datasets: [
              { type: 'bar', label: '거래대금', data: values,
                backgroundColor: valueColors,
                borderColor: valueBorders,
                borderWidth: valueBorderWidths,
                categoryPercentage: 0.85,
                barPercentage: 0.7,
                parsing: false, order: 10 },
              { type: 'line', label: '20일 평균', data: valSma20,
                borderColor: 'rgba(37,99,235,0.35)', borderWidth: 1, pointRadius: 0, parsing: false, order: 1, tension: 0 },
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: 'rgba(15,23,42,0.95)',
                titleColor: '#f1f5f9',
                bodyColor: '#e2e8f0',
                borderColor: '#334155',
                borderWidth: 1,
                padding: 10,
                callbacks: {
                  title: function(items) {
                    if (!items.length) return '';
                    const ts = items[0].parsed.x;
                    const d = new Date(ts);
                    return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
                  },
                  label: function(item) {
                    const v = item.parsed.y;
                    if (v == null) return null;
                    const s = v >= 1e8 ? (v/1e8).toFixed(2) + '억' : v >= 1e4 ? (v/1e4).toFixed(0) + '만' : v.toLocaleString();
                    const lines = [item.dataset.label + ': ' + s + '원'];
                    // 막대 색상 의미 부연 (이벤트일이 아닌 경우 한국식 상승/하락 거래대금)
                    if (item.dataset.label === '거래대금') {
                      const ts = item.parsed.x;
                      const row = view.find(r => toEpoch(r.date) === ts);
                      if (row) {
                        const idx = view.indexOf(row);
                        const prev = idx > 0 ? view[idx - 1].close : row.close;
                        if (qvaFirstDates.has(row.date)) lines.push('🟢 QVA 강조일');
                        else if (row.date === vviDate) lines.push('🟠 VVI 강조일');
                        else if (row.date === breakoutDate) lines.push('🔴 돌파 성공일');
                        else if (row.close > prev) lines.push('🔴 양봉/상승일 거래대금');
                        else if (row.close < prev) lines.push('🔵 음봉/하락일 거래대금');
                        else lines.push('⚪ 보합 거래대금');
                      }
                    }
                    return lines;
                  }
                }
              }
            },
            scales: {
              y: {
                position: 'right',
                ticks: {
                  callback: v => {
                    if (v >= 1e8) return (v/1e8).toFixed(0) + '억';
                    if (v >= 1e4) return (v/1e4).toFixed(0) + '만';
                    return v.toLocaleString();
                  },
                  font: { size: 9 },
                  color: '#777',
                  padding: 4,
                  maxTicksLimit: 4,
                },
                grid: { color: '#f1f3f5', drawBorder: false }
              },
              x: {
                type: 'time',
                time: { unit: 'month', displayFormats: { month: 'yy-MM' } },
                ticks: { font: { size: 9 }, color: '#777', maxRotation: 0, autoSkip: true, maxTicksLimit: 6 },
                grid: { display: false, drawBorder: false }
              }
            }
          }
        });
      </script>

      <script>
        // 토글 — VVI 고가선 ON/OFF
        const vviToggleBtn = document.getElementById('toggle-vvi-high');
        if (vviToggleBtn) {
          vviToggleBtn.addEventListener('click', () => {
            const active = vviToggleBtn.dataset.active === 'true';
            const next = !active;
            vviToggleBtn.dataset.active = next ? 'true' : 'false';
            vviToggleBtn.textContent = (next ? '☑ ' : '◻ ') + 'VVI 고가선 보기';
            vviToggleBtn.style.background = next ? '#fed7aa' : '#f1f5f9';
            vviToggleBtn.style.color = next ? '#9a3412' : '#475569';
            const ann = priceChart.options.plugins.annotation.annotations.vviHighLine;
            if (ann) {
              ann.display = next;
              if (next) {
                ann.label = { display: true, content: 'VVI 고가 ' + breakout.vviHigh.toLocaleString(), position: 'start', backgroundColor: '#f59e0b', color: 'white', font: { size: 9 }, padding: 2, borderRadius: 3 };
              }
              priceChart.update();
            }
          });
        }

        // 차트 갱신 버튼
        const refreshBtn = document.getElementById('refresh-chart-btn');
        const refreshStatus = document.getElementById('refresh-status');
        if (refreshBtn) {
          refreshBtn.addEventListener('click', async () => {
            const code = refreshBtn.dataset.code;
            refreshBtn.disabled = true;
            refreshBtn.style.opacity = '0.6';
            refreshStatus.style.display = 'block';
            refreshStatus.style.color = '#94a3b8';
            refreshStatus.textContent = '⏳ KIS API에서 최신 일봉을 받아오는 중... (최대 10초)';
            try {
              const r = await fetch('/refresh-chart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code }),
              });
              const data = await r.json();
              if (!r.ok || !data.ok) {
                refreshStatus.style.color = '#dc2626';
                refreshStatus.textContent = '⚠️ 갱신 실패: ' + (data.error || r.statusText);
                refreshBtn.disabled = false;
                refreshBtn.style.opacity = '1';
                return;
              }
              const latest = data.latestDate;
              const dateLabel = latest ? latest.slice(0,4)+'-'+latest.slice(4,6)+'-'+latest.slice(6,8) : '-';
              refreshStatus.style.color = '#047857';
              refreshStatus.textContent = '✅ 갱신 완료 — 최신 ' + dateLabel + ' (신규 ' + (data.addedDays||0) + '일, 수정 ' + (data.updatedDays||0) + '일). 잠시 후 페이지를 새로 고칩니다...';
              setTimeout(() => window.location.reload(), 800);
            } catch (e) {
              refreshStatus.style.color = '#dc2626';
              refreshStatus.textContent = '⚠️ 네트워크 오류: ' + (e.message || e);
              refreshBtn.disabled = false;
              refreshBtn.style.opacity = '1';
            }
          });
        }
      </script>
      <% } %>

    <% } else if (!error) { %>
      <div class="card">
        <div class="empty-state">검색 후 종목 차트와 AI 분석을 볼 수 있습니다.</div>
      </div>
    <% } %>

  </div>
</body>
</html>
