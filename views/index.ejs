            <h2 class="section-title mb-2"><i class="bi bi-shield-check"></i>안전 매수가 추천</h2>
            <span style="display: inline-block; padding: 4px 12px; border-radius: 999px; background: <%= _gradeBg %>; color: <%= _gradeFg %>; font-size: 0.95rem; font-weight: 700;">
              <%= _safeBuy?.grade || '관망' %>
            </span>
          </div>
          <% if (_safeBuy && _safeBuy.price) { %>
            <div class="text-end">
              <div class="muted-text small">매수가</div>
              <div style="font-size: 1.6rem; font-weight: 700; color: #0f172a;"><%= fmtNumber(_safeBuy.price) %>원</div>
              <div class="muted-text small">현재가 -<%= _safeBuy.gapPct %>%</div>
            </div>
          <% } %>
        </div>
        <% if (_safeBuy && _safeBuy.price) { %>
          <div class="row g-3 mb-2">
            <div class="col-md-4">
              <div class="metric-card p-2" style="background: #fff;">
                <div class="metric-label small">손절선</div>
                <div style="font-size: 1.1rem; font-weight: 700; color: #991b1b;"><%= fmtNumber(_safeBuy.stopLoss) %>원</div>
                <div class="muted-text small">매수가 -<%= _safeBuy.maxLossPct %>% (최대 손실)</div>
