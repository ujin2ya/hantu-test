<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>주식앱 스타일 차트 + 점수화</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root {
      --brand-gradient: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
      --soft-bg: #f3f5fb;
      --muted: #64748b;
    }

    html, body { height: 100%; }

    body {
      margin: 0;
      background: var(--soft-bg);
      color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo",
        "Malgun Gothic", sans-serif;
    }

    .app-header {
      background: var(--brand-gradient);
      color: #fff;
      padding: 28px 0 56px;
      margin-bottom: -40px;
    }

    .app-header h1 {
      font-weight: 700;
      letter-spacing: -0.5px;
      margin: 0;
      font-size: 1.75rem;
    }

    .app-header .subtitle {
      opacity: 0.85;
      font-size: 0.95rem;
      margin-top: 4px;
    }

    .glass-card {
      border: 0;
      border-radius: 18px;
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
      background: #fff;
    }

    .metric-card {
      border: 0;
      border-radius: 16px;
      background: #fff;
      box-shadow: 0 4px 14px rgba(15, 23, 42, 0.06);
      height: 100%;
    }

    .metric-card .metric-label {
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.2px;
    }

    .metric-card .metric-value {
      font-size: 1.6rem;
      font-weight: 700;
      word-break: break-word;
    }

    .metric-card .metric-sub {
      font-size: 0.85rem;
      color: var(--muted);
      margin-top: 4px;
    }

    .metric-card.metric-accent {
      background: var(--brand-gradient);
      color: #fff;
    }

    .metric-card.metric-accent .metric-label,
    .metric-card.metric-accent .metric-sub {
      color: rgba(255, 255, 255, 0.85);
    }

    .section-title {
      font-size: 1.05rem;
      font-weight: 700;
      margin: 0;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-title .bi {
      color: #2563eb;
    }

    .weight-item {
      background: #f8fafc;
      border-radius: 12px;
      padding: 12px 12px 10px;
    }

    .weight-item label {
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .weight-help {
      cursor: help;
      color: #94a3b8;
      font-size: 0.85rem;
      line-height: 1;
      transition: color 0.15s;
    }
    .weight-help:hover { color: #6366f1; }

    .market-bar {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px;
      padding: 10px 14px;
      background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      font-size: 0.85rem;
    }
    .market-item { display: inline-flex; align-items: baseline; gap: 6px; }
    .market-item .label {
      font-weight: 600;
      color: #475569;
      font-size: 0.78rem;
    }
    .market-item .value {
      font-weight: 700;
      color: #1e293b;
      font-variant-numeric: tabular-nums;
    }
    .market-item .change {
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .market-rs {
      margin-left: auto;
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
    }
    .market-rs.outperform { background: #dcfce7; color: #166534; }
    .market-rs.underperform { background: #fee2e2; color: #991b1b; }
    .market-rs.neutral { background: #f1f5f9; color: #475569; }

    .chart-wrap {
      position: relative;
      width: 100%;
      height: 340px;
    }

    .pill {
      background: #f8fafc;
      border-radius: 12px;
      padding: 10px 12px;
    }

    .pill strong {
      display: block;
      font-size: 0.72rem;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 600;
    }

    .pill span {
      font-size: 1rem;
      font-weight: 700;
    }

    .position-card {
      background: #f8fafc;
      border-radius: 12px;
      padding: 14px;
      height: 100%;
    }

    .position-card .title {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .position-card .percent {
      font-size: 1.4rem;
      font-weight: 700;
      margin: 4px 0 2px;
    }

    .position-card .desc {
      font-size: 0.85rem;
      color: #475569;
    }

    .meta-item {
      background: #f8fafc;
      border-radius: 12px;
      padding: 12px 14px;
      height: 100%;
    }

    .meta-item strong {
      display: block;
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 600;
    }

    .meta-item .value {
      font-size: 1rem;
      font-weight: 600;
      word-break: break-word;
    }

    .explain-box {
      background: #f8fafc;
      border-radius: 12px;
      padding: 18px;
      height: 100%;
    }

    .explain-box h3 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .zone-list {
      padding-left: 18px;
      margin: 0;
      line-height: 1.7;
    }

    .muted-text {
      color: var(--muted);
      font-size: 0.82rem;
      line-height: 1.55;
    }

    .ai-card {
      background: linear-gradient(135deg, #fafbff 0%, #f3f5fb 100%);
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      padding: 16px 18px;
      font-size: 0.92rem;
      line-height: 1.65;
      color: #1f2937;
    }
    .ai-card p { margin: 0 0 10px; }
    .ai-card p:last-child { margin-bottom: 0; }
    .ai-section-h {
      font-weight: 700;
      font-size: 0.92rem;
      margin: 14px 0 6px;
      color: #1e293b;
      border-left: 3px solid #6366f1;
      padding-left: 8px;
    }
    .ai-section-h:first-child { margin-top: 0; }
    .ai-mode-badge {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 999px;
      margin-bottom: 12px;
      color: #fff;
    }
    .ai-mode-badge.short { background: #dc2626; }
    .ai-mode-badge.swing { background: #2563eb; }
    .news-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .news-list li {
      padding: 8px 0;
      border-bottom: 1px dashed #e2e8f0;
      font-size: 0.88rem;
      line-height: 1.5;
    }
    .news-list li:last-child { border-bottom: 0; }
    .news-list a {
      color: #1e293b;
      text-decoration: none;
      font-weight: 500;
    }
    .news-list a:hover {
      color: #4f46e5;
      text-decoration: underline;
    }
    .news-meta {
      display: block;
      font-size: 0.72rem;
      color: #64748b;
      margin-top: 2px;
    }
    .news-meta .news-office {
      color: #475569;
      font-weight: 500;
    }
    .insight-tabs {
      display: flex;
      gap: 6px;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .insight-tabs button {
      border: 1px solid #e2e8f0;
      background: #f8fafc;
      color: #475569;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 999px;
      cursor: pointer;
      transition: all 0.15s;
    }
    .insight-tabs button:hover {
      background: #e2e8f0;
      color: #1e293b;
    }
    .insight-tabs button.active {
      background: var(--brand-gradient, linear-gradient(135deg, #6366f1, #818cf8));
      color: #fff;
      border-color: transparent;
    }

    .btn-search {
      background: var(--brand-gradient);
      color: #fff;
      border: 0;
      border-radius: 10px;
      padding: 8px 16px;
      font-size: 0.95rem;
      font-weight: 600;
      white-space: nowrap;
      transition: transform 0.08s ease, box-shadow 0.2s ease;
    }

    .btn-search:hover {
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 10px 20px rgba(37, 99, 235, 0.28);
    }

    .btn-search:focus { color: #fff; }

    .form-control, .form-select {
      border-radius: 10px;
    }

    .form-control:focus, .form-select:focus {
      border-color: #7c3aed;
      box-shadow: 0 0 0 0.2rem rgba(124, 58, 237, 0.15);
    }

    .verdict-badge {
      display: inline-block;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 0.78rem;
      font-weight: 600;
      margin-top: 6px;
    }

    .recommend-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 0.82rem;
      font-weight: 500;
    }

    .recommend-badge.recommend-aggressive { background: #dcfce7; color: #166534; }
    .recommend-badge.recommend-neutral { background: #dbeafe; color: #1e40af; }
    .recommend-badge.recommend-conservative { background: #fef3c7; color: #92400e; }

    .buy-tier {
      background: #f8fafc;
      border-radius: 14px;
      padding: 16px;
      height: 100%;
      border: 2px solid transparent;
      transition: border-color 0.15s ease, background 0.15s ease;
    }

    .buy-tier.active {
      border-color: #2563eb;
      background: #eff6ff;
      box-shadow: 0 4px 14px rgba(37, 99, 235, 0.12);
    }

    .buy-tier.tier-unavailable {
      opacity: 0.55;
      background: #f1f5f9;
    }

    .buy-tier .tier-label {
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 600;
      letter-spacing: 0.2px;
    }

    .buy-tier.active .tier-label {
      color: #1e40af;
    }

    .buy-tier .tier-price {
      font-size: 1.55rem;
      font-weight: 700;
      margin: 4px 0 2px;
      word-break: break-word;
    }

    .buy-tier .tier-gap {
      font-size: 0.82rem;
      color: #2563eb;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .buy-tier .tier-desc {
      font-size: 0.82rem;
      color: #475569;
      line-height: 1.45;
    }

    .buy-tier .tier-band {
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 500;
      margin-left: 2px;
    }

    .buy-tier.active .tier-band {
      color: #3b82f6;
    }

    .buy-tabs {
      gap: 6px;
      flex-wrap: wrap;
    }

    .buy-tabs .nav-link {
      color: var(--muted);
      font-weight: 600;
      font-size: 0.85rem;
      border-radius: 10px;
      padding: 6px 14px;
      background: #f1f5f9;
      border: 0;
    }

    .buy-tabs .nav-link.active {
      background: var(--brand-gradient);
      color: #fff;
    }

    .buy-tabs .nav-link:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    #loading-overlay {
      position: fixed;
      inset: 0;
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
      background: rgba(15, 23, 42, 0.35);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      color: #fff;
    }

    #loading-overlay.active { display: flex; }

    #loading-overlay .spinner-border {
      width: 3.2rem;
      height: 3.2rem;
      border-width: 0.35rem;
    }

    #loading-overlay .loading-text {
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 0.3px;
    }

    @media (max-width: 991.98px) {
      .app-header { padding: 22px 0 48px; margin-bottom: -34px; }
      .app-header h1 { font-size: 1.3rem; }
      .app-header .subtitle { font-size: 0.85rem; }
      .chart-wrap { height: 280px; }
    }

    @media (max-width: 575.98px) {
      .app-header { padding: 18px 0 42px; margin-bottom: -30px; }
      .app-header h1 { font-size: 1.15rem; letter-spacing: -0.3px; }
      .app-header .subtitle { font-size: 0.78rem; }

      .section-title { font-size: 0.95rem; }

      .metric-card { border-radius: 14px; }
      .metric-card .metric-label { font-size: 0.72rem; }
      .metric-card .metric-value { font-size: 1.15rem; }
      .metric-card .metric-sub { font-size: 0.78rem; }

      .position-card { padding: 12px; }
      .position-card .title { font-size: 0.72rem; }
      .position-card .percent { font-size: 1.15rem; }
      .position-card .desc { font-size: 0.78rem; }

      .meta-item { padding: 10px 12px; }
      .meta-item strong { font-size: 0.7rem; }
      .meta-item .value { font-size: 0.9rem; }

      .pill { padding: 8px 10px; }
      .pill strong { font-size: 0.66rem; }
      .pill span { font-size: 0.9rem; }

      .weight-item { padding: 8px 10px; }
      .weight-item label { font-size: 0.72rem; margin-bottom: 4px; }
      /* iOS 사파리는 포커스 시 16px 미만 입력에 자동 줌을 건다 — 줌 방지 */
      .weight-item .form-control-sm { font-size: 16px; padding: 6px 8px; }

      .explain-box { padding: 14px; }
      .explain-box h3 { font-size: 0.95rem; }

      .verdict-badge { font-size: 0.72rem; padding: 3px 10px; }

      .recommend-badge { font-size: 0.72rem; padding: 4px 10px; }

      .buy-tier { padding: 12px; }
      .buy-tier .tier-label { font-size: 0.75rem; }
      .buy-tier .tier-price { font-size: 1.25rem; }
      .buy-tier .tier-gap { font-size: 0.78rem; }
      .buy-tier .tier-desc { font-size: 0.78rem; }
      .buy-tier .tier-band { font-size: 0.66rem; display: block; margin-left: 0; margin-top: 2px; }

      .buy-tabs .nav-link { font-size: 0.78rem; padding: 5px 10px; }

      .chart-wrap { height: 240px; }

      .btn-search { padding: 10px 16px; font-size: 1rem; }
    }
  </style>
</head>
<body>
  <%
    const safeQuery = query || "";
    const safeError = error || null;
    const safeSelected = selected || null;
    const safeCurrentData = currentData || null;
    const safeCandidates = Array.isArray(candidates) ? candidates : [];
    const safeDailySeries = dailySeries || null;
    const safeWeeklySeries = weeklySeries || null;
    const safeMonthlySeries = monthlySeries || null;
    const safeYearlySeries = yearlySeries || null;
    const safeSummary = summary || null;
    const safeScoreModel = scoreModel || null;
    const safeMarket = (typeof market !== 'undefined' && market) ? market : null;
    const safeMarketContext = (typeof marketContext !== 'undefined' && marketContext) ? marketContext : null;
    const safeWeights = weights || {
      volume: 25, position: 17, trend: 8, rsi: 5, macd: 5,
      resistance: 15, volatility: 10, flow: 15,
    };

    function fmtNumber(value) {
      return Number(value || 0).toLocaleString();
    }
  %>

  <header class="app-header">
    <div class="container-fluid px-3 px-lg-5 d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h1><i class="bi bi-graph-up-arrow me-2"></i>주식앱 스타일 차트 + 점수화</h1>
        <div class="subtitle">한국투자증권 Open API · 일/주/월/연봉 + 안전 매수가 + AI 검증</div>
      </div>
      <div class="d-flex gap-2 align-self-center flex-wrap">
        <button type="button" onclick="history.back()" class="btn btn-light btn-sm">
          <i class="bi bi-arrow-left me-1"></i>이전
        </button>
        <a href="/backtest" class="btn btn-light btn-sm">
          <i class="bi bi-clipboard-data me-1"></i>백테스팅
        </a>
        <a href="/subscribe" class="btn btn-light btn-sm">
          <i class="bi bi-envelope-paper me-1"></i>메일 구독
        </a>
        <% if (typeof returnUrl !== 'undefined' && returnUrl) { %>
          <a href="<%= returnUrl %>" class="btn btn-warning btn-sm">
            <i class="bi bi-arrow-left me-1"></i>단타 스캔 결과로
          </a>
        <% } else { %>
          <a href="/scan" class="btn btn-light btn-sm">
            <i class="bi bi-radar me-1"></i>단타 스캔
          </a>
        <% } %>
      </div>
    </div>
  </header>

  <main class="container-fluid px-3 px-lg-5 pb-5">
    <div class="glass-card p-3 p-lg-4 mb-4">
      <form id="search-form" method="post" action="/search">
        <div class="row g-2 align-items-stretch mb-3">
          <div class="col-12 col-lg">
            <div class="input-group input-group-lg">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-secondary"></i>
              </span>
              <input
                type="text"
                name="stockQuery"
                class="form-control border-start-0"
                placeholder="종목명 또는 종목코드 (예: 삼성전자, 005930)"
                value="<%= safeQuery %>"
                autocomplete="off"
                required
              />
            </div>
          </div>
          <div class="col-12 col-lg-auto">
            <button type="submit" class="btn btn-search w-100 w-lg-auto">
              <i class="bi bi-lightning-charge-fill me-1"></i>조회
            </button>
          </div>
        </div>

        <% if (safeMarketContext) { %>
          <div class="muted-text small mt-2">
            <i class="bi bi-clock me-1"></i>
            <strong><%= safeMarketContext.label %></strong> · <%= safeMarketContext.description %>
          </div>
        <% } %>
      </form>
    </div>

    <% if (safeError) { %>
      <div class="alert alert-danger d-flex align-items-start gap-2 rounded-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
        <div style="white-space: pre-wrap;"><%= safeError %></div>
      </div>
    <% } %>

    <% if (safeCandidates.length > 1 && safeSelected) { %>
      <div class="alert alert-warning d-flex align-items-start gap-2 rounded-4" role="alert">
        <i class="bi bi-info-circle-fill mt-1"></i>
        <div>
          유사한 종목이 여러 개 있어 첫 번째 종목인
          <strong><%= safeSelected.name %></strong>
          을 조회했습니다.
        </div>
      </div>
    <% } %>

    <% if (safeMarket && (safeMarket.kospi || safeMarket.kosdaq)) { %>
      <div class="market-bar mb-3">
        <% if (safeMarket.kospi) { %>
          <% const k = safeMarket.kospi; const cls = k.changeRate >= 0 ? 'pos-rate' : 'neg-rate'; %>
          <div class="market-item">
            <span class="label">코스피</span>
            <span class="value"><%= k.price.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
            <span class="change <%= cls %>"><%= k.changeRate >= 0 ? '+' : '' %><%= k.changeRate.toFixed(2) %>%</span>
          </div>
        <% } %>
        <% if (safeMarket.kosdaq) { %>
          <% const q = safeMarket.kosdaq; const cls = q.changeRate >= 0 ? 'pos-rate' : 'neg-rate'; %>
          <div class="market-item">
            <span class="label">코스닥</span>
            <span class="value"><%= q.price.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
            <span class="change <%= cls %>"><%= q.changeRate >= 0 ? '+' : '' %><%= q.changeRate.toFixed(2) %>%</span>
          </div>
        <% } %>
        <% if (safeMarket.relativeRate !== null && safeMarket.relativeRate !== undefined) {
             const rs = safeMarket.relativeRate;
             const rsCls = rs > 0.5 ? 'outperform' : rs < -0.5 ? 'underperform' : 'neutral';
             const rsLabel = rs > 0.5 ? '시장 상회' : rs < -0.5 ? '시장 하회' : '시장 동조';
        %>
          <span class="market-rs <%= rsCls %>"
                title="종목 등락률 - <%= safeMarket.ownIndexLabel %> 등락률">
            <i class="bi bi-arrow-<%= rs > 0 ? 'up' : rs < 0 ? 'down' : 'right' %>-circle me-1"></i>
            vs <%= safeMarket.ownIndexLabel %> <%= rs >= 0 ? '+' : '' %><%= rs.toFixed(2) %>%p · <%= rsLabel %>
          </span>
        <% } %>
      </div>
    <% } %>

    <% if (safeCurrentData && safeDailySeries && safeWeeklySeries && safeMonthlySeries && safeYearlySeries && safeScoreModel) { %>

      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h2 class="h5 m-0">
          <i class="bi bi-bookmark-star me-1 text-primary"></i>
          <%= safeCurrentData.stockName %>
          <span class="text-secondary small ms-2"><%= safeCurrentData.stockCode %> · <%= safeCurrentData.market %></span>
          <% if (typeof stockType !== 'undefined' && stockType === 'weakTrend') { %>
            <span style="display:inline-block;padding:2px 8px;border-radius:6px;background:#e0e7ff;color:#4338ca;font-size:0.7rem;font-weight:600;margin-left:6px;vertical-align:middle;"
