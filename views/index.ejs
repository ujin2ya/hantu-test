                <div class="col"><div class="pill"><strong>구간</strong><span><%= c.series.position.zoneLabel %></span></div></div>
                <div class="col"><div class="pill"><strong>최저가</strong><span><%= fmtNumber(c.series.position.minPrice) %></span></div></div>
                <div class="col"><div class="pill"><strong>최고가</strong><span><%= fmtNumber(c.series.position.maxPrice) %></span></div></div>
              </div>
