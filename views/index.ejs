      </div>

      <div class="glass-card p-3 p-lg-4 mb-4">
        <h2 class="section-title mb-3"><i class="bi bi-journal-text"></i>점수 설명 / 물린 매물대 추정</h2>
        <div class="row g-3">
          <div class="col-12 col-lg-6">
            <div class="explain-box">
              <h3>점수 설명</h3>
              <ul class="zone-list">
                <li><strong>거래량:</strong> <%= safeScoreModel.volume.explanation %></li>
                <li><strong>위치:</strong> <%= safeScoreModel.position.explanation %></li>
                <li><strong>추세:</strong> <%= safeScoreModel.trend.explanation %></li>
                <li><strong>매물 압력:</strong> <%= safeScoreModel.resistance.explanation %></li>
                <li><strong>변동성:</strong> <%= safeScoreModel.volatility.explanation %></li>
                <% if (safeScoreModel.flow) { %>
                  <li><strong>수급:</strong> <%= safeScoreModel.flow.explanation %></li>
                <% } %>
              </ul>
              <div class="muted-text mt-2">
                지금 버전은 규칙 기반 점수화다. 다음 단계에서는 세부 특징을 더 쪼개고, 조건부 보너스/패널티를 늘려서 정교하게 만들 수 있다.
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-6">
            <div class="explain-box">
              <h3>사람들이 많이 물렸을 가능성이 높은 가격대</h3>
              <% if (!safeScoreModel.trappedZones || safeScoreModel.trappedZones.length === 0) { %>
                <div class="muted-text">현재가 위 뚜렷한 매물대가 적습니다.</div>
              <% } else { %>
                <ol class="zone-list">
                  <% safeScoreModel.trappedZones.forEach(function(zone) { %>
                    <li>
                      <strong><%= fmtNumber(zone.start) %> ~ <%= fmtNumber(zone.end) %>원</strong>
                      <span class="muted-text">(추정 거래량: <%= fmtNumber(zone.volume) %>)</span>
                    </li>
                  <% }) %>
                </ol>
                <div class="muted-text mt-2">
                  최근 일봉 120개 기준으로 가격대별 누적 거래량을 근사 계산한 값이다. 실제 개인별 매수단가와 같지는 않지만, 본전 매도 압력이 몰릴 가능성이 있는 구간으로 볼 수 있다.
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card p-3 p-lg-4 mt-4">
        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-3">
          <ul class="insight-tabs" role="tablist">
            <li><button type="button" class="active" data-insight-tab="news"><i class="bi bi-newspaper me-1"></i>뉴스</button></li>
            <li><button type="button" data-insight-tab="disc"><i class="bi bi-file-earmark-text me-1"></i>공시</button></li>
          </ul>
          <span class="muted-text" style="font-size: 0.72rem;">네이버 금융 / DART · 30분 캐시</span>
        </div>
        <div id="newsPanel" data-insight-panel="news">
          <div id="newsList" class="muted-text" style="font-size: 0.85rem;">
            <span class="spinner-border spinner-border-sm me-2"></span>뉴스를 불러오는 중...
          </div>
        </div>
        <div id="discPanel" data-insight-panel="disc" style="display:none;">
          <div id="discList" class="muted-text" style="font-size: 0.85rem;">
            <span class="spinner-border spinner-border-sm me-2"></span>공시를 불러오는 중...
          </div>
        </div>
      </div>

      <div class="glass-card p-3 p-lg-4 mt-4">
        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
          <h2 class="section-title mb-0"><i class="bi bi-robot"></i>AI 전략 코멘트</h2>
          <div class="btn-group btn-group-sm" role="group">
            <button type="button" class="btn btn-outline-danger" id="aiBtnShort">
              <i class="bi bi-lightning-charge me-1"></i>단타 코멘트
            </button>
            <button type="button" class="btn btn-outline-primary" id="aiBtnSwing">
              <i class="bi bi-graph-up me-1"></i>스윙 코멘트
            </button>
          </div>
        </div>
        <div class="muted-text mb-3" style="font-size: 0.78rem;">
          ⚠️ AI(Gemini Flash) 해석은 참고용이며 투자권유가 아닙니다. 매매 판단과 책임은 본인에게 있습니다.
        </div>
        <div id="aiCommentResult" style="display: none;"></div>
        <div id="aiCommentEmpty" class="muted-text">
          버튼을 누르면 위 점수와 차트 요약을 바탕으로 AI가 단타/스윙 관점의 해석을 생성합니다 (5~15초).
        </div>
      </div>

      <%
        const aiSnapshot = {
          name: currentData.stockName,
          code: currentData.stockCode,
          market: currentData.market,
          currentPrice: currentData.currentPrice,
          changeRate: currentData.changeRate,
          todayHigh: currentData.highPrice,
          todayLow: currentData.lowPrice,
          chegyeolStrength: currentData.chegyeolStrength,
          buySellRatio: currentData.buySellRatio,
          totalScore: safeScoreModel.totalScore,
          verdict: safeScoreModel.verdict,
          safeBuyRec: safeScoreModel.buyRecommendation || null,
          components: {
            volume:     { score: safeScoreModel.volume.score,     explanation: safeScoreModel.volume.explanation },
            position:   { score: safeScoreModel.position.score,   explanation: safeScoreModel.position.explanation },
            trend:      { score: safeScoreModel.trend.score,      explanation: safeScoreModel.trend.explanation },
            rsi:        { score: safeScoreModel.rsi.score,        explanation: safeScoreModel.rsi.explanation },
            macd:       { score: safeScoreModel.macd.score,       explanation: safeScoreModel.macd.explanation },
            resistance: { score: safeScoreModel.resistance.score, explanation: safeScoreModel.resistance.explanation },
            volatility: { score: safeScoreModel.volatility.score, explanation: safeScoreModel.volatility.explanation },
            flow:       safeScoreModel.flow ? { score: safeScoreModel.flow.score, explanation: safeScoreModel.flow.explanation } : null,
          },
          positions: {
            daily:   safeDailySeries?.position   || null,
            weekly:  safeWeeklySeries?.position  || null,
            monthly: safeMonthlySeries?.position || null,
            yearly:  safeYearlySeries?.position  || null,
          },
          trappedZones: safeScoreModel.trappedZones || [],
          buyRecommendation: safeScoreModel.buyRecommendation || null,
        };
      %>
      <script id="ai-snapshot-data" type="application/json"><%- JSON.stringify(aiSnapshot) %></script>
      <script id="ai-auto-mode" type="text/plain"><%= autoMode || 'swing' %></script>

      <script id="daily-series-data" type="application/json"><%- JSON.stringify(safeDailySeries) %></script>
      <script id="weekly-series-data" type="application/json"><%- JSON.stringify(safeWeeklySeries) %></script>
      <script id="monthly-series-data" type="application/json"><%- JSON.stringify(safeMonthlySeries) %></script>
      <script id="yearly-series-data" type="application/json"><%- JSON.stringify(safeYearlySeries) %></script>

      <script>
        window.addEventListener("DOMContentLoaded", function () {
          function parseJson(id) {
            const el = document.getElementById(id);
            if (!el) return null;
            try {
              return JSON.parse(el.textContent || "null");
            } catch (e) {
              return null;
            }
          }

          function createMixedChart(canvasId, series, lineColor) {
            const canvas = document.getElementById(canvasId);
            if (!canvas || !series || !window.Chart) return;

            const ctx = canvas.getContext("2d");
            const lastIndex = series.closePrices.length - 1;

            new Chart(ctx, {
              data: {
                labels: series.labels,
                datasets: [
                  {
                    type: "bar",
                    label: "거래량",
                    data: series.volumes || [],
                    yAxisID: "yVolume",
                    backgroundColor: "rgba(148, 163, 184, 0.45)",
                    borderWidth: 0,
                    order: 2
                  },
                  {
                    type: "line",
                    label: "종가",
                    data: series.closePrices,
                    yAxisID: "yPrice",
                    borderColor: lineColor,
                    backgroundColor: lineColor,
                    borderWidth: 2,
                    tension: 0.2,
                    fill: false,
                    pointRadius: series.closePrices.map((_, idx) => idx === lastIndex ? 5 : 0),
                    pointHoverRadius: series.closePrices.map((_, idx) => idx === lastIndex ? 6 : 3),
                    pointBackgroundColor: series.closePrices.map((_, idx) =>
                      idx === lastIndex ? "rgba(239, 68, 68, 1)" : lineColor
                    ),
                    order: 1
                  },
                  {
                    type: "line",
                    label: "현재가",
                    data: series.currentPriceLine,
                    yAxisID: "yPrice",
                    borderColor: "rgba(239, 68, 68, 0.9)",
                    borderWidth: 1.5,
                    borderDash: [6, 6],
                    pointRadius: 0,
                    tension: 0,
                    fill: false,
                    order: 0
                  }
                ]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: "index", intersect: false },
                plugins: {
                  legend: { position: "top" },
                  tooltip: {
                    callbacks: {
                      label: function(context) {
                        return `${context.dataset.label}: ${Number(context.raw || 0).toLocaleString()}`;
                      }
                    }
                  }
                },
                scales: {
                  x: { ticks: { maxTicksLimit: 8 } },
                  yPrice: {
                    type: "linear",
                    position: "left",
                    beginAtZero: false,
                    ticks: { callback: function(value) { return Number(value).toLocaleString(); } }
                  },
                  yVolume: {
                    type: "linear",
                    position: "right",
                    beginAtZero: true,
                    grid: { drawOnChartArea: false },
                    ticks: { callback: function(value) { return Number(value).toLocaleString(); } }
                  }
                }
              }
            });
          }

          const dailySeries = parseJson("daily-series-data");
          const weeklySeries = parseJson("weekly-series-data");
          const monthlySeries = parseJson("monthly-series-data");
          const yearlySeries = parseJson("yearly-series-data");

          createMixedChart("dailyChart", dailySeries, "rgba(37, 99, 235, 1)");
          createMixedChart("weeklyChart", weeklySeries, "rgba(16, 185, 129, 1)");
          createMixedChart("monthlyChart", monthlySeries, "rgba(245, 158, 11, 1)");
          createMixedChart("yearlyChart", yearlySeries, "rgba(139, 92, 246, 1)");
        });
      </script>
      <script>
        // AI 검증 (Gemini 그라운딩) — Google 검색으로 뉴스/실적/섹터/분석가 목표가 확인.
        (function () {
          const btn = document.getElementById("ai-adjust-btn");
          if (!btn) return;
          const resultBox = document.getElementById("ai-adjust-result");
          const buyPanel = document.getElementById("ai-buy-price-panel");

          function escHtml(s) {
            return String(s ?? "").replace(/[&<>"']/g, (c) => ({
              "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
            })[c]);
          }
          function fmtN(n) {
            return Number(n || 0).toLocaleString();
          }

          btn.addEventListener("click", async function () {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>AI 검색 중…';
            resultBox.style.display = "none";
            if (buyPanel) buyPanel.style.display = "none";
            try {
              const payload = {
                shortCode: btn.dataset.shortcode,
                name: btn.dataset.name,
                currentPrice: Number(btn.dataset.price) || 0,
                changeRate: Number(btn.dataset.change) || 0,
                baselineScore: Number(btn.dataset.baseline) || 0,
                market: btn.dataset.market || "",
                technicalBuyPrice: Number(btn.dataset.techBuyPrice) || null,
                technicalStopLoss: Number(btn.dataset.techStopLoss) || null,
              };
              const r = await fetch("/ai/adjust", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
              });
              const data = await r.json();
              if (!r.ok || !data.ok) throw new Error(data.error || "AI 보정 실패");
              const a = data.aiAdjust || {};

              // 1. 점수 보정 (작은 inline 블록)
              const bonus = a.bonus;
              const isErr = !!a.error;
              const sign = bonus > 0 ? "+" : (bonus < 0 ? "" : "±");
              const bg = isErr ? "#fff7ed" : (bonus > 0 ? "#dcfce7" : (bonus < 0 ? "#fee2e2" : "#f1f5f9"));
              const fg = isErr ? "#92400e" : (bonus > 0 ? "#166534" : (bonus < 0 ? "#991b1b" : "#475569"));
              resultBox.innerHTML =
                '<div style="background:' + bg + ';color:' + fg +
                ';padding:8px 10px;border-radius:8px;line-height:1.5;">' +
                '<div style="font-weight:700;font-size:0.95rem;">AI 점수 보정 ' + sign + (Number.isFinite(bonus) ? bonus : "?") + 'p ' +
                (isErr ? "(" + escHtml(a.error || "오류") + ")" : "") + '</div>' +
                '<div style="margin-top:3px;opacity:0.85;">' + escHtml(a.reasoning || "") + '</div>' +
                '<div style="margin-top:3px;font-size:0.7rem;color:#64748b;">' +
                (a.cached ? '캐시 적중 · ' : '') + '일일 누적 ' + (data.daily?.count ?? "?") + '회</div>' +
                '</div>';
              resultBox.style.display = "block";

              // 2. AI 종합 매수가 (큰 패널)
              const rec = a.buyPriceRec;
              if (buyPanel && rec && Number.isFinite(rec.price)) {
                const techPrice = Number(btn.dataset.techBuyPrice) || null;
                const aiPrice = rec.price;
                const diffPct = techPrice ? (((aiPrice - techPrice) / techPrice) * 100).toFixed(2) : null;
                const ctx = rec.context || {};
                const conf = rec.confidence || "low";
                const confColors = {
                  high: { bg: "#dcfce7", fg: "#166534" },
                  medium: { bg: "#fef3c7", fg: "#92400e" },
                  low: { bg: "#fee2e2", fg: "#991b1b" },
                };
                const cc = confColors[conf] || confColors.low;

                let ctxHtml = "";
                if (ctx.analystTarget) ctxHtml += '<div><strong>분석가 목표가:</strong> ' + fmtN(ctx.analystTarget) + '원</div>';
                if (ctx.recentNews) ctxHtml += '<div><strong>최근 뉴스:</strong> ' + escHtml(ctx.recentNews) + '</div>';
                if (ctx.sectorTrend) ctxHtml += '<div><strong>섹터:</strong> ' + escHtml(ctx.sectorTrend) + '</div>';
                if (ctx.earnings) ctxHtml += '<div><strong>실적:</strong> ' + escHtml(ctx.earnings) + '</div>';
                if (!ctxHtml) ctxHtml = '<div class="text-muted">추가 컨텍스트 정보 없음 (검색 결과 부족)</div>';

                const stopGap = ((aiPrice - rec.stopLoss) / aiPrice * 100).toFixed(2);
                const clampedNote = rec.clamped ? '<div class="muted-text small mt-1">⚠ AI 가격이 기술적 매수가 ±10% 범위로 강제 클램프됨 (할루시네이션 방어)</div>' : '';

                buyPanel.innerHTML =
                  '<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-3">' +
                    '<div>' +
                      '<h2 class="section-title mb-2"><i class="bi bi-magic"></i>AI 종합 매수가 (Google 검색 그라운딩)</h2>' +
                      '<span style="display:inline-block;padding:3px 10px;border-radius:999px;background:' + cc.bg + ';color:' + cc.fg + ';font-size:0.85rem;font-weight:700;">신뢰도: ' + conf + '</span>' +
                    '</div>' +
                    '<div class="text-end">' +
                      '<div class="muted-text small">AI 추천 매수가</div>' +
                      '<div style="font-size:1.6rem;font-weight:700;color:#0f172a;">' + fmtN(aiPrice) + '원</div>' +
                      (diffPct !== null ? '<div class="muted-text small">기술적 매수가 대비 ' + (Number(diffPct) >= 0 ? '+' : '') + diffPct + '%</div>' : '') +
                    '</div>' +
                  '</div>' +
                  '<div class="row g-3 mb-2">' +
                    '<div class="col-md-4">' +
                      '<div class="metric-card p-2" style="background:#fff;">' +
                        '<div class="metric-label small">손절선</div>' +
                        '<div style="font-size:1.05rem;font-weight:700;color:#991b1b;">' + fmtN(rec.stopLoss) + '원</div>' +
                        '<div class="muted-text small">AI 매수가 -' + stopGap + '%</div>' +
                      '</div>' +
                    '</div>' +
                    '<div class="col-md-8">' +
                      '<div class="metric-card p-2" style="background:#fff;">' +
                        '<div class="metric-label small">근거</div>' +
                        '<div class="small" style="line-height:1.5;">' + escHtml(rec.rationale || "") + '</div>' +
                      '</div>' +
                    '</div>' +
                  '</div>' +
                  '<div class="metric-card p-2 small" style="background:#fff;">' +
                    '<div class="metric-label small mb-1">검색 컨텍스트</div>' +
                    ctxHtml +
                  '</div>' +
                  clampedNote +
                  '<div class="muted-text small mt-2">※ AI 매수가는 기술적 매수가의 ±10% 안으로 강제 클램프됩니다. 손절선이 깨지면 즉시 손실 확정 — 가장 중요한 규칙. 투자 조언 아님.</div>';
                buyPanel.style.display = "block";
                buyPanel.scrollIntoView({ behavior: "smooth", block: "center" });
              } else if (buyPanel) {
                buyPanel.innerHTML =
                  '<div class="muted-text small"><i class="bi bi-info-circle me-1"></i>AI 매수가 추천 없음 — ' +
                  escHtml(rec?.rationale || "AI 응답에 매수가 정보가 없거나 정보 부족.") + '</div>';
                buyPanel.style.display = "block";
              }

              btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>다시 검증';
              btn.disabled = false;
            } catch (e) {
              resultBox.innerHTML = '<div class="text-warning small">AI 검증 실패: ' + escHtml(e.message || String(e)) + '</div>';
              resultBox.style.display = "block";
              btn.innerHTML = '<i class="bi bi-magic me-1"></i>AI 검증';
              btn.disabled = false;
            }
          });
        })();
      </script>
    <% } %>
  </main>

  <div id="loading-overlay" role="status" aria-live="polite">
    <div class="spinner-border text-light" aria-hidden="true"></div>
    <div class="loading-text">종목 데이터를 불러오는 중입니다...</div>
    <div class="small text-white-50">KIS API 호출 특성상 수 초가 걸릴 수 있습니다.</div>
  </div>

  <script>
    (function () {
      const overlay = document.getElementById("loading-overlay");
      const form = document.getElementById("search-form");

      function showOverlay() {
        if (overlay) overlay.classList.add("active");
      }
      function hideOverlay() {
        if (overlay) overlay.classList.remove("active");
      }

      if (form && overlay) {
        form.addEventListener("submit", function () {
          showOverlay();
        });
      }

      // 뒤로가기로 복원되었을 때 오버레이가 남아있지 않도록 처리
      window.addEventListener("pageshow", hideOverlay);
      window.addEventListener("DOMContentLoaded", hideOverlay);
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    (function () {
      const triggers = document.querySelectorAll('[data-bs-toggle="tooltip"]');
      triggers.forEach(function (el) { new bootstrap.Tooltip(el); });
    })();
  </script>

  <script>
    (function () {
      const snapshotEl = document.getElementById("ai-snapshot-data");
      if (!snapshotEl) return;
      let snapshot = null;
      try { snapshot = JSON.parse(snapshotEl.textContent || "null"); } catch (_) {}
      if (!snapshot) return;

      const btnShort = document.getElementById("aiBtnShort");
      const btnSwing = document.getElementById("aiBtnSwing");
      const resultBox = document.getElementById("aiCommentResult");
      const emptyBox = document.getElementById("aiCommentEmpty");
      const autoModeEl = document.getElementById("ai-auto-mode");
      const autoMode = (autoModeEl?.textContent || "swing").trim();

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function (c) {
          return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c];
        });
      }

      function renderMarkdown(md) {
        const lines = String(md || "").split(/\r?\n/);
        const out = [];
        let para = [];
        function flushPara() {
          if (para.length) {
            out.push('<p>' + para.join("<br>") + '</p>');
            para = [];
          }
        }
        for (const raw of lines) {
          const line = raw.trim();
          if (!line) { flushPara(); continue; }
          const h = line.match(/^#{2,6}\s+(.+)$/);
          if (h) {
            flushPara();
            out.push('<h6 class="ai-section-h">' + escapeHtml(h[1]) + '</h6>');
          } else {
            para.push(escapeHtml(line));
          }
        }
        flushPara();
        return out.join("");
      }

      function setBusy(busy) {
        [btnShort, btnSwing].forEach(function (b) { if (b) b.disabled = busy; });
      }

      async function callAi(mode) {
        setBusy(true);
        emptyBox.style.display = "none";
        resultBox.style.display = "block";
        resultBox.innerHTML =
          '<div class="text-secondary small d-flex align-items-center gap-2">' +
          '<span class="spinner-border spinner-border-sm"></span> AI 응답을 기다리는 중입니다...</div>';
        try {
          const res = await fetch("/ai/comment", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ mode: mode, snapshot: snapshot }),
          });
          const data = await res.json();
          if (!res.ok) {
            resultBox.innerHTML =
              '<div class="alert alert-warning small mb-0">AI 호출 실패: ' +
              escapeHtml(data.error || res.statusText) + "</div>";
            return;
          }
          const modeLabel = mode === "short" ? "단타" : "스윙";
          const cachedBadge = data.cached
            ? '<span class="badge bg-info ms-2" style="font-size: 0.65rem;">캐시</span>'
            : '';
          resultBox.innerHTML =
            '<div class="ai-card">' +
              '<div class="ai-mode-badge ' + (mode === "short" ? "short" : "swing") + '">' +
                modeLabel + " 관점" +
              '</div>' + cachedBadge +
              renderMarkdown(data.text) +
            '</div>';
        } catch (err) {
          resultBox.innerHTML =
            '<div class="alert alert-danger small mb-0">네트워크 오류: ' +
            escapeHtml(err.message || String(err)) + "</div>";
        } finally {
          setBusy(false);
        }
      }

      btnShort?.addEventListener("click", function () { callAi("short"); });
      btnSwing?.addEventListener("click", function () { callAi("swing"); });

      if (autoMode === "short" || autoMode === "swing") {
        setTimeout(function () { callAi(autoMode); }, 100);
      }

      const insightCode = (snapshot && snapshot.code) ? String(snapshot.code) : "";

      const tabButtons = document.querySelectorAll('[data-insight-tab]');
      const tabPanels = document.querySelectorAll('[data-insight-panel]');
      tabButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          const target = btn.getAttribute('data-insight-tab');
          tabButtons.forEach(function (b) { b.classList.toggle('active', b === btn); });
          tabPanels.forEach(function (p) {
            p.style.display = (p.getAttribute('data-insight-panel') === target) ? '' : 'none';
          });
        });
      });

      function renderEmpty(box, message) {
        box.classList.add("muted-text");
        box.innerHTML = '<span>' + escapeHtml(message) + '</span>';
      }
      function renderError(box, message) {
        box.classList.remove("muted-text");
        box.innerHTML =
          '<div class="alert alert-warning small mb-0">' + escapeHtml(message) + '</div>';
      }

      const newsBox = document.getElementById("newsList");
      if (newsBox && insightCode) {
        fetch("/news?code=" + encodeURIComponent(insightCode))
          .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
          .then(function (resp) {
            if (!resp.ok) {
              renderError(newsBox, "뉴스 조회 실패: " + (resp.body.error || "알 수 없는 오류"));
              return;
            }
            const items = (resp.body.items || []);
            if (!items.length) { renderEmpty(newsBox, "관련 뉴스가 없습니다."); return; }
            const html = items.map(function (it) {
              return '<li>' +
                '<a href="' + escapeHtml(it.url) + '" target="_blank" rel="noopener noreferrer">' +
                  escapeHtml(it.title) +
                '</a>' +
                '<span class="news-meta">' +
                  '<span class="news-office">' + escapeHtml(it.office || "") + '</span>' +
                  (it.datetime ? ' · ' + escapeHtml(it.datetime) : '') +
                '</span>' +
              '</li>';
            }).join('');
            newsBox.classList.remove("muted-text");
            newsBox.innerHTML = '<ul class="news-list">' + html + '</ul>';
          })
          .catch(function (err) {
            renderError(newsBox, "네트워크 오류: " + (err.message || String(err)));
          });
      }

      const discBox = document.getElementById("discList");
      if (discBox && insightCode) {
        fetch("/disclosures?code=" + encodeURIComponent(insightCode))
          .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
          .then(function (resp) {
            if (!resp.ok) {
              renderError(discBox, "공시 조회 실패: " + (resp.body.error || "알 수 없는 오류"));
              return;
            }
            const items = (resp.body.items || []);
            if (!items.length) {
              renderEmpty(discBox, resp.body.note || "최근 6개월 내 공시가 없습니다.");
              return;
            }
            const html = items.map(function (it) {
              const rmBadge = it.rm ? ' <span class="badge bg-secondary" style="font-size:0.62rem;">' + escapeHtml(it.rm) + '</span>' : '';
              return '<li>' +
                '<a href="' + escapeHtml(it.url) + '" target="_blank" rel="noopener noreferrer">' +
                  escapeHtml(it.title) +
                '</a>' + rmBadge +
                '<span class="news-meta">' +
                  '<span class="news-office">' + escapeHtml(it.submitter || "") + '</span>' +
                  (it.date ? ' · ' + escapeHtml(it.date) : '') +
                '</span>' +
              '</li>';
            }).join('');
            discBox.classList.remove("muted-text");
            discBox.innerHTML = '<ul class="news-list">' + html + '</ul>';
          })
          .catch(function (err) {
            renderError(discBox, "네트워크 오류: " + (err.message || String(err)));
          });
      }
    })();
  </script>
</body>
</html>
