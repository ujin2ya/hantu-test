      <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-currency-dollar me-1"></i>현재가</div>
            <div class="metric-value"><%= fmtNumber(safeCurrentData.currentPrice) %>원</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-arrow-up-right me-1"></i>등락률</div>
            <div class="metric-value"><%= safeCurrentData.changeRate %>%</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-bar-chart-fill me-1"></i>오늘 거래량</div>
            <div class="metric-value"><%= fmtNumber(safeCurrentData.todayVolume) %></div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="metric-card p-3">
            <div class="metric-label"><i class="bi bi-activity me-1"></i>20일 평균 대비</div>
            <div class="metric-value"><%= safeSummary ? safeSummary.todayRatio : "-" %>배</div>
          </div>
        </div>
