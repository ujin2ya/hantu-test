<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= stockMeta ? stockMeta.name + ' — 패턴 정보' : '종목 검색' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    body {
      background: #f3f5fb; color: #1f2937;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      padding: 20px 12px;
    }
    .wrap { max-width: 900px; margin: 0 auto; }
    .glass { background: #fff; border-radius: 14px; padding: 18px; box-shadow: 0 4px 16px rgba(15,23,42,0.06); margin-bottom: 14px; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
    h1 { font-size: 1.2rem; font-weight: 700; margin: 0; }
    h2 { font-size: 1rem; font-weight: 700; margin: 0 0 12px; }
    .stock-name { font-size: 1.1rem; font-weight: 700; color: #0f172a; }
    .stock-code { color: #94a3b8; font-size: 0.85rem; margin-left: 4px; }
    .price-row { display: flex; gap: 12px; flex-wrap: wrap; align-items: baseline; margin-top: 4px; }
    .price { font-size: 1.6rem; font-weight: 700; color: #0f172a; font-variant-numeric: tabular-nums; }
    .change { font-weight: 600; font-variant-numeric: tabular-nums; }
    .change.up { color: #c11; }
    .change.down { color: #2563eb; }
    .market-tag { display: inline-block; padding: 2px 8px; background: #f1f5f9; border-radius: 4px; font-size: 0.75rem; color: #475569; }
    .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 8px; margin-top: 12px; }
    .meta-cell { background: #f8fafc; border-radius: 8px; padding: 8px 10px; }
    .meta-cell .label { color: #64748b; font-size: 0.7rem; margin-bottom: 2px; }
    .meta-cell .value { font-weight: 600; font-size: 0.9rem; color: #0f172a; font-variant-numeric: tabular-nums; }
    .feat-grid { display: flex; flex-wrap: wrap; gap: 6px; font-size: 0.82rem; }
    .feat-item { background: #f8fafc; border-radius: 6px; padding: 5px 9px; }
    .feat-item strong { color: #0f172a; font-variant-numeric: tabular-nums; margin-left: 4px; }
    .chart-box { position: relative; height: 280px; }
    .chart-box.volume { height: 110px; margin-top: 6px; }
    .stale-tag { font-size: 0.7rem; color: #92400e; background: #fef3c7; padding: 2px 6px; border-radius: 4px; }
    @media (max-width: 576px) {
      body { padding: 12px 8px; }
      .glass { padding: 14px; border-radius: 12px; }
      h1 { font-size: 1.05rem; }
      .price { font-size: 1.4rem; }
      .chart-box { height: 240px; }
      .chart-box.volume { height: 90px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <h1><i class="bi bi-bar-chart-line me-2"></i>종목 정보</h1>
      <a href="/pattern" class="text-secondary small text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i>패턴 페이지
      </a>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger small mb-2"><%= error %></div>
    <% } %>

    <div class="glass">
      <form method="post" action="/search" class="row g-2 align-items-center">
        <div class="col">
          <input type="text" name="stockQuery" value="<%= query || '' %>" placeholder="종목명 또는 6자리 코드 (예: 엔알비, 475230)" class="form-control form-control-sm" autofocus />
        </div>
        <div class="col-auto">
          <button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>검색</button>
        </div>
      </form>
      <% if (candidates && candidates.length > 1) { %>
        <div class="text-secondary small mt-2">
          후보 <%= candidates.length %>건 — 첫 번째 종목 표시 중. 다른 종목은 코드로 검색.
        </div>
      <% } %>
    </div>

    <% if (stockMeta) { %>
      <div class="glass">
        <div>
          <span class="stock-name"><%= stockMeta.name %></span>
          <span class="stock-code"><%= stockMeta.code %></span>
          <% if (stockMeta.market) { %><span class="market-tag ms-2"><%= stockMeta.market %></span><% } %>
        </div>
        <div class="price-row">
          <span class="price"><%= stockMeta.closePrice ? stockMeta.closePrice.toLocaleString() : '-' %>원</span>
          <% if (stockMeta.changeRate != null) { %>
            <span class="change <%= stockMeta.changeRate > 0 ? 'up' : (stockMeta.changeRate < 0 ? 'down' : '') %>">
              <%= stockMeta.changeRate > 0 ? '+' : '' %><%= stockMeta.changeRate.toFixed(2) %>%
            </span>
          <% } %>
        </div>
        <div class="meta-grid">
          <% if (stockMeta.marketCap) { %>
            <div class="meta-cell"><div class="label">시가총액</div><div class="value"><%= (stockMeta.marketCap / 1e8).toFixed(0) %>억</div></div>
          <% } %>
          <% if (high60 != null) { %>
            <div class="meta-cell"><div class="label">60일 고점</div><div class="value"><%= high60.toLocaleString() %></div></div>
          <% } %>
          <% if (low60 != null) { %>
            <div class="meta-cell"><div class="label">60일 저점</div><div class="value"><%= low60.toLocaleString() %></div></div>
          <% } %>
          <% if (lastDate) { %>
            <div class="meta-cell"><div class="label">최근 거래일</div><div class="value" style="font-size:0.78rem;"><%= lastDate.slice(4,6)+'/'+lastDate.slice(6,8) %></div></div>
          <% } %>
        </div>
        <% if (cacheStale) { %>
          <div class="mt-2"><span class="stale-tag">⚠ 캐시 <%= cacheStale %>일 전 — 시드 갱신 필요할 수 있음</span></div>
        <% } %>
      </div>

      <% if (chartRows && chartRows.length) { %>
        <div class="glass">
          <h2><i class="bi bi-graph-up me-1"></i>일봉 + 거래량 (<%= chartRows.length %>일)</h2>
          <div class="chart-box"><canvas id="priceChart"></canvas></div>
          <div class="chart-box volume"><canvas id="volumeChart"></canvas></div>
        </div>
      <% } %>

      <% if (features) { %>
        <div class="glass">
          <h2><i class="bi bi-tags me-1"></i>패턴 features (오늘 기준)</h2>
          <%
            function fmtPct(v)  { return v == null ? '-' : (v * 100).toFixed(0) + '%'; }
            function fmtDelta(v){ if (v == null) return '-'; const d = (v - 1) * 100; return (d >= 0 ? '+' : '') + d.toFixed(0) + '%'; }
            function fmtMult(v) { return v == null ? '-' : v.toFixed(2) + '배'; }
            function fmtDays(v) { return v == null ? '-' : v + '일'; }
            function fmtForeign(v){ if (v == null) return '-'; return (v >= 0 ? '+' : '') + (v * 100).toFixed(1) + '%p'; }
            const featList = [
              ['20일 회전율',         fmtPct(features.turnover),          '직전 20일 거래대금 / 시총'],
              ['박스권',              fmtDays(features.boxDays),           '점화 직전 일변동 ≤4% 연속일수'],
              ['60일 고점 대비',      fmtDelta(features.positionPct),      '종가 / 60일 고점'],
              ['60일 저점 대비',      fmtDelta(features.positionFromLow),  '종가 / 60일 저점'],
              ['20일선 대비',         fmtDelta(features.maPos20),          '종가 / 20일 SMA'],
              ['60일선 대비',         fmtDelta(features.maPos60),          '종가 / 60일 SMA'],
              ['현재가 매물밀도',     fmtPct(features.localResistance),    '현재가 ±5% 60일 누적 거래대금 비율'],
              ['위쪽 매물대',         fmtPct(features.resistAbove),        '현재가 위쪽 60일 거래대금 비율'],
              ['오늘 거래량',         fmtMult(features.igniteVolumeRatio), '오늘 거래량 / 20일 평균'],
              ['오늘 거래대금/시총',  fmtPct(features.igniteValueRatio),   '오늘 거래대금 / 시총'],
              ['ATR 수렴',            fmtMult(features.atrCompress),       '5일 ATR / 20일 ATR — <1 = 수렴'],
              ['양봉/음봉 거래대금',  fmtMult(features.bullBearRatio),     '20일 양봉 거래대금 / 음봉 거래대금'],
              ['외인 보유 변화',      fmtForeign(features.foreignDelta),   '20일간 외인 보유율 변화'],
              ['거래량 급증',         fmtMult(features.volumeSurge),       '5일 평균 거래량 / 60일 평균'],
            ];
          %>
          <div class="feat-grid">
            <% featList.forEach(function(f) { %>
              <span class="feat-item" title="<%= f[2] %>"><%= f[0] %><strong><%= f[1] %></strong></span>
            <% }) %>
          </div>
        </div>
      <% } %>
    <% } else if (!error) { %>
      <div class="text-center text-secondary small mt-4 mb-4">
        종목명 또는 코드로 검색하세요. <br/>
        패턴 페이지에서 후보를 클릭하면 자동으로 열립니다.
      </div>
    <% } %>
  </div>

  <% if (stockMeta && chartRows && chartRows.length) { %>
    <script>
      const rows = <%- JSON.stringify(chartRows) %>;
      const labels = rows.map(r => r.date.slice(4,6)+'/'+r.date.slice(6,8));

      // ─── 일봉 차트 (close-line + 5/20/60 SMA) ───
      function sma(arr, period) {
        const out = [];
        for (let i = 0; i < arr.length; i++) {
          if (i < period - 1) { out.push(null); continue; }
          let s = 0;
          for (let j = i - period + 1; j <= i; j++) s += arr[j];
          out.push(Math.round(s / period));
        }
        return out;
      }
      const closes = rows.map(r => r.close);
      const sma5 = sma(closes, 5);
      const sma20 = sma(closes, 20);
      const sma60 = sma(closes, 60);

      // 상승/하락 막대 — high-low를 floating bar 로
      const wickData = rows.map(r => [r.low, r.high]);
      const bodyData = rows.map(r => [Math.min(r.open, r.close), Math.max(r.open, r.close)]);
      const bodyColors = rows.map(r => r.close >= r.open ? 'rgba(220, 38, 38, 0.85)' : 'rgba(37, 99, 235, 0.85)');

      new Chart(document.getElementById('priceChart'), {
        data: {
          labels,
          datasets: [
            // wick (low-high 얇은 막대)
            { type: 'bar', data: wickData, backgroundColor: 'rgba(100,116,139,0.6)', borderWidth: 0, barPercentage: 0.15, categoryPercentage: 0.95, order: 3 },
            // body (open-close 두꺼운 막대) — 색상은 등락 반영
            { type: 'bar', data: bodyData, backgroundColor: bodyColors, borderWidth: 0, barPercentage: 0.7, categoryPercentage: 0.95, order: 2 },
            // SMA lines
            { type: 'line', label: '5일선', data: sma5, borderColor: '#dc2626', borderWidth: 1.2, pointRadius: 0, tension: 0, order: 1 },
            { type: 'line', label: '20일선', data: sma20, borderColor: '#7c3aed', borderWidth: 1.2, pointRadius: 0, tension: 0, order: 1 },
            { type: 'line', label: '60일선', data: sma60, borderColor: '#16a34a', borderWidth: 1.2, pointRadius: 0, tension: 0, order: 1 },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          scales: {
            x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 10 } } },
            y: { position: 'right', ticks: { font: { size: 10 } }, grid: { color: '#f1f5f9' } },
          },
          plugins: {
            legend: { position: 'top', labels: { font: { size: 11 }, boxWidth: 12, filter: (l) => l.text && !l.text.startsWith('Dataset') } },
            tooltip: {
              callbacks: {
                title: (items) => labels[items[0].dataIndex],
                label: (item) => {
                  const r = rows[item.dataIndex];
                  if (item.datasetIndex === 0 || item.datasetIndex === 1) {
                    return [`시 ${r.open.toLocaleString()}`, `고 ${r.high.toLocaleString()}`, `저 ${r.low.toLocaleString()}`, `종 ${r.close.toLocaleString()}`];
                  }
                  return `${item.dataset.label}: ${item.raw?.toLocaleString() ?? '-'}`;
                },
              },
            },
          },
        },
      });

      // ─── 거래량 차트 ───
      const volColors = rows.map(r => r.close >= r.open ? 'rgba(220, 38, 38, 0.7)' : 'rgba(37, 99, 235, 0.7)');
      new Chart(document.getElementById('volumeChart'), {
        type: 'bar',
        data: {
          labels,
          datasets: [{ data: rows.map(r => r.volume), backgroundColor: volColors, borderWidth: 0, barPercentage: 0.85, categoryPercentage: 0.95 }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 9 } } },
            y: { position: 'right', ticks: { font: { size: 9 }, callback: (v) => v >= 1e6 ? (v/1e6).toFixed(0)+'M' : (v/1e3).toFixed(0)+'K' }, grid: { color: '#f1f5f9' } },
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                title: (items) => labels[items[0].dataIndex],
                label: (item) => `거래량: ${item.raw.toLocaleString()}`,
              },
            },
          },
        },
      });
    </script>
  <% } %>
</body>
</html>
